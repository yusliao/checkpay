# ============================================================
# CheckPay 环境变量配置示例
# 复制此文件为 .env，填入实际值后启动 docker-compose
# ============================================================

# ── 数据库 ───────────────────────────────────────────────────
DB_PASSWORD=admin123

# ── MinIO 对象存储 ────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=checkpay-files

# ── Web 应用端口 ──────────────────────────────────────────────
WEB_PORT=8080

# ── 腾讯混元 OCR（主引擎）────────────────────────────────────
# 前往 https://console.cloud.tencent.com/cam/capi 获取
# 留空则使用 Mock（开发/测试用，返回随机假数据）
HUNYUAN_SECRET_ID=
HUNYUAN_SECRET_KEY=
HUNYUAN_REGION=ap-guangzhou

# OCR 模型名（默认 hunyuan-vision，无需修改）
OCR_MODEL=hunyuan-vision
OCR_MAX_RETRIES=3
OCR_RETRY_DELAY_MS=3000

# ── Azure AI Vision OCR（对比引擎，可选）─────────────────────
# 服务：Azure AI Vision（Computer Vision Read API）
# 前往 Azure Portal → 创建 "Computer Vision" 资源 → 获取 Endpoint 和 Key
# 留空则跳过 Azure 引擎，复核页面仅显示混元结果
AZURE_VISION_ENDPOINT=
AZURE_VISION_API_KEY=
