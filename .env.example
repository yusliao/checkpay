# ============================================================
# CheckPay 环境变量配置示例
# 复制此文件为 .env，填入实际值后启动 docker-compose
# ============================================================

# ── 数据库 ───────────────────────────────────────────────────
DB_PASSWORD=admin123

# ── MinIO 对象存储 ────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=checkpay-files

# ── Web 应用端口 ──────────────────────────────────────────────
WEB_PORT=8080

OCR_MAX_RETRIES=3
OCR_RETRY_DELAY_MS=3000
OCR_AMOUNT_VALIDATION_ENABLED=true
OCR_AMOUNT_VALIDATION_TRIGGER_CONFIDENCE_THRESHOLD=0.85
OCR_AMOUNT_VALIDATION_FAIL_OPEN=true
# 支票主 OCR：是否在 Vision Read 之外再调一次 Document Intelligence prebuilt-check.us 做结构化融合（增加成本与延迟）
OCR_PREBUILT_CHECK_ENRICH_PRIMARY_RESULT=false
# 支票「提交入库」成功后是否自动写入 ocr_training_samples（草稿保存不写）；为 true 且与 OCR 完全一致时可不写入（见下一项）
OCR_TRAINING_AUTO_SAMPLE_ON_CHECK_SUBMIT=true
OCR_TRAINING_AUTO_SAMPLE_REQUIRE_DIFF=true
OCR_TRAINING_AUTO_SAMPLE_DEDUP_BY_OCR_RESULT_ID=true
# Minimal | Verbose | Off — 自动训练样本日志详细程度
OCR_TRAINING_AUTO_SAMPLE_LOG_VERBOSITY=Minimal
# 支票训练纠偏：StrongOnly（默认）| Similarity（全文 Dice 相似度 + 低置信字段合并）
OCR_CHECK_AZURE_TRAINING_CORRECTION_MODE=Similarity
OCR_CHECK_AZURE_TRAINING_CORRECTION_MIN_SIMILARITY=0.80
OCR_CHECK_AZURE_TRAINING_CORRECTION_SIMILARITY_MAX_FIELD_CONFIDENCE=0.62
OCR_CHECK_AZURE_TRAINING_CORRECTION_CLUSTER_MIN_SAMPLES=3
OCR_CHECK_AZURE_TRAINING_CORRECTION_SAMPLE_MIN_AGE_MINUTES=30
OCR_CHECK_AZURE_TRAINING_CORRECTION_REQUIRE_TEMPLATE_MATCH=true
OCR_CHECK_AZURE_TRAINING_CORRECTION_SUMMARY_ENABLED=true
OCR_CHECK_AZURE_TRAINING_CORRECTION_SUMMARY_FLUSH_MINUTES=15

# ── Azure AI Vision（支票/扣款识别主引擎：Read API）────────────
# 前往 Azure Portal → 创建 "Computer Vision" 或含 Vision 的多服务资源 → Endpoint + Key
# 留空则 Worker 无法完成识别（Web 端扣款导入等仍可用 Mock，取决于 appsettings）
AZURE_VISION_ENDPOINT=
AZURE_VISION_API_KEY=

# ── Azure Document Intelligence（可选：手写金额二次校验，模型 prebuilt-check.us / v4）────
# 若仅配置了上面的 Computer Vision，主 OCR 可用，但「手写金额校验」会 401（Key 无权调用 DI）。
# 解决：在 Azure 创建「Document Intelligence」资源，把其 Endpoint/Key 填到下面；或改用同时包含 Vision+DI 的多服务资源并只填 AZURE_VISION_*。
# 留空则回退使用 AZURE_VISION_*（与主 OCR 同一套凭据）。
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_API_KEY=
