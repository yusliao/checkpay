{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish src/CheckPay.Web/CheckPay.Web.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "dotnet out/CheckPay.Web.dll",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
