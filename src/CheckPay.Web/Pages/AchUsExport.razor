@page "/reports/ach-us"
@attribute [Authorize(Roles = "USFinance,Admin")]
@using System.Text
@using CheckPay.Application.Common
@using CheckPay.Application.Common.Interfaces
@using CheckPay.Domain.Entities
@using CheckPay.Domain.Enums
@using Microsoft.EntityFrameworkCore
@inject IApplicationDbContext DbContext
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IAuditLogService AuditLog

<PageTitle>ACH 支票导出（美国财务） - CheckPay</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">ACH 支票导出（美国财务）</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    只读列表，按上传日期筛选；可下载 CSV 供银行界面粘贴。美财/管理员可标记 ACH 扣款成功；待核查状态下可撤销成功标记（银行拒付/冲正）或撤销支票与扣款的关联。
</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="6" md="3">
            <MudDatePicker @bind-Date="_from" Label="上传开始" />
        </MudItem>
        <MudItem xs="6" md="3">
            <MudDatePicker @bind-Date="_to" Label="上传结束" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string"
                       Value="_selectedPayee"
                       ValueChanged="OnPayeeChangedAsync"
                       Label="收款方"
                       Clearable="true">
                <MudSelectItem Value="@CheungKongPayee">CHEUNG KONG HOLDING INC</MudSelectItem>
                <MudSelectItem Value="@MaxwellPayee">MAXWELL TRADING</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3" Class="d-flex align-end flex-wrap" Style="gap:8px">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync" Disabled="@_loading">查询</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="ExportCsvAsync" Disabled="@(!_rows.Any() || _exporting)">导出 CSV（全部）</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="ExportFailedDebitAsync" Disabled="@(!_failedRows.Any() || _exporting)">导出扣款未成功</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable Items="_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading">
    <HeaderContent>
        <MudTh>上传日期</MudTh>
        <MudTh>客户编号</MudTh>
        <MudTh>手机号</MudTh>
        <MudTh>支票日期</MudTh>
        <MudTh>Bank</MudTh>
        <MudTh>RTN</MudTh>
        <MudTh>Account</MudTh>
        <MudTh>金额</MudTh>
        <MudTh>扣款成功</MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
        <MudTd>@context.Customer.CustomerCode</MudTd>
        <MudTd>@CustomerDisplay.MobileOrDash(context.Customer.MobilePhone)</MudTd>
        <MudTd>@context.CheckDate.ToString("yyyy-MM-dd")</MudTd>
        <MudTd>@(context.BankName ?? "—")</MudTd>
        <MudTd>@(context.RoutingNumber ?? "—")</MudTd>
        <MudTd>@(context.AccountNumber ?? "—")</MudTd>
        <MudTd>@context.CheckAmount.ToString("N2")</MudTd>
        <MudTd>@(context.AchDebitSucceeded ? "Y" : "N")</MudTd>
        <MudTd>
            <MudStack Row="true" Spacing="1" Class="flex-wrap">
                @if (!context.AchDebitSucceeded)
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Success"
                               OnClick="@(() => MarkDebitSuccess(context))">标为成功</MudButton>
                }
                @if (AchDebitSuccessMarkRevocation.CanRevokeSuccessMark(context))
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.MoneyOff"
                               Disabled="@(_revokingAchSuccessId == context.Id || _revokingAssociationId == context.Id)"
                               OnClick="@(() => RevokeAchSuccessMarkAsync(context))">
                        撤销成功
                    </MudButton>
                }
                @if (PendingReviewDebitRevocation.CanRevoke(context))
                {
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.LinkOff"
                               Disabled="@(_revokingAssociationId == context.Id || _revokingAchSuccessId == context.Id)"
                               OnClick="@(() => RevokeDebitAssociationAsync(context))">
                        撤销关联
                    </MudButton>
                }
            </MudStack>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private DateTime? _from = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
    private DateTime? _to = DateTime.UtcNow.Date;
    private List<CheckRecord> _rows = new();
    private List<CheckRecord> _failedRows = new();
    private bool _loading;
    private bool _exporting;
    private Guid? _revokingAssociationId;
    private Guid? _revokingAchSuccessId;
    private string? _selectedPayee;
    private bool _restoredPayeeFromLocalStorage;

    private const string CheungKongPayee = "CHEUNG KONG HOLDING INC";
    private const string MaxwellPayee = "MAXWELL TRADING";
    private const string PayeeStorageKey = "checkpay.achus.selectedPayee";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _restoredPayeeFromLocalStorage) return;
        _restoredPayeeFromLocalStorage = true;

        try
        {
            var saved = await JS.InvokeAsync<string?>("checkPayStorageGet", PayeeStorageKey);
            if (saved == CheungKongPayee || saved == MaxwellPayee)
            {
                _selectedPayee = saved;
                await LoadAsync();
                StateHasChanged();
            }
        }
        catch
        {
            // 忽略浏览器存储读取异常（例如禁用存储）
        }
    }

    private async Task LoadAsync()
    {
        if (!_from.HasValue || !_to.HasValue) return;
        _loading = true;
        var start = DateTime.SpecifyKind(_from.Value.Date, DateTimeKind.Utc);
        var end = DateTime.SpecifyKind(_to.Value.Date.AddDays(1).AddTicks(-1), DateTimeKind.Utc);

        var query = DbContext.CheckRecords
            .AsNoTracking()
            .Include(c => c.Customer)
            .Include(c => c.DebitRecord)
            .Where(c => c.CreatedAt >= start && c.CreatedAt <= end)
            .AsQueryable();

        if (_selectedPayee == CheungKongPayee)
        {
            query = query.Where(c =>
                c.PayToOrderOf != null &&
                (EF.Functions.ILike(c.PayToOrderOf, "%CHEUNG KONG HOLDING INC%") ||
                 EF.Functions.ILike(c.PayToOrderOf, "%ALLIANCE FOOD GROUP%")));
        }
        else if (_selectedPayee == MaxwellPayee)
        {
            query = query.Where(c =>
                c.PayToOrderOf != null &&
                (EF.Functions.ILike(c.PayToOrderOf, "%MAXWELL TRADING%") ||
                 EF.Functions.ILike(c.PayToOrderOf, "%EXCEL FOOD SERVICES%")));
        }

        _rows = await query
            .OrderByDescending(c => c.CreatedAt)
            .ToListAsync();

        _failedRows = _rows.Where(c => c.SubmittedAt != null && !c.AchDebitSucceeded).ToList();
        _loading = false;
    }

    private async Task OnPayeeChangedAsync(string? payee)
    {
        _selectedPayee = payee;

        try
        {
            await JS.InvokeVoidAsync("checkPayStorageSet", PayeeStorageKey, payee);
        }
        catch
        {
            // 忽略浏览器存储写入异常（例如禁用存储）
        }

        await LoadAsync();
    }

    private async Task MarkDebitSuccess(CheckRecord row)
    {
        var tracked = await DbContext.CheckRecords.FirstOrDefaultAsync(c => c.Id == row.Id);
        if (tracked == null) return;
        tracked.AchDebitSucceeded = true;
        tracked.AchDebitSucceededAt = DateTime.UtcNow;
        tracked.AchDebitSuccessRevokedAt = null;
        tracked.UpdatedAt = DateTime.UtcNow;
        await DbContext.SaveChangesAsync();
        Snackbar.Add("已标记扣款成功", Severity.Success);
        await LoadAsync();
    }

    private async Task RevokeAchSuccessMarkAsync(CheckRecord row)
    {
        if (_revokingAchSuccessId.HasValue || _revokingAssociationId.HasValue) return;

        var options = new DialogOptions { MaxWidth = MaxWidth.Small };
        var confirmed = await DialogService.ShowMessageBoxAsync(
            title: "撤销扣款成功",
            message: $"支票 {row.CheckNumber}：取消「ACH 扣款成功」标记（银行拒付/冲正）。支票仍为待核查，不解除扣款关联。大陆财务将看到撤回提醒。确定继续？",
            yesText: "撤销成功标记",
            cancelText: "取消",
            options: options);
        if (confirmed != true) return;

        var id = row.Id;
        _revokingAchSuccessId = id;
        try
        {
            AchSuccessMarkRevokeResult result;
            try
            {
                result = await AchDebitSuccessMarkRevocation.TryRevokeAsync(DbContext, id);
            }
            catch (DbUpdateConcurrencyException)
            {
                Snackbar.Add("数据已被其他用户修改，请刷新后重试", Severity.Error);
                await LoadAsync();
                return;
            }

            if (!result.Success)
            {
                Snackbar.Add(result.ErrorMessage ?? "无法撤销", Severity.Warning);
                await LoadAsync();
                return;
            }

            var s = result.Snapshot!;
            await AuditLog.LogAsync(AuditAction.Update, "CheckRecord", id,
                new { s.AchDebitSucceeded, s.AchDebitSucceededAt },
                new { AchDebitSucceeded = false, AchDebitSucceededAt = (DateTime?)null, AchDebitSuccessRevoked = true });

            Snackbar.Add("已撤销扣款成功标记", Severity.Success);
            await LoadAsync();
        }
        finally
        {
            _revokingAchSuccessId = null;
        }
    }

    private async Task RevokeDebitAssociationAsync(CheckRecord row)
    {
        if (_revokingAssociationId.HasValue || _revokingAchSuccessId.HasValue) return;

        var options = new DialogOptions { MaxWidth = MaxWidth.Small };
        var confirmed = await DialogService.ShowMessageBoxAsync(
            title: "撤销扣款关联",
            message: $"支票 {row.CheckNumber}：将解除与当前银行扣款记录的关联，支票回到「待扣款」，扣款进入异常列表。确定继续？",
            yesText: "撤销",
            cancelText: "取消",
            options: options);
        if (confirmed != true) return;

        var id = row.Id;
        _revokingAssociationId = id;
        try
        {
            RevokeDebitAssociationResult result;
            try
            {
                result = await PendingReviewDebitRevocation.TryRevokeAsync(DbContext, id);
            }
            catch (DbUpdateConcurrencyException)
            {
                Snackbar.Add("数据已被其他用户修改，请刷新后重试", Severity.Error);
                await LoadAsync();
                return;
            }

            if (!result.Success)
            {
                Snackbar.Add(result.ErrorMessage ?? "无法撤销", Severity.Warning);
                await LoadAsync();
                return;
            }

            var s = result.Snapshot!;
            await AuditLog.LogAsync(AuditAction.Update, "CheckRecord", id,
                new { Status = s.CheckStatus, s.AchDebitSucceeded, LinkedDebitId = s.DebitId },
                new
                {
                    Status = CheckStatus.PendingDebit,
                    AchDebitSucceeded = false,
                    RevokedDebitId = s.DebitId,
                    DebitNowUnmatched = true
                });

            Snackbar.Add("已撤销扣款关联", Severity.Success);
            await LoadAsync();
        }
        finally
        {
            _revokingAssociationId = null;
        }
    }

    private async Task ExportCsvAsync() => await ExportRowsAsync(_rows, "ach_us_all");

    private async Task ExportFailedDebitAsync() => await ExportRowsAsync(_failedRows, "ach_us_failed_debit");

    private async Task ExportRowsAsync(List<CheckRecord> rows, string prefix)
    {
        _exporting = true;
        try
        {
            var sb = new StringBuilder();
            sb.AppendLine("UploadDate,CustomerCode,MobilePhone,CheckDate,BankName,RoutingNumber,AccountNumber,AccountType,AccountHolderName,AccountAddress,CheckNumber,Amount,Note,SubmittedAtUtc,AchDebitSucceeded,InvoiceNumbers,PaymentPeriod,CompanyName,CustomerCompanyNewRelationshipWarning");
            foreach (var c in rows)
            {
                sb.AppendLine(string.Join(',',
                    Csv(c.CreatedAt.ToUniversalTime().ToString("yyyy-MM-dd")),
                    Csv(c.Customer.CustomerCode),
                    Csv(c.Customer.MobilePhone),
                    Csv(c.CheckDate.ToString("yyyy-MM-dd")),
                    Csv(c.BankName),
                    Csv(c.RoutingNumber),
                    Csv(c.AccountNumber),
                    Csv(c.AccountType),
                    Csv(c.AccountHolderName),
                    Csv(c.AccountAddress),
                    Csv(c.CheckNumber),
                    c.CheckAmount.ToString("F2", System.Globalization.CultureInfo.InvariantCulture),
                    Csv(c.Notes),
                    Csv(c.SubmittedAt?.ToUniversalTime().ToString("yyyy-MM-dd HH:mm")),
                    c.AchDebitSucceeded ? "Y" : "N",
                    Csv(c.InvoiceNumbers),
                    Csv(c.PaymentPeriodText),
                    Csv(c.CompanyName),
                    c.CustomerCompanyNewRelationshipWarning ? "Y" : "N"));
            }

            var bytes = Encoding.UTF8.GetPreamble().Concat(Encoding.UTF8.GetBytes(sb.ToString())).ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var name = $"{prefix}_{DateTime.UtcNow:yyyyMMddHHmm}.csv";
            await JS.InvokeVoidAsync("downloadFile", name, "text/csv;charset=utf-8", base64);
            Snackbar.Add($"已生成 {rows.Count} 行", Severity.Success);
        }
        finally
        {
            _exporting = false;
        }
    }

    private static string Csv(string? v)
    {
        if (string.IsNullOrEmpty(v)) return "\"\"";
        var esc = v.Replace("\"", "\"\"");
        return $"\"{esc}\"";
    }
}
