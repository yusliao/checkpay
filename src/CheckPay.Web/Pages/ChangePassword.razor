@page "/change-password"
@using Microsoft.AspNetCore.Authorization
@using CheckPay.Infrastructure.Data
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@attribute [Authorize]
@inject ApplicationDbContext DbContext
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>修改密码 - CheckPay</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-8">
        <MudText Typo="Typo.h4" GutterBottom="true">修改密码</MudText>

        <MudTextField @bind-Value="_oldPassword" Label="当前密码" Variant="Variant.Outlined"
                      InputType="InputType.Password" Class="mt-4" />
        <MudTextField @bind-Value="_newPassword" Label="新密码" Variant="Variant.Outlined"
                      InputType="InputType.Password" Class="mt-4" />
        <MudTextField @bind-Value="_confirmPassword" Label="确认新密码" Variant="Variant.Outlined"
                      InputType="InputType.Password" Class="mt-4" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                   Class="mt-4" OnClick="HandleChangePassword"
                   Disabled="@(_isChanging || string.IsNullOrWhiteSpace(_oldPassword) || string.IsNullOrWhiteSpace(_newPassword) || string.IsNullOrWhiteSpace(_confirmPassword))">
            @if (_isChanging)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                <MudText Class="ml-2">修改中...</MudText>
            }
            else
            {
                <MudText>确认修改</MudText>
            }
        </MudButton>

        <MudButton Variant="Variant.Text" Color="Color.Default" FullWidth="true"
                   Class="mt-2" OnClick="@(() => Navigation.NavigateTo("/"))">
            取消
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private string _oldPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _isChanging;

    private async Task HandleChangePassword()
    {
        _isChanging = true;

        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add("新密码与确认密码不一致", Severity.Error);
            _isChanging = false;
            return;
        }

        if (_newPassword.Length < 6)
        {
            Snackbar.Add("新密码长度至少6位", Severity.Warning);
            _isChanging = false;
            return;
        }

        var authState = await AuthenticationStateTask!;
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrEmpty(userId))
        {
            Snackbar.Add("用户信息无效，请重新登录", Severity.Error);
            _isChanging = false;
            return;
        }

        var user = await DbContext.Users.FirstOrDefaultAsync(u => u.Id == Guid.Parse(userId));

        if (user == null || !BCrypt.Net.BCrypt.Verify(_oldPassword, user.PasswordHash))
        {
            Snackbar.Add("当前密码错误", Severity.Error);
            _isChanging = false;
            return;
        }

        user.PasswordHash = BCrypt.Net.BCrypt.HashPassword(_newPassword);
        user.UpdatedAt = DateTime.UtcNow;
        await DbContext.SaveChangesAsync();

        Snackbar.Add("密码修改成功", Severity.Success);
        Navigation.NavigateTo("/");
    }
}
