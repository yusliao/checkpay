@page "/records"
@attribute [Authorize]
@using CheckPay.Application.Common
@using CheckPay.Application.Common.Interfaces
@using CheckPay.Domain.Entities
@using CheckPay.Domain.Enums
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.WebUtilities
@using System.Linq
@inject IApplicationDbContext DbContext
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IAuditLogService AuditLog
@inject IBlobStorageService BlobStorage

<PageTitle>收款记录 - CheckPay</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">收款记录</MudText>

@* 筛选栏 *@
<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect @bind-Value="_filterStatus" Label="状态" Clearable="true" T="CheckStatus?" Dense="true">
                <MudSelectItem Value="@((CheckStatus?)CheckStatus.PendingDebit)">待扣款</MudSelectItem>
                <MudSelectItem Value="@((CheckStatus?)CheckStatus.PendingReview)">待核查</MudSelectItem>
                <MudSelectItem Value="@((CheckStatus?)CheckStatus.Confirmed)">已确认</MudSelectItem>
                <MudSelectItem Value="@((CheckStatus?)CheckStatus.Questioned)">存疑</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudTextField @bind-Value="_filterCheckNumber" Label="支票号" Dense="true" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudDatePicker @bind-Date="_filterDateFrom" Label="开始日期" Dense="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <MudDatePicker @bind-Date="_filterDateTo" Label="结束日期" Dense="true" />
        </MudItem>
        <MudItem xs="12" sm="12" md="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilter" FullWidth="true">搜索</MudButton>
            <MudButton Variant="Variant.Outlined" Class="ml-2" OnClick="ClearFilter" FullWidth="true">重置</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@* 记录表格（服务端分页：Count + Skip/Take） *@
<MudTable Items="@_records" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading"
          OnRowClick="OnRowClick" T="CheckRecord" RowClass="cursor-pointer" Dense="true">
    <HeaderContent>
        <MudTh>支票号</MudTh>
        <MudTh>客户</MudTh>
        <MudTh>手机号</MudTh>
        <MudTh>RTN(后4)</MudTh>
        <MudTh>提交</MudTh>
        <MudTh>支票金额</MudTh>
        <MudTh>扣款金额</MudTh>
        <MudTh>日期</MudTh>
        <MudTh>状态</MudTh>
        <MudTh Style="width:88px">操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="支票号">@context.CheckNumber</MudTd>
        <MudTd DataLabel="客户">@context.Customer?.CustomerName</MudTd>
        <MudTd DataLabel="手机号">@CustomerDisplay.MobileOrDash(context.Customer?.MobilePhone)</MudTd>
        <MudTd DataLabel="RTN">@MaskRtn(context.RoutingNumber)</MudTd>
        <MudTd DataLabel="提交">
            @if (context.SubmittedAt.HasValue)
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Success">已提交</MudChip>
            }
            else
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Warning">草稿</MudChip>
            }
        </MudTd>
        <MudTd DataLabel="支票金额">@context.CheckAmount.ToString("C")</MudTd>
        <MudTd DataLabel="扣款金额">
            @if (context.DebitRecord != null)
            {
                @context.DebitRecord.DebitAmount.ToString("C")
            }
            else
            {
                <MudText Color="Color.Secondary">—</MudText>
            }
        </MudTd>
        <MudTd DataLabel="日期">@context.CheckDate.ToShortDateString()</MudTd>
        <MudTd DataLabel="状态">
            <MudChip T="string" Size="Size.Small" Color="GetStatusColor(context.Status)">
                @GetStatusText(context.Status)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="操作" @onclick:stopPropagation="true">
            @if (CanEditSubmittedCheck(context))
            {
                <AuthorizeView Roles="Sales,USFinance,Admin">
                    <Authorized Context="authRow">
                        <MudIconButton Icon="@Icons.Material.Filled.EditNote" Color="Color.Primary" Size="Size.Small"
                                       title="编辑票面信息（已提交且未 ACH 扣款成功）"
                                       OnClick="@(() => OpenSubmittedEditDialogAsync(context))" />
                    </Authorized>
                </AuthorizeView>
            }
        </MudTd>
    </RowTemplate>
</MudTable>

<MudStack Spacing="1" Class="mt-2 mb-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
        <MudText Typo="Typo.body2" Color="Color.Secondary">共 @_totalCheckRecords 条</MudText>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.body2" Color="Color.Secondary">每页</MudText>
            <MudSelect T="int" Value="_checkPageSize" ValueChanged="OnCheckPageSizeChangedAsync" Dense="true" Style="min-width:88px">
                <MudSelectItem Value="10">10</MudSelectItem>
                <MudSelectItem Value="20">20</MudSelectItem>
                <MudSelectItem Value="50">50</MudSelectItem>
            </MudSelect>
        </MudStack>
    </MudStack>
    @if (_checkTotalPages > 1)
    {
        <MudStack Row="true" Justify="Justify.Center" Class="pt-1">
            <MudPagination Count="_checkTotalPages" Selected="_checkPage" SelectedChanged="OnCheckPageChangedAsync"
                           ShowFirstButton="true" ShowLastButton="true" BoundaryCount="1" MiddleCount="3" />
        </MudStack>
    }
</MudStack>

@* 右侧 Drawer 详情 *@
<MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Elevation="2" Variant="DrawerVariant.Temporary" Width="400px">
    @if (_selectedRecord != null)
    {
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">支票详情</MudText>
        </MudDrawerHeader>
        <MudList T="string" Dense="true" Class="px-4">
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">支票号</MudText>
                <MudText>@_selectedRecord.CheckNumber</MudText>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">客户</MudText>
                <MudText>@_selectedRecord.Customer?.CustomerName</MudText>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">客户手机号</MudText>
                <MudText>@CustomerDisplay.MobileOrDash(_selectedRecord.Customer?.MobilePhone)</MudText>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">公司名称</MudText>
                <MudText>@(_selectedRecord.CompanyName ?? "—")</MudText>
            </MudListItem>
            <MudDivider />
            @if (_selectedRecord.CustomerCompanyNewRelationshipWarning)
            {
                <MudListItem T="string">
                    <MudAlert Severity="Severity.Error" Dense="true">新的客户关系：公司名称未在该客户编号下登记</MudAlert>
                </MudListItem>
                <MudDivider />
            }
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">支票金额</MudText>
                <MudText>@_selectedRecord.CheckAmount.ToString("C")</MudText>
            </MudListItem>
            <MudDivider />
            @if (_selectedRecord.DebitRecord != null)
            {
                <MudListItem T="string">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">扣款金额</MudText>
                    <MudText>@_selectedRecord.DebitRecord.DebitAmount.ToString("C")</MudText>
                </MudListItem>
                <MudDivider />
            }
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">支票日期</MudText>
                <MudText>@_selectedRecord.CheckDate.ToString("yyyy-MM-dd")</MudText>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">状态</MudText>
                <MudChip T="string" Size="Size.Small" Color="GetStatusColor(_selectedRecord.Status)">
                    @GetStatusText(_selectedRecord.Status)
                </MudChip>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">备注</MudText>
                <MudText>@(_selectedRecord.Notes ?? "—")</MudText>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">提交状态</MudText>
                <MudText>@(_selectedRecord.SubmittedAt.HasValue ? $"已提交 {_selectedRecord.SubmittedAt:yyyy-MM-dd HH:mm} UTC" : "草稿")</MudText>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">ACH 扣款成功</MudText>
                <MudText>@(_selectedRecord.AchDebitSucceeded ? $"是 ({_selectedRecord.AchDebitSucceededAt:yyyy-MM-dd})" : "否")</MudText>
            </MudListItem>
            @if (_selectedRecord.AchDebitSuccessRevokedAt != null)
            {
                <MudDivider />
                <MudListItem T="string">
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="ma-0">
                        美财已于 @_selectedRecord.AchDebitSuccessRevokedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        撤回「ACH 扣款成功」标记（可能为银行后续拒付/冲正）。请大陆财务核对该笔实际到账情况后再确认核查结论。
                    </MudAlert>
                </MudListItem>
            }
            <MudDivider />
            @if (_selectedRecord.CustomerMasterMismatchWarning)
            {
                <MudListItem T="string">
                    <MudAlert Severity="Severity.Warning" Dense="true">与客户主数据期望银行/持有人不一致</MudAlert>
                </MudListItem>
                <MudDivider />
            }
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Routing / Account</MudText>
                <MudText Typo="Typo.body2">@MaskRtn(_selectedRecord.RoutingNumber) / @(string.IsNullOrEmpty(_selectedRecord.AccountNumber) ? "—" : "****" + _selectedRecord.AccountNumber[^Math.Min(4, _selectedRecord.AccountNumber.Length)..])</MudText>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">银行 / 持有人</MudText>
                <MudText>@(_selectedRecord.BankName ?? "—") / @(_selectedRecord.AccountHolderName ?? "—")</MudText>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">发票 / 期间</MudText>
                <MudText>@(_selectedRecord.InvoiceNumbers ?? "—") / @(_selectedRecord.PaymentPeriodText ?? "—")</MudText>
            </MudListItem>
            <MudDivider />
            <MudListItem T="string">
                <MudText Typo="Typo.caption" Color="Color.Secondary">创建时间</MudText>
                <MudText>@_selectedRecord.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
            </MudListItem>
        </MudList>

        @* 图片预览 *@
        @if (!string.IsNullOrEmpty(_selectedRecord.ImageUrl))
        {
            <MudPaper Class="ma-4 pa-2">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">支票图片</MudText>
                <MudImage Src="@GetProxyImageUrl(_selectedRecord.ImageUrl)" Alt="支票图片" Class="rounded" Style="width:100%" />
            </MudPaper>
        }

        @* 草稿：补全 ACH 并正式提交（与上传页「提交入库」校验一致） *@
        @if (_selectedRecord.SubmittedAt == null)
        {
            <AuthorizeView Roles="Sales,USFinance,Admin">
                <Authorized>
                    <MudPaper Class="ma-4 pa-3" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">草稿 — 提交入库</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2" Style="display:block">
                            保存草稿时未要求填写完整 ACH；请补全后提交，规则与上传页「提交入库」相同。需修改支票号、金额、客户等请使用「编辑草稿」。
                        </MudText>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Class="mb-3"
                                   StartIcon="@Icons.Material.Filled.EditNote"
                                   OnClick="@(() => Navigation.NavigateTo($"/checks/draft/{_selectedRecord.Id}"))">
                            编辑草稿（完整表单，可多次保存）
                        </MudButton>
                        <MudTextField @bind-Value="_draftRouting" Label="Routing Number (9 位数字)" Variant="Variant.Outlined"
                                      Class="mb-2" MaxLength="9" Margin="Margin.Dense" />
                        <MudTextField @bind-Value="_draftAccount" Label="Account Number" Variant="Variant.Outlined"
                                      Class="mb-2" Margin="Margin.Dense" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   Disabled="@(_submittingDraft || _deletingDraft)"
                                   OnClick="SubmitDraftAsync">
                            @(_submittingDraft ? "提交中…" : "提交入库")
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true" Class="mt-2"
                                   StartIcon="@Icons.Material.Filled.DeleteOutline"
                                   Disabled="@(_submittingDraft || _deletingDraft)"
                                   OnClick="ConfirmDeleteDraftAsync">
                            @(_deletingDraft ? "删除中…" : "删除草稿")
                        </MudButton>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1" Style="display:block">
                            不再需要该笔时可删除草稿：记录与 OCR 结果将移除，已上传图片会尽量从存储删除，支票号可重新使用。
                        </MudText>
                    </MudPaper>
                </Authorized>
            </AuthorizeView>
        }

        @* 已提交：票面信息修正（未 ACH 扣款成功） *@
        @if (CanEditSubmittedCheck(_selectedRecord))
        {
            <AuthorizeView Roles="Sales,USFinance,Admin">
                <Authorized Context="authSubmittedEdit">
                    <MudPaper Class="ma-4 pa-3" Elevation="0" Outlined="true">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">票面信息</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2" Style="display:block">
                            已提交入库后可在此修正支票号、金额、客户、ACH 与抬头等；<strong>标记 ACH 扣款成功后不可再改</strong>。
                        </MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   StartIcon="@Icons.Material.Filled.EditNote"
                                   OnClick="@(() => OpenSubmittedEditDialogAsync(_selectedRecord!))">
                            编辑票面信息
                        </MudButton>
                    </MudPaper>
                </Authorized>
            </AuthorizeView>
        }

        @* 状态变更按钮（待核查时显示） *@
        @if (_selectedRecord.Status == CheckStatus.PendingReview)
        {
            <MudStack Row="true" Class="ma-4" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           OnClick="@(() => Navigation.NavigateTo($"/reviews/{_selectedRecord.Id}"))">
                    去核查
                </MudButton>
            </MudStack>
            <AuthorizeView Roles="USFinance,Admin" Context="authCtx">
                <Authorized>
                    @if (AchDebitSuccessMarkRevocation.CanRevokeSuccessMark(_selectedRecord))
                    {
                        <MudStack Class="mx-4 mb-2">
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.MoneyOff"
                                       Disabled="@(_revokingAchSuccess || _revokingDebit)"
                                       OnClick="RevokeAchSuccessForSelectedAsync">
                                @(_revokingAchSuccess ? "处理中…" : "撤销扣款成功")
                            </MudButton>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                银行已扣款后又失败/冲正时使用：仅取消「ACH 扣款成功」标记，不解除与扣款扫描记录的关联；大陆财务将看到撤回提醒。
                            </MudText>
                        </MudStack>
                    }
                    @if (PendingReviewDebitRevocation.CanRevoke(_selectedRecord.Status, _selectedRecord.DebitRecord))
                    {
                        <MudStack Class="mx-4 mb-4">
                            <MudButton Variant="Variant.Outlined" Color="Color.Warning" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.LinkOff"
                                       Disabled="@(_revokingDebit || _revokingAchSuccess)"
                                       OnClick="RevokeDebitForSelectedAsync">
                                @(_revokingDebit ? "处理中…" : "撤销扣款关联")
                            </MudButton>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                解除与当前银行扣款记录的关联，支票回到「待扣款」，扣款进入异常列表；并清除 ACH 成功及撤回标记。
                            </MudText>
                        </MudStack>
                    }
                </Authorized>
            </AuthorizeView>
        }
    }
</MudDrawer>

@code {
    private List<CheckRecord> _records = new();
    private int _totalCheckRecords;
    private int _checkPage = 1;
    private int _checkPageSize = 20;
    private int _checkTotalPages => Math.Max(1, (int)Math.Ceiling(_totalCheckRecords / (double)Math.Max(1, _checkPageSize)));
    private bool _loading = true;
    private bool _drawerOpen;
    private CheckRecord? _selectedRecord;
    private bool _revokingDebit;
    private bool _revokingAchSuccess;
    private bool _submittingDraft;
    private bool _deletingDraft;
    private string _draftRouting = "";
    private string _draftAccount = "";

    // 筛选条件
    private CheckStatus? _filterStatus;
    private string _filterCheckNumber = "";
    private DateTime? _filterDateFrom;
    private DateTime? _filterDateTo;

    protected override async Task OnInitializedAsync()
    {
        // 支持URL参数预设筛选（如Dashboard点击卡片跳转）
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("status", out var statusStr))
        {
            if (Enum.TryParse<CheckStatus>(statusStr, out var s))
                _filterStatus = s;
        }
        await LoadRecords();
    }

    private IQueryable<CheckRecord> BuildCheckRecordsFilterQuery()
    {
        var query = DbContext.CheckRecords.AsQueryable();
        if (_filterStatus.HasValue)
            query = query.Where(c => c.Status == _filterStatus.Value);
        if (!string.IsNullOrWhiteSpace(_filterCheckNumber))
            query = query.Where(c => c.CheckNumber.Contains(_filterCheckNumber));
        if (_filterDateFrom.HasValue)
            query = query.Where(c => c.CheckDate >= DateTime.SpecifyKind(_filterDateFrom.Value, DateTimeKind.Utc));
        if (_filterDateTo.HasValue)
            query = query.Where(c => c.CheckDate <= DateTime.SpecifyKind(_filterDateTo.Value.AddDays(1).AddTicks(-1), DateTimeKind.Utc));
        return query;
    }

    private IQueryable<CheckRecord> BuildCheckRecordsListQuery() =>
        BuildCheckRecordsFilterQuery()
            .Include(c => c.Customer)
            .ThenInclude(cu => cu.CompanyNames)
            .Include(c => c.DebitRecord);

    private async Task LoadRecords()
    {
        _loading = true;
        try
        {
            _totalCheckRecords = await BuildCheckRecordsFilterQuery().CountAsync();
            if (_checkPage > _checkTotalPages)
                _checkPage = _checkTotalPages;
            if (_checkPage < 1)
                _checkPage = 1;

            var skip = (_checkPage - 1) * _checkPageSize;
            _records = await BuildCheckRecordsListQuery()
                .OrderByDescending(c => c.CreatedAt)
                .Skip(skip)
                .Take(_checkPageSize)
                .ToListAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnCheckPageChangedAsync(int page)
    {
        _checkPage = page;
        await LoadRecords();
    }

    private async Task OnCheckPageSizeChangedAsync(int size)
    {
        _checkPageSize = size;
        _checkPage = 1;
        await LoadRecords();
    }

    private async Task RefreshSelectedRecordAsync(Guid checkId)
    {
        _selectedRecord = await BuildCheckRecordsListQuery()
            .AsNoTracking()
            .FirstOrDefaultAsync(c => c.Id == checkId);
        InitDraftEditFields();
    }

    private async Task ApplyFilter()
    {
        _checkPage = 1;
        await LoadRecords();
    }

    private async Task ClearFilter()
    {
        _filterStatus = null;
        _filterCheckNumber = "";
        _filterDateFrom = null;
        _filterDateTo = null;
        _checkPage = 1;
        await LoadRecords();
    }

    private void OnRowClick(TableRowClickEventArgs<CheckRecord> args)
    {
        _selectedRecord = args.Item;
        InitDraftEditFields();
        _drawerOpen = true;
    }

    private static bool CanEditSubmittedCheck(CheckRecord? c) =>
        c is { SubmittedAt: not null, AchDebitSucceeded: false };

    private async Task OpenSubmittedEditDialogAsync(CheckRecord record)
    {
        if (!CanEditSubmittedCheck(record))
            return;

        var parameters = new DialogParameters<CheckRecordSubmittedEditDialog>
        {
            { x => x.CheckRecordId, record.Id }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog = await DialogService.ShowAsync<CheckRecordSubmittedEditDialog>("编辑支票信息", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            await LoadRecords();
            if (_drawerOpen && _selectedRecord?.Id == record.Id)
                await RefreshSelectedRecordAsync(record.Id);
        }
    }

    private void InitDraftEditFields()
    {
        if (_selectedRecord == null || _selectedRecord.SubmittedAt != null)
        {
            _draftRouting = "";
            _draftAccount = "";
            return;
        }

        _draftRouting = _selectedRecord.RoutingNumber ?? "";
        _draftAccount = _selectedRecord.AccountNumber ?? "";
    }

    private static string? ValidateDraftAchForSubmit(string routing, string account)
    {
        var r = routing.Trim();
        if (r.Length != 9 || !r.All(char.IsDigit))
            return "Routing Number 须为 9 位数字";
        if (string.IsNullOrWhiteSpace(account))
            return "请填写 Account Number";
        return null;
    }

    private async Task SubmitDraftAsync()
    {
        if (_selectedRecord == null || _submittingDraft || _selectedRecord.SubmittedAt != null) return;

        var achErr = ValidateDraftAchForSubmit(_draftRouting, _draftAccount);
        if (!string.IsNullOrEmpty(achErr))
        {
            Snackbar.Add(achErr, Severity.Warning);
            return;
        }

        var checkId = _selectedRecord.Id;
        _submittingDraft = true;
        try
        {
            var tracked = await DbContext.CheckRecords.FirstOrDefaultAsync(c => c.Id == checkId);
            if (tracked == null)
            {
                Snackbar.Add("记录不存在", Severity.Error);
                await LoadRecords();
                _drawerOpen = false;
                return;
            }

            if (tracked.SubmittedAt != null)
            {
                Snackbar.Add("该记录已提交", Severity.Info);
                await LoadRecords();
                await RefreshSelectedRecordAsync(checkId);
                return;
            }

            tracked.RoutingNumber = _draftRouting.Trim();
            tracked.AccountNumber = _draftAccount.Trim();
            tracked.SubmittedAt = DateTime.UtcNow;
            tracked.UpdatedAt = DateTime.UtcNow;

            try
            {
                await DbContext.SaveChangesAsync();
            }
            catch (DbUpdateConcurrencyException)
            {
                Snackbar.Add("数据已被其他用户修改，请刷新后重试", Severity.Error);
                await LoadRecords();
                await RefreshSelectedRecordAsync(checkId);
                return;
            }

            Snackbar.Add("草稿已正式提交入库", Severity.Success);
            await LoadRecords();
            await RefreshSelectedRecordAsync(checkId);
        }
        finally
        {
            _submittingDraft = false;
        }
    }

    private async Task ConfirmDeleteDraftAsync()
    {
        if (_selectedRecord == null || _deletingDraft || _submittingDraft) return;

        var options = new DialogOptions { MaxWidth = MaxWidth.Small };
        var confirmed = await DialogService.ShowMessageBoxAsync(
            title: "删除草稿",
            message: $"确定删除支票号 {_selectedRecord.CheckNumber} 的草稿吗？此操作不可恢复，支票号将可重新用于上传。",
            yesText: "删除",
            cancelText: "取消",
            options: options);
        if (confirmed != true) return;

        await DeleteDraftAsync();
    }

    private async Task DeleteDraftAsync()
    {
        if (_selectedRecord == null) return;

        var checkId = _selectedRecord.Id;
        _deletingDraft = true;
        try
        {
            var tracked = await DbContext.CheckRecords
                .Include(c => c.DebitRecord)
                .FirstOrDefaultAsync(c => c.Id == checkId);

            if (tracked == null)
            {
                Snackbar.Add("记录不存在", Severity.Error);
                _drawerOpen = false;
                _selectedRecord = null;
                await LoadRecords();
                return;
            }

            if (tracked.SubmittedAt != null)
            {
                Snackbar.Add("已提交的记录不能作为草稿删除", Severity.Warning);
                await LoadRecords();
                await RefreshSelectedRecordAsync(checkId);
                return;
            }

            if (tracked.Status != CheckStatus.PendingDebit || tracked.DebitRecord != null)
            {
                Snackbar.Add("仅允许删除未关联扣款、且状态为待扣款的草稿", Severity.Warning);
                await LoadRecords();
                await RefreshSelectedRecordAsync(checkId);
                return;
            }

            var checkNumber = tracked.CheckNumber;
            var imageUrl = tracked.ImageUrl;
            var ocrResultId = tracked.OcrResultId;

            var linkedDebits = await DbContext.DebitRecords
                .Where(d => d.CheckRecordId == checkId)
                .ToListAsync();
            var now = DateTime.UtcNow;
            foreach (var d in linkedDebits)
            {
                d.CheckRecordId = null;
                d.DebitStatus = DebitStatus.Unmatched;
                d.UpdatedAt = now;
            }

            DbContext.CheckRecords.Remove(tracked);

            if (ocrResultId.HasValue)
            {
                var ocr = await DbContext.OcrResults.FirstOrDefaultAsync(o => o.Id == ocrResultId.Value);
                if (ocr != null)
                    DbContext.OcrResults.Remove(ocr);
            }

            try
            {
                await DbContext.SaveChangesAsync();
            }
            catch (DbUpdateConcurrencyException)
            {
                Snackbar.Add("数据已被其他用户修改，请刷新后重试", Severity.Error);
                await LoadRecords();
                await RefreshSelectedRecordAsync(checkId);
                return;
            }

            if (!string.IsNullOrEmpty(imageUrl))
            {
                try
                {
                    await BlobStorage.DeleteAsync(imageUrl);
                }
                catch
                {
                    // 存储删除失败不阻断业务；记录已从库中移除
                }
            }

            await AuditLog.LogAsync(AuditAction.Delete, "CheckRecord", checkId,
                new { CheckNumber = checkNumber, SubmittedAt = (DateTime?)null, Status = CheckStatus.PendingDebit },
                new { Note = "草稿删除" });

            Snackbar.Add($"草稿「{checkNumber}」已删除", Severity.Success);
            _drawerOpen = false;
            _selectedRecord = null;
            await LoadRecords();
        }
        finally
        {
            _deletingDraft = false;
        }
    }

    private async Task RevokeAchSuccessForSelectedAsync()
    {
        if (_selectedRecord == null || _revokingAchSuccess || _revokingDebit) return;

        var checkId = _selectedRecord.Id;
        var options = new DialogOptions { MaxWidth = MaxWidth.Small };
        var confirmed = await DialogService.ShowMessageBoxAsync(
            title: "撤销扣款成功",
            message: "将取消本单的「ACH 扣款成功」标记（适用于银行后续拒付或冲正）。支票仍保持待核查，与扣款记录的关联不变。大陆财务将看到「扣款成功已撤回」提醒。确定继续？",
            yesText: "撤销成功标记",
            cancelText: "取消",
            options: options);
        if (confirmed != true) return;

        _revokingAchSuccess = true;
        try
        {
            AchSuccessMarkRevokeResult result;
            try
            {
                result = await AchDebitSuccessMarkRevocation.TryRevokeAsync(DbContext, checkId);
            }
            catch (DbUpdateConcurrencyException)
            {
                Snackbar.Add("数据已被其他用户修改，请刷新后重试", Severity.Error);
                await LoadRecords();
                await RefreshSelectedRecordAsync(checkId);
                return;
            }

            if (!result.Success)
            {
                Snackbar.Add(result.ErrorMessage ?? "无法撤销", Severity.Warning);
                await LoadRecords();
                await RefreshSelectedRecordAsync(checkId);
                return;
            }

            var s = result.Snapshot!;
            await AuditLog.LogAsync(AuditAction.Update, "CheckRecord", checkId,
                new { s.AchDebitSucceeded, s.AchDebitSucceededAt },
                new { AchDebitSucceeded = false, AchDebitSucceededAt = (DateTime?)null, AchDebitSuccessRevoked = true });

            Snackbar.Add("已撤销扣款成功标记", Severity.Success);
            await LoadRecords();
            await RefreshSelectedRecordAsync(checkId);
        }
        finally
        {
            _revokingAchSuccess = false;
        }
    }

    private async Task RevokeDebitForSelectedAsync()
    {
        if (_selectedRecord == null || _revokingDebit) return;

        var checkId = _selectedRecord.Id;
        var options = new DialogOptions { MaxWidth = MaxWidth.Small };
        var confirmed = await DialogService.ShowMessageBoxAsync(
            title: "撤销扣款关联",
            message: "将解除本条支票与当前银行扣款记录的关联，支票回到「待扣款」，扣款进入异常列表待重新关联；ACH 成功及撤回标记将一并清除。确定继续？",
            yesText: "撤销",
            cancelText: "取消",
            options: options);
        if (confirmed != true) return;

        _revokingDebit = true;
        try
        {
            RevokeDebitAssociationResult result;
            try
            {
                result = await PendingReviewDebitRevocation.TryRevokeAsync(DbContext, checkId);
            }
            catch (DbUpdateConcurrencyException)
            {
                Snackbar.Add("数据已被其他用户修改，请刷新后重试", Severity.Error);
                await LoadRecords();
                await RefreshSelectedRecordAsync(checkId);
                return;
            }

            if (!result.Success)
            {
                Snackbar.Add(result.ErrorMessage ?? "无法撤销", Severity.Warning);
                await LoadRecords();
                await RefreshSelectedRecordAsync(checkId);
                return;
            }

            var s = result.Snapshot!;
            await AuditLog.LogAsync(AuditAction.Update, "CheckRecord", checkId,
                new { Status = s.CheckStatus, s.AchDebitSucceeded, LinkedDebitId = s.DebitId },
                new
                {
                    Status = CheckStatus.PendingDebit,
                    AchDebitSucceeded = false,
                    RevokedDebitId = s.DebitId,
                    DebitNowUnmatched = true
                });

            Snackbar.Add("已撤销扣款关联", Severity.Success);
            await LoadRecords();
            await RefreshSelectedRecordAsync(checkId);
            if (_selectedRecord == null)
                _drawerOpen = false;
        }
        finally
        {
            _revokingDebit = false;
        }
    }

    private Color GetStatusColor(CheckStatus status) => status switch
    {
        CheckStatus.PendingDebit   => Color.Warning,
        CheckStatus.PendingReview  => Color.Info,
        CheckStatus.Confirmed      => Color.Success,
        CheckStatus.Questioned     => Color.Error,
        _                          => Color.Default
    };

    private string GetStatusText(CheckStatus status) => status switch
    {
        CheckStatus.PendingDebit   => "待扣款",
        CheckStatus.PendingReview  => "待核查",
        CheckStatus.Confirmed      => "已确认",
        CheckStatus.Questioned     => "存疑",
        _                          => "未知"
    };

    private string GetProxyImageUrl(string? imageUrl)
    {
        if (string.IsNullOrEmpty(imageUrl)) return string.Empty;
        return $"/api/ImageProxy?url={Uri.EscapeDataString(imageUrl)}";
    }

    private static string MaskRtn(string? routing)
    {
        if (string.IsNullOrEmpty(routing) || routing.Length < 4) return "—";
        return "****" + routing[^4..];
    }
}
