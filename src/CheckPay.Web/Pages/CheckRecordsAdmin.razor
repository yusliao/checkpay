@page "/admin/check-records"
@attribute [Authorize(Roles = "Admin")]
@using CheckPay.Application.Common
@using CheckPay.Application.Common.Interfaces
@using CheckPay.Domain.Entities
@using CheckPay.Domain.Enums
@using Microsoft.EntityFrameworkCore
@inject IApplicationDbContext DbContext
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>支票记录管理 - CheckPay</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">支票记录管理（运维）</MudText>
    <MudButton Variant="Variant.Outlined" Color="Color.Default"
               StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="LoadData"
               Disabled="@_loading">
        刷新
    </MudButton>
</MudStack>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudStack Row="true" Spacing="2">
        <MudTextField @bind-Value="_filterCheckNumber" Label="支票号" Placeholder="输入支票号搜索"
                      Variant="Variant.Outlined" Dense="true" Style="width:200px" Clearable="true" />
        <MudSelect @bind-Value="_filterStatus" Label="状态" T="CheckStatus?" Dense="true" Clearable="true"
                   Variant="Variant.Outlined" Style="min-width:150px">
            <MudSelectItem Value="@((CheckStatus?)CheckStatus.PendingDebit)">待扣款</MudSelectItem>
            <MudSelectItem Value="@((CheckStatus?)CheckStatus.PendingReview)">待核查</MudSelectItem>
            <MudSelectItem Value="@((CheckStatus?)CheckStatus.Confirmed)">已确认</MudSelectItem>
            <MudSelectItem Value="@((CheckStatus?)CheckStatus.Questioned)">存疑</MudSelectItem>
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyFilter">搜索</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="ClearFilter">重置</MudButton>
    </MudStack>
</MudPaper>

<MudTable Items="@_filteredRecords" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" T="CheckRecord">
    <HeaderContent>
        <MudTh>支票号</MudTh>
        <MudTh>客户</MudTh>
        <MudTh>餐馆编号</MudTh>
        <MudTh>支票金额</MudTh>
        <MudTh>日期</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="支票号">
            <MudLink Href="@($"/records/{context.Id}")" Color="Color.Inherit"
                     Underline="Underline.None">@context.CheckNumber</MudLink>
        </MudTd>
        <MudTd DataLabel="客户">@context.Customer?.CustomerName</MudTd>
        <MudTd DataLabel="餐馆编号">@CustomerDisplay.MobileOrDash(context.Customer?.MobilePhone)</MudTd>
        <MudTd DataLabel="支票金额">@context.CheckAmount.ToString("C")</MudTd>
        <MudTd DataLabel="日期">@context.CheckDate.ToShortDateString()</MudTd>
        <MudTd DataLabel="状态">
            <MudChip T="string" Size="Size.Small" Color="GetStatusColor(context.Status)">
                @GetStatusText(context.Status)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="操作">
            @if (context.Status == CheckStatus.Confirmed)
            {
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                           title="已确认记录不可删除">
                    删除
                </MudButton>
            }
            else
            {
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                           OnClick="@(() => ConfirmDelete(context))">
                    删除
                </MudButton>
            }
        </MudTd>
    </RowTemplate>
    <FooterContent>
        <MudTd colspan="7">
            <MudText Typo="Typo.caption">共 @_filteredRecords.Count 条记录（筛选后）</MudText>
        </MudTd>
    </FooterContent>
</MudTable>


@code {
    private List<CheckRecord> _records = new();
    private List<CheckRecord> _filteredRecords = new();
    private bool _loading = true;

    private string _filterCheckNumber = string.Empty;
    private CheckStatus? _filterStatus;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        _records = await DbContext.CheckRecords
            .Include(c => c.Customer)
            .OrderByDescending(c => c.CheckDate)
            .ToListAsync();
        ApplyFilterInternal();
        _loading = false;
    }

    private void ApplyFilterInternal()
    {
        var query = _records.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_filterCheckNumber))
            query = query.Where(c => c.CheckNumber.Contains(_filterCheckNumber, StringComparison.OrdinalIgnoreCase));

        if (_filterStatus.HasValue)
            query = query.Where(c => c.Status == _filterStatus.Value);

        _filteredRecords = query.ToList();
    }

    private async Task ApplyFilter()
    {
        ApplyFilterInternal();
        await Task.CompletedTask;
    }

    private void ClearFilter()
    {
        _filterCheckNumber = string.Empty;
        _filterStatus = null;
        ApplyFilterInternal();
    }

    private async Task ConfirmDelete(CheckRecord record)
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall };
        var confirmed = await DialogService.ShowMessageBoxAsync(
            title: "确认删除",
            message: $"确定要删除支票记录 {record.CheckNumber} 吗？此操作不可恢复！",
            yesText: "删除",
            noText: null,
            cancelText: "取消",
            options: options);

        if (confirmed == true)
            await ExecuteDelete(record);
    }

    private async Task ExecuteDelete(CheckRecord record)
    {
        var tracked = await DbContext.CheckRecords.FindAsync(record.Id);
        if (tracked == null)
        {
            Snackbar.Add("记录不存在或已被删除", Severity.Error);
            await LoadData();
            return;
        }

        var linkedDebits = await DbContext.DebitRecords
            .Where(d => d.CheckRecordId == record.Id)
            .ToListAsync();
        var now = DateTime.UtcNow;
        foreach (var d in linkedDebits)
        {
            d.CheckRecordId = null;
            d.DebitStatus = DebitStatus.Unmatched;
            d.UpdatedAt = now;
        }

        DbContext.CheckRecords.Remove(tracked);
        await DbContext.SaveChangesAsync();

        Snackbar.Add($"支票记录 {record.CheckNumber} 已删除", Severity.Success);
        await LoadData();
    }

    private static Color GetStatusColor(CheckStatus status) => status switch
    {
        CheckStatus.PendingDebit   => Color.Info,
        CheckStatus.PendingReview  => Color.Warning,
        CheckStatus.Confirmed      => Color.Success,
        CheckStatus.Questioned     => Color.Error,
        _                          => Color.Default
    };

    private static string GetStatusText(CheckStatus status) => status switch
    {
        CheckStatus.PendingDebit   => "待扣款",
        CheckStatus.PendingReview  => "待核查",
        CheckStatus.Confirmed      => "已确认",
        CheckStatus.Questioned     => "存疑",
        _                          => status.ToString()
    };
}
