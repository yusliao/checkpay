@page "/checks/review/{Id:guid}"
@page "/checks/draft/{DraftId:guid}"
@attribute [Authorize(Roles = "Sales,USFinance,Admin")]
@using CheckPay.Application.Common.Interfaces
@using Microsoft.Extensions.Logging
@using CheckPay.Application.Common.Models
@using CheckPay.Domain.Entities
@using CheckPay.Domain.Enums
@using CheckPay.Application.Common
@using CheckPay.Worker.Services
@using CheckPay.Web.Common
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Configuration
@using System.Linq
@using System.Text.Json
@using System.Text.RegularExpressions
@inject IApplicationDbContext DbContext
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject OcrWorker OcrWorker
@inject IOcrService OcrService
@inject IAuditLogService AuditLog
@inject IConfiguration Configuration
@inject ICheckOcrTemplateResolver CheckOcrTemplateResolver
@inject ILogger<CheckReview> Logger

<PageTitle>@(_editingCheckRecordId.HasValue ? "编辑草稿 - CheckPay" : "复核支票 - CheckPay")</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@(_editingCheckRecordId.HasValue ? "编辑草稿" : "复核支票信息")</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (!string.IsNullOrEmpty(_initError))
{
    <MudAlert Severity="Severity.Error" Class="mb-3">@_initError</MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Navigation.NavigateTo("/records"))">返回收款记录</MudButton>
}
else if (ShowCheckEditForm())
{
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">支票图片</MudText>
                <MudImage Src="@GetProxyImageUrl()" Alt="支票图片" Class="rounded" />
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" GutterBottom="true">识别信息</MudText>

                @if (_editingCheckRecordId.HasValue)
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        正在编辑已保存的草稿，可多次修改后保存或提交入库。
                    </MudAlert>
                }
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                    OCR：Azure AI Vision Read（支票字段由全文解析）
                </MudText>
                <div class="mb-2">
                    <MudTextField @bind-Value="_checkNumber"
                                  Label="支票号"
                                  Required="true"
                                  Variant="Variant.Outlined"
                                  Style="@GetFieldStyle("checkNumber")"
                                  HelperText="@GetFieldHint("checkNumber")"
                                  HelperTextOnFocus="false"
                                  Adornment="@GetAdornment("checkNumber")"
                                  AdornmentColor="@GetAdornmentColor("checkNumber")"
                                  AdornmentIcon="@GetAdornmentIcon("checkNumber")" />
                </div>

                @* 金额 - 置信度颜色 *@
                <div class="mb-2">
                    <MudNumericField @bind-Value="_amount"
                                     Label="金额"
                                     Required="true"
                                     Format="N2"
                                     Variant="Variant.Outlined"
                                     Style="@GetFieldStyle("amount")"
                                     HelperText="@GetFieldHint("amount")"
                                     HelperTextOnFocus="false"
                                     Adornment="@GetAdornment("amount")"
                                     AdornmentColor="@GetAdornmentColor("amount")"
                                     AdornmentIcon="@GetAdornmentIcon("amount")" />
                </div>
                @if (TryBuildAmountValidationHint(out var validationSeverity, out var validationText))
                {
                    <MudAlert Severity="@validationSeverity" Dense="true" Class="mb-2">
                        @validationText
                    </MudAlert>
                }
                @if (HasAmountValidationMismatch())
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Class="mr-1" />
                        @OcrAmountValidationNotes.MismatchBlockingMessage
                    </MudAlert>
                }
                @if (HasManualReviewCompleted())
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Verified" Class="mr-1" />
                        @OcrAmountValidationNotes.ManualReviewCompletedMessage
                    </MudAlert>
                }
                @if (CanShowManualAmountValidationButton())
                {
                    <MudStack Row="true" Spacing="1" Class="mb-2">
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Info"
                                   StartIcon="@Icons.Material.Filled.FactCheck"
                                   OnClick="RunAmountValidationAsync"
                                   Disabled="@_amountValidationRunning">
                            @(_amountValidationRunning ? OcrAmountValidationNotes.ManualValidatingButtonText : OcrAmountValidationNotes.ManualValidateButtonText)
                        </MudButton>
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.VerifiedUser"
                                   OnClick="MarkManualReviewCompleted"
                                   Disabled="@(!HasAmountValidationRawMismatch())">
                            @OcrAmountValidationNotes.ManualReviewCompleteButtonText
                        </MudButton>
                    </MudStack>
                }

                @* 日期 - 置信度颜色 *@
                <div class="mb-2">
                    <MudDatePicker @bind-Date="_checkDate"
                                   Label="日期"
                                   Required="true"
                                   Variant="Variant.Outlined"
                                   Style="@GetFieldStyle("date")"
                                   HelperText="@GetFieldHint("date")" />
                </div>

                <MudDivider Class="my-3" />
                <MudText Typo="Typo.subtitle2" Class="mb-2">ACH / 票面信息</MudText>
                <MudTextField @bind-Value="_routingNumber" Label="Routing Number (ABA)" Variant="Variant.Outlined" Class="mb-2"
                              Style="@GetFieldStyle("routingNumber")" HelperText="@GetFieldHint("routingNumber")"
                              OnBlur="@OnAchRoutingBlurAsync" />
                <MudTextField @bind-Value="_accountNumber" Label="Account Number" Variant="Variant.Outlined" Class="mb-2"
                              Style="@GetFieldStyle("accountNumber")" HelperText="@GetFieldHint("accountNumber")" />
                <MudTextField @bind-Value="_bankName" Label="Bank Name" Variant="Variant.Outlined" Class="mb-2"
                              Style="@GetFieldStyle("bankName")" HelperText="@GetFieldHint("bankName")" />
                <MudTextField @bind-Value="_accountHolderName" Label="Account Holder Name" Variant="Variant.Outlined" Class="mb-2"
                              Style="@GetFieldStyle("accountHolderName")" HelperText="@GetFieldHint("accountHolderName")" />
                <MudTextField @bind-Value="_accountAddress" Label="Account Address" Variant="Variant.Outlined" Class="mb-2"
                              Style="@GetFieldStyle("accountAddress")" HelperText="@GetFieldHint("accountAddress")" Lines="2" />
                <MudSelect T="string" @bind-Value="_accountType" Label="Account Type" Variant="Variant.Outlined"
                           Class="mb-2"
                           Style="@GetFieldStyle("accountType")" HelperText="@GetFieldHint("accountType")">
                    <MudSelectItem T="string" Value="@CheckAccountTypeCatalog.BusinessChecking">
                        @CheckAccountTypeCatalog.BusinessChecking
                    </MudSelectItem>
                    <MudSelectItem T="string" Value="@CheckAccountTypeCatalog.Savings">
                        @CheckAccountTypeCatalog.Savings
                    </MudSelectItem>
                </MudSelect>
                <MudTextField @bind-Value="_payToOrderOf" Label="Pay to the order of" Variant="Variant.Outlined" Class="mb-2"
                              Style="@GetFieldStyle("payToOrderOf")" HelperText="@GetFieldHint("payToOrderOf")" />
                <MudTextField @bind-Value="_forMemo" Label="For / Memo" Variant="Variant.Outlined" Class="mb-2"
                              Style="@GetFieldStyle("forMemo")" HelperText="@GetFieldHint("forMemo")" />
                <MudTextField @bind-Value="_companyName" Label="公司名称（付款/开票主体）" Variant="Variant.Outlined" Class="mb-2"
                              Style="@GetFieldStyle("companyName")" HelperText="@GetFieldHint("companyName")" />

                <MudTextField @bind-Value="_customerCode"
                               Label="客户账号"
                               Required="true"
                               Variant="Variant.Outlined"
                               Class="mb-2"
                               Placeholder="与支票账号一致，支持新建"
                               OnBlur="@OnCustomerAccountBlurAsync" />
                <MudTextField @bind-Value="_customerPhone"
                               Label="客户手机号"
                               Required="true"
                               Variant="Variant.Outlined"
                               Class="mb-2"
                               MaxLength="30" />

                @if (ShowCustomerAuthorizationHint())
                {
                    <MudText Typo="Typo.caption" Color="Color.Warning" Class="mb-2" Style="display:block">
                        该账号与公司信息可能未授权，请注意确认
                    </MudText>
                }

                @if (!string.IsNullOrWhiteSpace(_customerCode))
                {
                    var match = GetCustomerMatch();
                    if (match != null)
                    {
                        <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                            匹配客户：@match.CustomerName · 手机 @CustomerDisplay.MobileOrDash(match.MobilePhone)
                        </MudAlert>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                            新客户将自动创建：@_customerCode.Trim()
                        </MudAlert>
                    }
                }

                @if (ShowNewCompanyRelationshipWarning())
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                        这是新的客户关系：当前公司名称未在该客户账号下登记，请在客户管理中维护关联公司后再核对。
                    </MudAlert>
                }

                <MudTextField @bind-Value="_notes" Label="备注" Lines="3" Variant="Variant.Outlined" Class="mb-3" />
                <MudTextField @bind-Value="_invoiceNumbers" Label="发票号码（多个用英文逗号分隔）" Variant="Variant.Outlined" Class="mb-2" />
                <MudTextField @bind-Value="_paymentPeriodText" Label="支付对应期间（如 2026-06）" Variant="Variant.Outlined" Class="mb-4" />

                @* 置信度图例说明 *@
                <MudPaper Class="pa-2 mb-4" Style="background:#f5f5f5">
                    <MudText Typo="Typo.caption">置信度说明：</MudText>
                    <MudStack Row="true" Spacing="2" Class="mt-1">
                        <MudChip T="string" Size="Size.Small" Style="background:#e8f5e9;color:#2e7d32">高 ≥85%</MudChip>
                        <MudChip T="string" Size="Size.Small" Style="background:#fff3e0;color:#e65100">中 60-85%</MudChip>
                        <MudChip T="string" Size="Size.Small" Style="background:#ffebee;color:#c62828">低 &lt;60%</MudChip>
                    </MudStack>
                </MudPaper>

                <MudButton Variant="Variant.Outlined" Color="Color.Default" Class="mr-2" OnClick="Abandon">
                    @(_editingCheckRecordId.HasValue ? "返回收款记录" : "放弃")
                </MudButton>
                @if (HasAmountValidationMismatch())
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Warning"
                               Class="mr-2"
                               StartIcon="@Icons.Material.Filled.ReportProblem"
                               OnClick="SaveDraftWithMismatchReasonAsync">
                        @OcrAmountValidationNotes.DraftOnMismatchButtonText
                    </MudButton>
                }
                <MudButton Variant="Variant.Outlined" Color="Color.Info" Class="mr-2" OnClick="() => SaveCheck(false)">保存草稿</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => SaveCheck(true)">提交入库</MudButton>
            </MudPaper>
        </MudItem>
    </MudGrid>
}
else if (_ocrResult == null)
{
    <MudAlert Severity="Severity.Error">未找到 OCR 记录</MudAlert>
}
else if (_ocrResult.Status == OcrStatus.Pending || _ocrResult.Status == OcrStatus.Processing)
{
    <MudPaper Class="pa-4 mt-4">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">OCR 正在处理中...</MudText>
            <MudText Typo="Typo.body2">请稍候或点击下方按钮刷新状态。</MudText>
            <MudStack Row="true" Spacing="1">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">提交时间：@_ocrResult.CreatedAt.ToLocalTime():g</MudText>
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RefreshStatus">刷新状态</MudButton>
        </MudStack>
    </MudPaper>
}
else if (_ocrResult.Status == OcrStatus.Failed)
{
    <MudAlert Severity="Severity.Error" Class="mb-3">
        OCR 识别失败：@(_ocrResult.ErrorMessage ?? "未知错误")
    </MudAlert>
    <MudStack Row="true" Spacing="2">
        <MudButton Variant="Variant.Outlined" OnClick="RefreshStatus">刷新状态</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RetryOcr" Disabled="@_retryingOcr">
            @(_retryingOcr ? "重新提交中..." : "重新提交 OCR 任务")
        </MudButton>
    </MudStack>
}
else if (PrimaryCheckOcrPayload(_ocrResult) == null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-3">
        未找到 OCR 结果，请重新触发识别。
    </MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RetryOcr" Disabled="@_retryingOcr">
        @(_retryingOcr ? "重新提交中..." : "重新提交 OCR 任务")
    </MudButton>
}

@code {
    [Parameter] public Guid Id { get; set; }
    [Parameter] public Guid DraftId { get; set; }

    private bool _loading = true;
    private bool _retryingOcr;
    private bool _prefilledFromOcr;
    private Guid? _editingCheckRecordId;
    private string? _initError;
    private OcrResult? _ocrResult;
    private List<Customer> _customers = new();
    private string _checkNumber = string.Empty;
    private decimal _amount;
    private DateTime? _checkDate;
    private string _customerCode = string.Empty;
    private string _customerPhone = string.Empty;
    /// <summary>最近一次从客户主数据成功同步时的「账号 + ABA」锚点，避免误覆盖用户手工修改。</summary>
    private string? _lastCustomerCodeForAutoPhone;
    private string? _lastRoutingKeyForAutoPhone;
    private string _notes = string.Empty;
    private string _routingNumber = "";
    private string _accountNumber = "";
    private string _bankName = "";
    private string _accountHolderName = "";
    private string _accountAddress = "";
    private string _accountType = CheckAccountTypeCatalog.BusinessChecking;
    private string _payToOrderOf = PayToOrderOfCatalog.CheungKongAllianceFood;
    private string _forMemo = "";
    private string _micrLineRaw = "";
    private string _checkNumberMicr = "";
    private string _invoiceNumbers = "";
    private string _paymentPeriodText = "";
    private string _companyName = "";
    private Dictionary<string, double> _confidenceScores = new(StringComparer.OrdinalIgnoreCase);
    private bool _amountValidationRunning;
    protected override async Task OnInitializedAsync()
    {
        if (DraftId != Guid.Empty)
            await LoadDraftForEditAsync();
        else
            await LoadOcrResultAsync();
    }

    private bool ShowCheckEditForm()
    {
        if (_editingCheckRecordId.HasValue) return true;
        return _ocrResult != null
               && _ocrResult.Status == OcrStatus.Completed
               && PrimaryCheckOcrPayload(_ocrResult) != null;
    }

    /// <summary>主识别 JSON：新数据在 RawResult；旧双引擎数据可能仅在 AzureRawResult。</summary>
    private static JsonDocument? PrimaryCheckOcrPayload(OcrResult? o) => o?.RawResult ?? o?.AzureRawResult;

    private static JsonDocument? PrimaryCheckConfidenceDoc(OcrResult? o) =>
        o?.RawResult != null ? o.ConfidenceScores : o?.AzureConfidenceScores;

    private async Task LoadDraftForEditAsync()
    {
        _loading = true;
        _initError = null;
        try
        {
            if (DraftId == Guid.Empty)
            {
                _initError = "无效的草稿 Id";
                return;
            }

            var draft = await DbContext.CheckRecords
                .AsNoTracking()
                .Include(c => c.Customer)
                .ThenInclude(cu => cu.CompanyNames)
                .Include(c => c.OcrResult)
                .Include(c => c.DebitRecord)
                .FirstOrDefaultAsync(c => c.Id == DraftId);

            if (draft == null)
            {
                _initError = "未找到该支票记录";
                return;
            }

            if (draft.SubmittedAt != null)
            {
                _initError = "该记录已提交入库，请在收款记录中查看。";
                return;
            }

            if (draft.Status != CheckStatus.PendingDebit)
            {
                _initError = "仅待扣款状态的草稿可在此编辑";
                return;
            }

            if (draft.DebitRecord != null)
            {
                _initError = "该草稿已关联银行扣款，无法在此编辑";
                return;
            }

            if (draft.OcrResult == null)
            {
                _initError = "草稿缺少关联的 OCR 记录，无法打开编辑页";
                return;
            }

            _editingCheckRecordId = draft.Id;
            _ocrResult = draft.OcrResult;

            _customers = await DbContext.Customers
                .Where(c => c.IsActive)
                .Include(c => c.CompanyNames)
                .OrderBy(c => c.CustomerCode)
                .ThenBy(c => c.ExpectedRoutingNumber)
                .ToListAsync();

            ApplyCheckRecordToForm(draft);
            await SyncCustomerFromMasterAsync();
            RefreshConfidenceFromSelectedOcrEngine();
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyCheckRecordToForm(CheckRecord c)
    {
        _checkNumber = c.CheckNumber;
        _amount = c.CheckAmount;
        _checkDate = c.CheckDate;
        _notes = c.Notes ?? string.Empty;
        _routingNumber = c.RoutingNumber ?? string.Empty;
        _accountNumber = c.AccountNumber ?? string.Empty;
        _bankName = c.BankName ?? string.Empty;
        _accountHolderName = c.AccountHolderName ?? string.Empty;
        _accountAddress = c.AccountAddress ?? string.Empty;
        _accountType = c.AccountType ?? string.Empty;
        if (string.IsNullOrWhiteSpace(_accountType))
            _accountType = CheckAccountTypeCatalog.BusinessChecking;
        _payToOrderOf = c.PayToOrderOf ?? string.Empty;
        if (string.IsNullOrWhiteSpace(_payToOrderOf))
            _payToOrderOf = PayToOrderOfCatalog.CheungKongAllianceFood;
        _forMemo = c.ForMemo ?? string.Empty;
        _micrLineRaw = c.MicrLineRaw ?? string.Empty;
        _checkNumberMicr = c.CheckNumberMicr ?? string.Empty;
        _invoiceNumbers = c.InvoiceNumbers ?? string.Empty;
        _paymentPeriodText = c.PaymentPeriodText ?? string.Empty;
        _companyName = c.CompanyName ?? string.Empty;
        _customerCode = c.Customer?.CustomerCode ?? string.Empty;
        _customerPhone = c.Customer?.MobilePhone ?? string.Empty;
        _prefilledFromOcr = true;
        _lastCustomerCodeForAutoPhone = string.IsNullOrWhiteSpace(_customerCode) ? null : _customerCode.Trim();
        _lastRoutingKeyForAutoPhone = CustomerAchRoutingLookup.NormalizeRoutingKey(_routingNumber);
    }

    private void RefreshConfidenceFromSelectedOcrEngine()
    {
        if (_ocrResult == null || PrimaryCheckOcrPayload(_ocrResult) == null)
        {
            _confidenceScores = new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);
            return;
        }

        _confidenceScores = ExtractConfidenceScoresFrom(PrimaryCheckConfidenceDoc(_ocrResult));
    }

    private async Task LoadOcrResultAsync()
    {
        _loading = true;
        _editingCheckRecordId = null;
        _initError = null;
        _ocrResult = await DbContext.OcrResults
            .AsNoTracking()
            .FirstOrDefaultAsync(o => o.Id == Id);
        _customers = await DbContext.Customers
            .Where(c => c.IsActive)
            .Include(c => c.CompanyNames)
            .OrderBy(c => c.CustomerCode)
            .ThenBy(c => c.ExpectedRoutingNumber)
            .ToListAsync();

        if (_ocrResult?.Status == OcrStatus.Completed && PrimaryCheckOcrPayload(_ocrResult) != null)
            await PopulateFromStoredResultAsync();

        _loading = false;
    }

    private async Task PopulateFromStoredResultAsync(bool force = false)
    {
        if (_prefilledFromOcr && !force) return;

        var rawResult = PrimaryCheckOcrPayload(_ocrResult);
        var confScores = PrimaryCheckConfidenceDoc(_ocrResult);

        if (rawResult == null) return;

        if (force)
        {
            _lastCustomerCodeForAutoPhone = null;
            _lastRoutingKeyForAutoPhone = null;
            _routingNumber = _accountNumber = _bankName = _accountHolderName = _accountAddress = "";
            _accountType = CheckAccountTypeCatalog.BusinessChecking;
            _payToOrderOf = PayToOrderOfCatalog.CheungKongAllianceFood;
            _forMemo = _micrLineRaw = _checkNumberMicr = "";
            _companyName = "";
            _customerCode = "";
            _customerPhone = "";
        }

        _confidenceScores = ExtractConfidenceScoresFrom(confScores);
        var root = rawResult.RootElement;

        var recognizedNumber = ExtractString(root, "CheckNumber");
        var recognizedAmount = ExtractDecimal(root, "Amount");
        var recognizedDate   = ExtractDate(root, "Date");

        if (!string.IsNullOrEmpty(recognizedNumber)) _checkNumber = recognizedNumber;
        if (recognizedAmount > 0) _amount = recognizedAmount;
        if (recognizedDate.HasValue) _checkDate = recognizedDate;

        void Pull(string jsonProp, ref string target)
        {
            var v = ExtractString(root, jsonProp);
            if (!string.IsNullOrEmpty(v)) target = v;
        }

        Pull("RoutingNumber", ref _routingNumber);
        Pull("AccountNumber", ref _accountNumber);
        var acctForCustomer = ExtractString(root, "AccountNumber");
        if (!string.IsNullOrEmpty(acctForCustomer) && (force || string.IsNullOrWhiteSpace(_customerCode)))
            _customerCode = acctForCustomer;
        Pull("BankName", ref _bankName);
        Pull("AccountAddress", ref _accountAddress);
        var acctTypeV = ExtractString(root, "AccountType");
        if (!string.IsNullOrEmpty(acctTypeV))
        {
            var mappedAcct = CheckAccountTypeCatalog.MatchSalesSelectable(acctTypeV);
            if (mappedAcct != null)
                _accountType = mappedAcct;
            else if (string.IsNullOrWhiteSpace(_accountType)
                     || string.Equals(_accountType, CheckAccountTypeCatalog.BusinessChecking, StringComparison.Ordinal))
                _accountType = CheckAccountTypeCatalog.BusinessChecking;
        }

        Pull("PayToOrderOf", ref _payToOrderOf);
        var canonicalPayTo = PayToOrderOfCatalog.MatchCanonical(_payToOrderOf);
        if (canonicalPayTo != null)
            _payToOrderOf = canonicalPayTo;
        else if (string.IsNullOrWhiteSpace(_payToOrderOf))
            _payToOrderOf = PayToOrderOfCatalog.CheungKongAllianceFood;
        Pull("ForMemo", ref _forMemo);
        Pull("MicrLineRaw", ref _micrLineRaw);
        Pull("CheckNumberMicr", ref _checkNumberMicr);
        ApplyOcrMergedHolderCompany(root, force);

        _prefilledFromOcr = true;
        await SyncCustomerFromMasterAsync();
    }

    private async Task OnCustomerAccountBlurAsync(FocusEventArgs _)
        => await SyncCustomerFromMasterAsync();

    private Task OnAchRoutingBlurAsync(FocusEventArgs _)
        => SyncCustomerFromMasterAsync();

    /// <summary>客户账号有值时，从客户主数据按「账号 + 9 位 ABA」同步手机号、期望银行名、公司/持有人、地址、账户类型、Pay to（规则同上传页）。</summary>
    private async Task SyncCustomerFromMasterAsync(CancellationToken cancellationToken = default)
    {
        if (string.IsNullOrWhiteSpace(_customerCode))
        {
            _lastCustomerCodeForAutoPhone = null;
            _lastRoutingKeyForAutoPhone = null;
            return;
        }

        var code = _customerCode.Trim();
        var lower = code.ToLowerInvariant();
        var routingKey = CustomerAchRoutingLookup.NormalizeRoutingKey(_routingNumber);

        var query = DbContext.Customers
            .AsNoTracking()
            .Where(c => c.IsActive && c.CustomerCode.ToLower() == lower);
        if (routingKey.Length == 9)
            query = query.Where(c => c.ExpectedRoutingNumber == routingKey);
        else
            query = query.Where(c => c.ExpectedRoutingNumber == "");

        var rowEntity = await query.FirstOrDefaultAsync(cancellationToken);
        CustomerMasterSync.MasterRow? masterRow = rowEntity == null
            ? null
            : new CustomerMasterSync.MasterRow(
                rowEntity.MobilePhone,
                rowEntity.ExpectedBankName,
                rowEntity.ExpectedCompanyName,
                rowEntity.ExpectedAccountHolderName,
                rowEntity.ExpectedAccountAddress,
                rowEntity.ExpectedAccountType,
                rowEntity.ExpectedPayToOrderOf);

        var lastCode = _lastCustomerCodeForAutoPhone;
        var lastRk = _lastRoutingKeyForAutoPhone;
        CustomerMasterSync.ApplyToCheckFormFields(
            masterRow,
            code,
            routingKey,
            ref lastCode,
            ref lastRk,
            ref _customerPhone,
            ref _bankName,
            ref _companyName,
            ref _accountHolderName,
            ref _accountAddress,
            ref _accountType,
            ref _payToOrderOf);
        _lastCustomerCodeForAutoPhone = lastCode;
        _lastRoutingKeyForAutoPhone = lastRk;
    }

    /// <summary>渲染 OCR 单元格内容（字段值 + 置信度色标）</summary>
    private MarkupString RenderOcrCell(JsonDocument? rawResult, JsonDocument? confidenceScores,
        string field, bool isAmount, string? fallback = null)
    {
        if (rawResult == null)
        {
            var msg = string.IsNullOrEmpty(fallback) ? "识别失败" : fallback;
            return new MarkupString($"<span style='color:#9e9e9e'>{msg}</span>");
        }

        var root = rawResult.RootElement;
        string value = field switch
        {
            "Amount"      => ExtractDecimal(root, "Amount") is decimal amt and > 0 ? $"${amt:N2}" : "-",
            "Date"        => ExtractDate(root, "Date")?.ToString("yyyy-MM-dd") ?? "-",
            "CheckNumber" => ExtractString(root, "CheckNumber") is string s and { Length: > 0 } ? s : "-",
            _             => "-"
        };

        var conf = ExtractFieldConfidence(confidenceScores, field);
        var (color, dot) = conf switch
        {
            >= 0.85 => ("#2e7d32", "🟢"),
            >= 0.60 => ("#e65100", "🟡"),
            _       => ("#c62828", "🔴")
        };

        return new MarkupString(
            $"<span style='color:{color}'>{dot} {value}</span> <span style='color:#9e9e9e;font-size:0.75em'>({conf:P0})</span>");
    }

    private static double ExtractFieldConfidence(JsonDocument? confidenceScores, string field)
    {
        if (confidenceScores?.RootElement.ValueKind != JsonValueKind.Object) return 0.5;
        if (confidenceScores.RootElement.TryGetProperty(field, out var el))
        {
            if (el.ValueKind == JsonValueKind.Number) return Math.Clamp(el.GetDouble(), 0.0, 1.0);
        }
        return 0.5;
    }

    private Dictionary<string, double> ExtractConfidenceScores()
        => ExtractConfidenceScoresFrom(_ocrResult?.ConfidenceScores);

    private static Dictionary<string, double> ExtractConfidenceScoresFrom(JsonDocument? doc)
    {
        var dict = new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);
        if (doc?.RootElement.ValueKind == JsonValueKind.Object)
        {
            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                if (prop.Value.ValueKind == JsonValueKind.Number)
                    dict[prop.Name] = prop.Value.GetDouble();
                else if (prop.Value.ValueKind == JsonValueKind.String &&
                         double.TryParse(prop.Value.GetString(), out var parsed))
                    dict[prop.Name] = parsed;
            }
        }
        return dict;
    }

    private double GetConfidence(string field)
    {
        var key = field switch
        {
            "checkNumber" => "CheckNumber",
            "amount" => "Amount",
            "date" => "Date",
            "routingNumber" => "RoutingNumber",
            "accountNumber" => "AccountNumber",
            "bankName" => "BankName",
            "accountHolderName" => "AccountHolderName",
            "accountAddress" => "AccountAddress",
            "accountType" => "AccountType",
            "payToOrderOf" => "PayToOrderOf",
            "forMemo" => "ForMemo",
            "micrLineRaw" => "MicrLineRaw",
            "checkNumberMicr" => "CheckNumberMicr",
            "companyName" => "CompanyName",
            _ => field
        };
        if (_confidenceScores.TryGetValue(key, out var v)) return v;
        return _confidenceScores.TryGetValue(field, out var v2) ? v2 : 0;
    }

    private string GetFieldStyle(string field)
    {
        if (_confidenceScores.Count == 0) return string.Empty;
        var confidence = GetConfidence(field);
        return confidence switch
        {
            >= 0.85 => "border-color:#4caf50!important",
            >= 0.60 => "border-color:#ff9800!important",
            _ => "border-color:#f44336!important"
        };
    }

    private string GetFieldHint(string field)
    {
        if (_confidenceScores.Count == 0) return string.Empty;
        return GetConfidence(field) switch
        {
            >= 0.85 => string.Empty,
            >= 0.60 => "请复核此字段",
            _ => "识别不确定，请手动填写"
        };
    }

    private Adornment GetAdornment(string field)
    {
        var confidence = GetConfidence(field);
        return (confidence is > 0 and < 0.85 && _confidenceScores.Count > 0)
            ? Adornment.End : Adornment.None;
    }

    private Color GetAdornmentColor(string field)
        => GetConfidence(field) >= 0.60 ? Color.Warning : Color.Error;

    private string GetAdornmentIcon(string field)
        => GetConfidence(field) >= 0.60
            ? Icons.Material.Filled.Warning
            : Icons.Material.Filled.Error;

    private bool TryBuildAmountValidationHint(out Severity severity, out string text)
    {
        severity = Severity.Normal;
        text = string.Empty;
        if (_ocrResult == null) return false;

        if (_ocrResult.AmountValidationStatus == AmountValidationStatus.Pending)
            return false;

        if (_ocrResult.AmountValidationStatus == AmountValidationStatus.Skipped)
        {
            severity = Severity.Info;
            text = _ocrResult.AmountValidationErrorMessage ?? "金额二次校验已跳过";
            return true;
        }

        if (_ocrResult.AmountValidationStatus == AmountValidationStatus.Failed)
        {
            severity = Severity.Warning;
            text = _ocrResult.AmountValidationErrorMessage ?? "金额二次校验失败，请人工复核";
            return true;
        }

        if (_ocrResult.AmountValidationResult == null)
            return false;

        try
        {
            var payload = _ocrResult.AmountValidationResult.RootElement.GetRawText();
            var result = JsonSerializer.Deserialize<AmountValidationResult>(payload);
            if (result == null) return false;

            var parsed = result.LegalAmountParsed.HasValue ? result.LegalAmountParsed.Value.ToString("N2") : "未解析";
            if (result.IsConsistent == true)
            {
                if (!HasWrittenAmountEvidence(result))
                {
                    severity = Severity.Warning;
                    text = $"未识别到大写金额文本，需手动校验金额（数字金额 {_amount:N2}）{BuildValidationTimeText()}";
                }
                else
                {
                    severity = Severity.Success;
                    text = $"手写金额校验一致：数字金额 {_amount:N2}，手写解析 {parsed}（置信度 {result.Confidence:P0}）{BuildValidationTimeText()}";
                }
            }
            else if (result.IsConsistent == false)
            {
                severity = Severity.Error;
                text = $"手写金额与数字金额不一致：数字金额 {_amount:N2}，手写解析 {parsed}（置信度 {result.Confidence:P0}）{BuildValidationTimeText()}";
            }
            else
            {
                severity = Severity.Warning;
                text = (result.Reason ?? "手写金额未能确定一致性，请人工复核") + BuildValidationTimeText();
            }

            return true;
        }
        catch
        {
            return false;
        }
    }

    private static bool HasWrittenAmountEvidence(AmountValidationResult result)
    {
        if (string.IsNullOrWhiteSpace(result.LegalAmountRaw))
            return false;

        // 仅有数字/符号不算大写金额证据，至少应包含英文金额词。
        return Regex.IsMatch(result.LegalAmountRaw, @"[A-Za-z]");
    }

    private bool CanShowManualAmountValidationButton()
        => _ocrResult is { Status: OcrStatus.Completed } && _amount > 0m;

    private string BuildValidationTimeText()
        => _ocrResult?.AmountValidatedAt is DateTime dt ? $"（最后校验：{dt.ToLocalTime().ToString(OcrAmountValidationNotes.UiDateTimeFormat)}）" : string.Empty;

    private bool HasAmountValidationRawMismatch()
    {
        if (_ocrResult?.AmountValidationResult == null) return false;
        try
        {
            var payload = _ocrResult.AmountValidationResult.RootElement.GetRawText();
            var result = JsonSerializer.Deserialize<AmountValidationResult>(payload);
            return result?.IsConsistent == false;
        }
        catch
        {
            return false;
        }
    }

    private bool HasAmountValidationMismatch()
        => HasAmountValidationRawMismatch() && !HasManualReviewCompleted();

