    /// <summary>再次识别：重置 OcrResult 状态，重新入队</summary>
    private async Task RetryOcrAsync()
    {
        if (_current?.Done == true || _current?.OcrResultId == null || _retryingOcr) return;

        _retryingOcr = true;
        try
        {
            var ocrId = _current.OcrResultId!.Value;
            var missing = false;
            await DbSerializedAsync(async () =>
            {
                var tracked = await DbContext.OcrResults.FirstOrDefaultAsync(o => o.Id == ocrId);
                if (tracked == null)
                {
                    missing = true;
                    return;
                }

                tracked.Status = OcrStatus.Pending;
                tracked.ErrorMessage = null;
                tracked.RawResult?.Dispose();
                tracked.RawResult = null;
                tracked.ConfidenceScores?.Dispose();
                tracked.ConfidenceScores = null;
                tracked.AzureRawResult?.Dispose();
                tracked.AzureRawResult = null;
                tracked.AzureConfidenceScores?.Dispose();
                tracked.AzureConfidenceScores = null;
                tracked.AzureStatus = OcrStatus.Pending;
                tracked.AzureErrorMessage = null;
                tracked.AmountValidationResult?.Dispose();
                tracked.AmountValidationResult = null;
                tracked.AmountValidationStatus = AmountValidationStatus.Pending;
                tracked.AmountValidationErrorMessage = null;
                tracked.AmountValidatedAt = null;
                tracked.UpdatedAt = DateTime.UtcNow;

                await DbContext.SaveChangesAsync();
            });

            if (missing)
            {
                Snackbar.Add("未找到 OCR 记录", Severity.Error);
                return;
            }

            await OcrWorker.EnqueueAsync(ocrId);

            _current.OcrStatus = CheckOcrStatus.Recognizing;
            _current.ReusedHistoricalOcr = false;
            _current.RawResult = null;
            _current.ConfidenceScores = new(StringComparer.OrdinalIgnoreCase);
            _ocrCopyPanelText = "";
            ClearForm();

            Snackbar.Add("已重新提交 OCR 任务", Severity.Info);

            // 重新开始轮询
            _ = PollOcrStatusAsync(_current, _cts.Token);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"重新提交失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _retryingOcr = false;
        }
    }

    private async Task RunAmountValidationAsync()
    {
        if (_current?.Done == true || _current?.OcrResultId == null) return;
        if (_amount <= 0m)
        {
            Snackbar.Add("请先确认金额后再执行手写金额校验", Severity.Warning);
            return;
        }

        _amountValidationRunning = true;
        try
        {
            var ocrId = _current.OcrResultId.Value;
            string? imageUrl = null;
            await DbSerializedAsync(async () =>
            {
                var row = await DbContext.OcrResults.AsNoTracking().FirstOrDefaultAsync(x => x.Id == ocrId);
                imageUrl = row?.ImageUrl;
            });

            if (string.IsNullOrEmpty(imageUrl))
            {
                Snackbar.Add("未找到 OCR 记录", Severity.Error);
                return;
            }

            var visionExtractedText = OcrResultRawJsonReaders.TryReadExtractedText(GetPreferredOcrDocument(_current));
            var diResult =
                await OcrService.ValidateHandwrittenAmountAsync(imageUrl, _amount, CancellationToken.None, visionExtractedText);

            AmountValidationStatus oldStatus = default;
            string? oldError = null;
            string? oldResult = null;
            OcrResult? trackedAfter = null;

            await DbSerializedAsync(async () =>
            {
                var tracked = await DbContext.OcrResults.FirstOrDefaultAsync(x => x.Id == ocrId);
                if (tracked == null)
                    return;

                oldStatus = tracked.AmountValidationStatus;
                oldError = tracked.AmountValidationErrorMessage;
                oldResult = tracked.AmountValidationResult?.RootElement.GetRawText();

                tracked.AmountValidationResult?.Dispose();
                tracked.AmountValidationResult = JsonDocument.Parse(JsonSerializer.Serialize(diResult));
                tracked.AmountValidationStatus = diResult.Status.Equals("completed", StringComparison.OrdinalIgnoreCase)
                    ? AmountValidationStatus.Completed
                    : diResult.Status.Equals("skipped", StringComparison.OrdinalIgnoreCase)
                        ? AmountValidationStatus.Skipped
                        : AmountValidationStatus.Failed;
                tracked.AmountValidationErrorMessage = diResult.Reason;
                tracked.AmountValidatedAt = DateTime.UtcNow;
                tracked.UpdatedAt = DateTime.UtcNow;

                if (tracked.RawResult != null)
                {
                    var merged = OcrRawResultAmountValidationDiagnostics.MergeIntoRawJson(
                        tracked.RawResult,
                        tracked.AmountValidationResult,
                        tracked.AmountValidationStatus,
                        tracked.AmountValidationErrorMessage);
                    tracked.RawResult.Dispose();
                    tracked.RawResult = merged;
                }

                await DbContext.SaveChangesAsync();
                trackedAfter = tracked;
            });

            if (trackedAfter == null)
            {
                Snackbar.Add("未找到 OCR 记录", Severity.Error);
                return;
            }

            try
            {
                await DbSerializedAsync(async () =>
                    await AuditLog.LogAsync(
                        AuditAction.Update,
                        "OcrResult",
                        trackedAfter.Id,
                        new
                        {
                            AmountValidationStatus = oldStatus.ToString(),
                            AmountValidationErrorMessage = oldError,
                            AmountValidationResult = oldResult
                        },
                        new
                        {
                            AmountValidationStatus = trackedAfter.AmountValidationStatus.ToString(),
                            AmountValidationErrorMessage = trackedAfter.AmountValidationErrorMessage,
                            AmountValidationResult = trackedAfter.AmountValidationResult?.RootElement.GetRawText(),
                            Trigger = "Manual"
                        }));
            }
            catch (Exception auditEx)
            {
                Logger.LogWarning(auditEx, "手动金额校验审计日志写入失败，已忽略。OcrResultId={OcrResultId}", trackedAfter.Id);
            }

            _ocrResult = trackedAfter;
            if (_current != null
                && _current.OcrResultId == trackedAfter.Id
                && trackedAfter.RawResult != null)
            {
                _current.RawResult?.Dispose();
                _current.RawResult =
                    JsonDocument.Parse(trackedAfter.RawResult.RootElement.GetRawText());
            }

            RefreshOcrCopyPanelText();
            Snackbar.Add("手写金额校验已完成", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"手写金额校验失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _amountValidationRunning = false;
        }
    }

    private async Task SaveCurrent(bool submitAsFinal)
    {
        if (_saving || _current == null || _current.Done) return;
        _saving = true;

        try
        {
            string? validationError = null;
            var masterMismatch = false;

            await DbSerializedAsync(async () =>
            {
                validationError = await ValidateFormAsync(submitAsFinal);
                if (!string.IsNullOrEmpty(validationError))
                    return;

                var customer = await ResolveCustomerAsync();
                masterMismatch = CheckMasterDataComparer.HasMismatch(
                    customer,
                    NullIfEmpty(_bankName),
                    NullIfEmpty(_accountHolderName),
                    NullIfEmpty(_companyName),
                    NullIfEmpty(_accountNumber),
                    NullIfEmpty(_accountAddress));

                var registeredCompanies = customer.CompanyNames.Select(x => x.CompanyName).ToList();
                var companyWarn = !CustomerCompanyNameRules.IsRegisteredCompany(registeredCompanies, _companyName);

                var normalizedCheckNumber = CheckNumberGuard.Normalize(_checkNumber);
                var capturedImageUrl = _current.ImageUrl;
                var capturedOcrResultId = _current.OcrResultId;
                var checkDateUtc = DateTime.SpecifyKind(_checkDate!.Value, DateTimeKind.Utc);

                var check = new CheckRecord
                {
                    CheckNumber = normalizedCheckNumber,
                    CheckAmount = _amount,
                    CheckDate = checkDateUtc,
                    Customer = customer,
                    ImageUrl = capturedImageUrl,
                    OcrResultId = capturedOcrResultId,
                    Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim(),
                    Status = CheckStatus.PendingDebit,
                    RowVersion = 0,
                    BankName = NullIfEmpty(_bankName),
                    RoutingNumber = NullIfEmpty(_routingNumber),
                    AccountNumber = NullIfEmpty(_accountNumber),
                    AccountType = NullIfEmpty(_accountType),
                    AccountHolderName = NullIfEmpty(_accountHolderName),
                    AccountAddress = NullIfEmpty(_accountAddress),
                    PayToOrderOf = NullIfEmpty(_payToOrderOf),
                    ForMemo = NullIfEmpty(_forMemo),
                    MicrLineRaw = NullIfEmpty(_micrLineRaw),
                    CheckNumberMicr = NullIfEmpty(_checkNumberMicr),
                    InvoiceNumbers = NullIfEmpty(_invoiceNumbers),
                    PaymentPeriodText = NullIfEmpty(_paymentPeriodText),
                    CompanyName = NullIfEmpty(_companyName),
                    SubmittedAt = submitAsFinal ? DateTime.UtcNow : null,
                    CustomerMasterMismatchWarning = masterMismatch,
                    CustomerCompanyNewRelationshipWarning = companyWarn
                };

                DbContext.CheckRecords.Add(check);
                await DbContext.SaveChangesAsync();

                if (submitAsFinal)
                {
                    await CheckSubmitOcrTrainingSamplePageHelper.TryAppendAfterCheckFinalSubmitAsync(
                        DbContext,
                        Configuration,
                        capturedImageUrl,
                        capturedOcrResultId,
                        normalizedCheckNumber,
                        _amount,
                        checkDateUtc,
                        BuildSubmittedAchExtensionData(),
                        check.Id,
                        CheckOcrTemplateResolver,
                        Logger);
                }
            });

            if (!string.IsNullOrEmpty(validationError))
            {
                Snackbar.Add(validationError, Severity.Warning);
                return;
            }

            _current!.Done = true;
            const string masterSuffix = "（与客户主数据期望不一致，已标记警告。）";
            if (submitAsFinal)
            {
                Snackbar.Add(masterMismatch ? $"支票已提交入库！{masterSuffix}" : "支票已提交入库！", Severity.Success);
            }
            else
            {
                var draftBody =
                    "支票草稿已保存。可稍后在「收款记录」中打开该笔，使用「编辑草稿」继续修改，或在收款记录中补全 Routing / Account 后「提交入库」。";
                Snackbar.Add(masterMismatch ? $"{draftBody}{masterSuffix}" : draftBody, Severity.Success);
            }

            _current = _uploadQueue.FirstOrDefault(q => !q.Done);
            ClearForm();
            if (_current?.OcrStatus == CheckOcrStatus.Completed)
                await PrefillFormAsync(_current);
        }
        catch (DbUpdateConcurrencyException)
        {
            Snackbar.Add("数据已被其他用户修改，请刷新后重试", Severity.Error);
        }
        catch (DbUpdateException ex) when (CheckNumberGuard.IsUniqueViolation(ex))
        {
            if (ex.GetBaseException() is Npgsql.PostgresException pg)
                Logger.LogWarning(
                    "支票保存唯一索引冲突 ix_check_records_check_number：{SqlState} {Message}. Detail: {Detail}",
                    pg.SqlState,
                    pg.MessageText,
                    pg.Detail);

            if (DbContext is DbContext ef)
            {
                foreach (var entry in ef.ChangeTracker.Entries<CheckRecord>().Where(e => e.State == EntityState.Added)
                             .ToList())
                    entry.State = EntityState.Detached;
            }

            Snackbar.Add(
                CheckNumberGuard.FormatDuplicateUserMessage(
                    CheckNumberGuard.Normalize(_checkNumber),
                    CheckNumberGuard.NormalizeRouting(_routingNumber)),
                Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveDraftWithMismatchReasonAsync()
    {
        if (!HasAmountValidationMismatch())
        {
            Snackbar.Add("当前不存在金额不一致，无需一键转草稿。", Severity.Info);
            return;
        }

        AppendMismatchReasonToNotes();
        await SaveCurrent(false);
    }

    private void AppendMismatchReasonToNotes()
    {
        const string marker = OcrAmountValidationNotes.MismatchDraftMarker;
        if (!string.IsNullOrWhiteSpace(_notes) && _notes.Contains(marker, StringComparison.Ordinal))
            return;

        var line = $"{marker} 时间:{DateTime.Now.ToString(OcrAmountValidationNotes.UiDateTimeFormat)}";
        _notes = string.IsNullOrWhiteSpace(_notes) ? line : $"{_notes.Trim()}\n{line}";
    }

    private void MarkManualReviewCompleted()
    {
        if (!HasAmountValidationRawMismatch())
        {
            Snackbar.Add("当前不存在金额不一致，无需人工复核确认。", Severity.Info);
            return;
        }

        const string marker = OcrAmountValidationNotes.ManualReviewCompleteMarker;
        if (!string.IsNullOrWhiteSpace(_notes) && _notes.Contains(marker, StringComparison.Ordinal))
        {
            Snackbar.Add("已标记人工复核完毕，可直接提交入库。", Severity.Success);
            return;
        }

        var line = $"{marker} 时间:{DateTime.Now.ToString(OcrAmountValidationNotes.UiDateTimeFormat)}";
        _notes = string.IsNullOrWhiteSpace(_notes) ? line : $"{_notes.Trim()}\n{line}";
        Snackbar.Add("已标记人工复核完毕，可继续提交入库。", Severity.Success);
    }

    private bool HasManualReviewCompleted()
        => !string.IsNullOrWhiteSpace(_notes)
           && _notes.Contains(OcrAmountValidationNotes.ManualReviewCompleteMarker, StringComparison.Ordinal);

    private async Task RemoveItemAsync(QueueItem item)
    {
        _uploadQueue.Remove(item);

        // 如果删的是当前选中项，切换到下一个未完成的
        if (_current == item)
        {
            _current = _uploadQueue.FirstOrDefault(q => !q.Done);
            ClearForm();
            if (_current?.OcrStatus == CheckOcrStatus.Completed)
                await PrefillFormAsync(_current);
        }

        // 队列清空时重置到初始状态
        if (!_uploadQueue.Any())
            Reset();
    }

    private void SkipCurrent()
    {
        if (_current?.Uploading == true)
        {
            Snackbar.Add("当前文件仍在上传，暂时无法跳过", Severity.Info);
            return;
        }
        _current = _uploadQueue.FirstOrDefault(q => !q.Done && q != _current);
        ClearForm();
    }

    private CheckAchExtensionData BuildSubmittedAchExtensionData() =>
        new(
            NullIfEmpty(_routingNumber),
            NullIfEmpty(_accountNumber),
            NullIfEmpty(_bankName),
            NullIfEmpty(_accountHolderName),
            NullIfEmpty(_accountAddress),
            NullIfEmpty(_accountType),
            NullIfEmpty(_payToOrderOf),
            NullIfEmpty(_forMemo),
            NullIfEmpty(_micrLineRaw),
            NullIfEmpty(_checkNumberMicr),
            null,
            NullIfEmpty(_companyName));

    private async Task<string?> ValidateFormAsync(bool submitAsFinal)
    {
        if (_current == null || string.IsNullOrEmpty(_current.ImageUrl))
            return "当前文件尚未上传完成";
        if (string.IsNullOrWhiteSpace(_checkNumber))
            return "支票号不能为空";
        if (_amount <= 0)
            return "金额必须大于 0";
        if (!_checkDate.HasValue)
            return "请选择支票日期";
        if (string.IsNullOrWhiteSpace(_customerCode))
            return "请输入客户账号";
        if (string.IsNullOrWhiteSpace(_customerPhone))
            return "请输入餐馆编号";
        if (submitAsFinal)
        {
            if (HasAmountValidationMismatch())
                return OcrAmountValidationNotes.MismatchSubmitBlockedReason;
            if (string.IsNullOrWhiteSpace(_routingNumber) || _routingNumber.Length != 9 || !_routingNumber.All(char.IsDigit))
                return "提交入库时 Routing Number 须为 9 位数字";
            if (string.IsNullOrWhiteSpace(_accountNumber))
                return "提交入库时请填写 Account Number";
        }

        _checkNumber = CheckNumberGuard.Normalize(_checkNumber);
        _routingNumber = CheckNumberGuard.NormalizeRouting(_routingNumber);
        var exists = await CheckNumberGuard.ExistsAsync(DbContext, _checkNumber, _routingNumber);
        if (exists)
            return CheckNumberGuard.FormatDuplicateUserMessage(_checkNumber, _routingNumber);

        return null;
    }

    private static string? NullIfEmpty(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private Customer? GetCustomerMatch()
    {
        if (string.IsNullOrWhiteSpace(_customerCode)) return null;
        var code = _customerCode.Trim();
        var rk = CustomerAchRoutingLookup.NormalizeRoutingKey(_routingNumber);
        return _customers.FirstOrDefault(c =>
            c.CustomerCode.Equals(code, StringComparison.OrdinalIgnoreCase)
            && string.Equals(c.ExpectedRoutingNumber, rk, StringComparison.Ordinal));
    }

    private bool ShowNewCompanyRelationshipWarning()
    {
        var match = GetCustomerMatch();
        if (match == null || string.IsNullOrWhiteSpace(_companyName)) return false;
        var names = match.CompanyNames.Select(cn => cn.CompanyName);
        return !CustomerCompanyNameRules.IsRegisteredCompany(names, _companyName);
    }

    /// <summary>OCR 结果 JSON 中是否含有非空 AccountNumber（按当前选择的引擎）。</summary>
    private bool CurrentOcrJsonHasAccountNumber()
    {
        if (_current == null || _current.OcrStatus != CheckOcrStatus.Completed) return false;
        var doc = GetPreferredOcrDocument(_current);
        if (doc == null) return false;
        return !string.IsNullOrWhiteSpace(ExtractString(doc.RootElement, "AccountNumber"));
    }

    /// <summary>OCR 未识别账号，或当前账号/公司组合未在客户主数据中登记。</summary>
    private bool ShowCustomerAuthorizationHint()
    {
        if (_current == null || _current.OcrStatus != CheckOcrStatus.Completed) return false;

        if (!CurrentOcrJsonHasAccountNumber())
            return true;

        if (string.IsNullOrWhiteSpace(_customerCode))
            return false;

        var match = GetCustomerMatch();
        if (match == null)
            return true;

        if (ShowNewCompanyRelationshipWarning())
            return true;

        return false;
    }

    private async Task<Customer> ResolveCustomerAsync()
    {
        var code = _customerCode.Trim();
        var routingKey = CustomerAchRoutingLookup.NormalizeRoutingKey(_routingNumber);
        var existing = await DbContext.Customers
            .Include(c => c.CompanyNames)
            .FirstOrDefaultAsync(c => c.CustomerCode == code && c.ExpectedRoutingNumber == routingKey);
        if (existing != null)
        {
            var phone = _customerPhone.Trim();
            if (!string.Equals(existing.MobilePhone, phone, StringComparison.Ordinal))
            {
                existing.MobilePhone = phone;
                existing.UpdatedAt = DateTime.UtcNow;
                var mem = _customers.FirstOrDefault(x => x.Id == existing.Id);
                if (mem != null) mem.MobilePhone = phone;
            }

            return existing;
        }

        var ocrCompany = OcrCheckCustomerFields.MergeHolderCompanyDisplayName(_companyName, _accountHolderName, _payToOrderOf);
        var ocrCompanyTrim = string.IsNullOrWhiteSpace(ocrCompany) ? null : ocrCompany.Trim();
        var displayName = ocrCompanyTrim ?? code;

        var customer = new Customer
        {
            CustomerCode = code,
            ExpectedRoutingNumber = routingKey,
            CustomerName = displayName,
            MobilePhone = _customerPhone.Trim(),
            ExpectedBankName = NullIfEmpty(_bankName),
            ExpectedAccountHolderName = ocrCompanyTrim,
            ExpectedCompanyName = ocrCompanyTrim,
            ExpectedAccountAddress = NullIfEmpty(_accountAddress),
            ExpectedAccountType = CustomerMasterSync.CanonicalAccountTypeForCustomerMaster(_accountType),
            ExpectedPayToOrderOf = CustomerMasterSync.CanonicalPayToForCustomerMaster(_payToOrderOf),
            IsActive = true,
            IsAuthorized = false,
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow
        };
        if (ocrCompanyTrim != null)
        {
            customer.CompanyNames.Add(new CustomerCompanyName { CompanyName = ocrCompanyTrim });
        }

        DbContext.Customers.Add(customer);
        _customers.Add(customer);
        return customer;
    }

    private void ClearForm()
    {
        _checkNumber = "";
        _amount = 0;
        _checkDate = null;
        _customerCode = "";
        _customerPhone = "";
        _lastCustomerCodeForAutoPhone = null;
        _lastRoutingKeyForAutoPhone = null;
        _notes = "";
        _routingNumber = _accountNumber = _bankName = _accountHolderName = _accountAddress = "";
        _accountType = CheckAccountTypeCatalog.BusinessChecking;
        _payToOrderOf = PayToOrderOfCatalog.CheungKongAllianceFood;
        _forMemo = _micrLineRaw = _checkNumberMicr = "";
        _invoiceNumbers = _paymentPeriodText = "";
        _companyName = "";
        _confidenceScores = new(StringComparer.OrdinalIgnoreCase);
    }

    private bool IsFormEmpty() =>
        string.IsNullOrEmpty(_checkNumber) && _amount <= 0 && string.IsNullOrEmpty(_customerCode)
        && string.IsNullOrEmpty(_routingNumber) && string.IsNullOrEmpty(_accountNumber);

    private void Reset()
    {
        _uploadQueue.Clear();
        _current = null;
        ClearForm();
    }

    // ── 置信度相关 ────────────────────────────────────────────────

    private double GetConfidence(string field)
    {
        var key = MapConfidenceKey(field);
        if (_confidenceScores.TryGetValue(key, out var v)) return v;
        return _confidenceScores.TryGetValue(field, out var v2) ? v2 : 0;
    }

    private static string MapConfidenceKey(string field) => field switch
    {
        "checkNumber" => "CheckNumber",
        "amount" => "Amount",
        "date" => "Date",
        "routingNumber" => "RoutingNumber",
        "accountNumber" => "AccountNumber",
        "bankName" => "BankName",
        "accountHolderName" => "AccountHolderName",
        "accountAddress" => "AccountAddress",
        "accountType" => "AccountType",
        "payToOrderOf" => "PayToOrderOf",
        "forMemo" => "ForMemo",
        "micrLineRaw" => "MicrLineRaw",
        "checkNumberMicr" => "CheckNumberMicr",
        "companyName" => "CompanyName",
        _ => field
    };

    private string GetFieldStyle(string field)
    {
        if (_confidenceScores.Count == 0) return string.Empty;
        return GetConfidence(field) switch
        {
            >= 0.85 => "border-color:#4caf50!important",
            >= 0.60 => "border-color:#ff9800!important",
            _ => "border-color:#f44336!important"
        };
    }

    private string GetFieldHint(string field)
    {
        if (_confidenceScores.Count == 0) return string.Empty;
        return GetConfidence(field) switch
        {
            >= 0.85 => string.Empty,
            >= 0.60 => "请复核此字段",
            _ => "识别不确定，请手动填写"
        };
    }

    private Adornment GetAdornment(string field)
    {
        var confidence = GetConfidence(field);
        return (confidence is > 0 and < 0.85 && _confidenceScores.Count > 0)
            ? Adornment.End : Adornment.None;
    }

    private Color GetAdornmentColor(string field)
        => GetConfidence(field) >= 0.60 ? Color.Warning : Color.Error;

    private string GetAdornmentIcon(string field)
        => GetConfidence(field) >= 0.60
            ? Icons.Material.Filled.Warning
            : Icons.Material.Filled.Error;

    private bool TryBuildAmountValidationHint(out Severity severity, out string text)
    {
        severity = Severity.Normal;
        text = string.Empty;
        if (_ocrResult == null || _current?.OcrStatus != CheckOcrStatus.Completed)
            return false;

        if (_ocrResult.AmountValidationStatus == AmountValidationStatus.Pending)
            return false;

        if (_ocrResult.AmountValidationStatus == AmountValidationStatus.Skipped)
        {
            severity = Severity.Info;
            text = _ocrResult.AmountValidationErrorMessage ?? "金额二次校验已跳过";
            return true;
        }

        if (_ocrResult.AmountValidationStatus == AmountValidationStatus.Failed)
        {
            severity = Severity.Warning;
            text = _ocrResult.AmountValidationErrorMessage ?? "金额二次校验失败，请人工复核";
            return true;
        }

        if (_ocrResult.AmountValidationResult == null)
            return false;

        try
        {
            var payload = _ocrResult.AmountValidationResult.RootElement.GetRawText();
            var result = JsonSerializer.Deserialize<AmountValidationResult>(payload);
            if (result == null) return false;

            var parsed = result.LegalAmountParsed.HasValue ? result.LegalAmountParsed.Value.ToString("N2") : "未解析";
            if (result.IsConsistent == true)
            {
                if (!HasWrittenAmountEvidence(result))
                {
                    severity = Severity.Warning;
                    text = $"未识别到大写金额文本，需手动校验金额（数字金额 {_amount:N2}）{BuildValidationTimeText()}";
                }
                else
                {
                    severity = Severity.Success;
                    text = $"手写金额校验一致：数字金额 {_amount:N2}，手写解析 {parsed}（置信度 {result.Confidence:P0}）{BuildValidationTimeText()}";
                }
            }
            else if (result.IsConsistent == false)
            {
                severity = Severity.Error;
                text = $"手写金额与数字金额不一致：数字金额 {_amount:N2}，手写解析 {parsed}（置信度 {result.Confidence:P0}）{BuildValidationTimeText()}";
            }
            else
            {
                severity = Severity.Warning;
                text = (result.Reason ?? "手写金额未能确定一致性，请人工复核") + BuildValidationTimeText();
            }

            return true;
        }
        catch
        {
            return false;
        }
    }

    private static bool HasWrittenAmountEvidence(AmountValidationResult result)
    {
        if (string.IsNullOrWhiteSpace(result.LegalAmountRaw))
            return false;

        // 仅有数字/符号不算大写金额证据，至少应包含英文金额词。
        return Regex.IsMatch(result.LegalAmountRaw, @"[A-Za-z]");
    }

    private bool CanShowManualAmountValidationButton()
        => _current is { OcrStatus: CheckOcrStatus.Completed } && _amount > 0m;

    private string BuildValidationTimeText()
        => _ocrResult?.AmountValidatedAt is DateTime dt ? $"（最后校验：{dt.ToLocalTime().ToString(OcrAmountValidationNotes.UiDateTimeFormat)}）" : string.Empty;

    private bool HasAmountValidationRawMismatch()
    {
        if (_ocrResult?.AmountValidationResult == null) return false;
        try
        {
            var payload = _ocrResult.AmountValidationResult.RootElement.GetRawText();
            var result = JsonSerializer.Deserialize<AmountValidationResult>(payload);
            return result?.IsConsistent == false;
        }
        catch
        {
            return false;
        }
    }

    private bool HasAmountValidationMismatch()
        => HasAmountValidationRawMismatch() && !HasManualReviewCompleted();

    // ── JSON 解析工具 ─────────────────────────────────────────────

    private static Dictionary<string, double> ExtractConfidenceScores(OcrResult ocrResult)
    {
        var dict = new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);
        var confJson = ocrResult.RawResult != null
            ? ocrResult.ConfidenceScores
            : ocrResult.AzureConfidenceScores;

        if (confJson?.RootElement.ValueKind != JsonValueKind.Object)
            return dict;

        foreach (var prop in confJson.RootElement.EnumerateObject())
        {
            if (prop.Value.ValueKind == JsonValueKind.Number)
                dict[prop.Name] = prop.Value.GetDouble();
            else if (prop.Value.ValueKind == JsonValueKind.String &&
                     double.TryParse(prop.Value.GetString(), out var parsed))
                dict[prop.Name] = parsed;
        }
        return dict;
    }

    private static string ExtractString(JsonElement root, string name)
        => root.TryGetProperty(name, out var el) && el.ValueKind != JsonValueKind.Null
            ? el.GetString() ?? "" : "";

    private static decimal ExtractDecimal(JsonElement root, string name)
    {
        if (!root.TryGetProperty(name, out var el) || el.ValueKind == JsonValueKind.Null)
            return 0m;
        return el.ValueKind switch
        {
            JsonValueKind.Number => el.GetDecimal(),
            JsonValueKind.String when decimal.TryParse(el.GetString(), out var v) => v,
            _ => 0m
        };
    }

    private static DateTime? ExtractDate(JsonElement root, string name)
    {
        if (!root.TryGetProperty(name, out var el) || el.ValueKind == JsonValueKind.Null)
            return null;
        return el.ValueKind == JsonValueKind.String &&
               DateTime.TryParse(el.GetString(), out var d) ? d : null;
    }

    private static string GetProxyImageUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return string.Empty;
        return $"/api/ImageProxy?url={Uri.EscapeDataString(url)}";
    }

