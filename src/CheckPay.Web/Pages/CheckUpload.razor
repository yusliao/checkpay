    private static string GetQueueThumbBorderColor(QueueItem item, QueueItem? current)
    {
        if (item == current)
            return "#1976d2";
        if (item.Done)
            return "#4caf50";
        if (item.ReusedHistoricalOcr)
            return "#ff9800";
        return "#e0e0e0";
    }

    /// <summary>Scoped DbContext 非线程安全；OCR 轮询与 UI 事件可能并发，序列化全部异步数据库访问。</summary>
    private readonly SemaphoreSlim _dbGate = new(1, 1);

    private async Task<T> DbSerializedAsync<T>(Func<Task<T>> action, CancellationToken cancellationToken = default)
    {
        await _dbGate.WaitAsync(cancellationToken);
        try { return await action(); }
        finally { _dbGate.Release(); }
    }

    private async Task DbSerializedAsync(Func<Task> action, CancellationToken cancellationToken = default)
    {
        await _dbGate.WaitAsync(cancellationToken);
        try { await action(); }
        finally { _dbGate.Release(); }
    }

    protected override async Task OnInitializedAsync()
    {
        _customers = await DbSerializedAsync(async () =>
            await DbContext.Customers
                .Where(c => c.IsActive)
                .Include(c => c.CompanyNames)
                .OrderBy(c => c.CustomerCode)
                .ThenBy(c => c.ExpectedRoutingNumber)
                .ToListAsync());
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        // 先全部读入内存，防止 DOM 切换后文件引用失效
        var snapshots = new List<(string Name, byte[] Data)>();
        foreach (var file in e.GetMultipleFiles(20))
        {
            try
            {
                using var raw = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var ms = new MemoryStream();
                await raw.CopyToAsync(ms);
                snapshots.Add((file.Name, ms.ToArray()));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"读取 {file.Name} 失败: {ex.Message}", Severity.Error);
            }
        }

        foreach (var (name, data) in snapshots)
        {
            var item = new QueueItem { FileName = name, Uploading = true, OcrStatus = CheckOcrStatus.Uploading };
            _uploadQueue.Add(item);
            if (_current == null) _current = item;
            StateHasChanged();

            try
            {
                using var uploadMs = new MemoryStream(data);
                item.ImageUrl = await BlobStorage.UploadAsync(uploadMs, name);
                item.Uploading = false;
                item.OcrStatus = CheckOcrStatus.Recognizing;
                StateHasChanged();

                var hash = OcrImageContentDedup.ComputeSha256Hex(data);
                var dedupEnabled = Configuration.GetValue("Ocr:Dedup:Enabled", true);
                var maxAgeDays = Configuration.GetValue<int?>("Ocr:Dedup:MaxSourceAgeDays");
                if (maxAgeDays is <= 0) maxAgeDays = null;

                OcrResult? reusable = null;
                var ocrResultId = Guid.Empty;
                await DbSerializedAsync(async () =>
                {
                    if (dedupEnabled && !_forceFreshOcr)
                    {
                        reusable = await OcrImageContentDedup.FindReusableCompletedAsync(
                            DbContext.OcrResults.AsNoTracking(),
                            hash,
                            maxAgeDays);
                    }

                    var ocrResult = new OcrResult
                    {
                        ImageUrl = item.ImageUrl,
                        ImageContentSha256 = hash,
                        Status = reusable != null ? OcrStatus.Completed : OcrStatus.Pending
                    };
                    if (reusable != null)
                    {
                        OcrImageContentDedup.CopyCompletedOcrFromSource(ocrResult, reusable);
                        OcrImageContentDedup.DisposeDetachedPayload(reusable);
                    }

                    DbContext.OcrResults.Add(ocrResult);
                    await DbContext.SaveChangesAsync();
                    ocrResultId = ocrResult.Id;
                });

                item.OcrResultId = ocrResultId;

                if (reusable == null)
                    await OcrWorker.EnqueueAsync(ocrResultId);
                else
                {
                    item.ReusedHistoricalOcr = true;
                    await InvokeAsync(StateHasChanged);
                }

                _ = PollOcrStatusAsync(item, _cts.Token);
            }
            catch (Exception ex)
            {
                item.Uploading = false;
                item.OcrStatus = CheckOcrStatus.Failed;
                Snackbar.Add($"上传 {name} 失败: {ex.Message}", Severity.Error);
                StateHasChanged();
            }
        }
    }

    /// <summary>轮询数据库直到 OCR 完成或失败</summary>
    private async Task PollOcrStatusAsync(QueueItem item, CancellationToken ct)
    {
        if (item.OcrResultId == null) return;

        while (!ct.IsCancellationRequested)
        {
            await Task.Delay(2000, ct);

            try
            {
                var result = await DbSerializedAsync(async () =>
                        await DbContext.OcrResults
                            .AsNoTracking()
                            .FirstOrDefaultAsync(o => o.Id == item.OcrResultId!.Value, ct),
                    ct);

                if (result == null) break;

                var payload = result.RawResult ?? result.AzureRawResult;
                if (result.Status == OcrStatus.Completed && payload != null)
                {
                    item.OcrStatus = CheckOcrStatus.Completed;
                    item.RawResult = result.RawResult ?? result.AzureRawResult;
                    item.ConfidenceScores = ExtractConfidenceScores(result);

                    // 当前选中时更新 _ocrResult
                    if (_current == item)
                        _ocrResult = result;

                    await InvokeAsync(async () =>
                    {
                        if (_current == item && IsFormEmpty())
                            await PrefillFormAsync(item);
                        if (_current == item)
                            RefreshOcrCopyPanelText();
                        StateHasChanged();
                    });
                    break;
                }

                if (result.Status == OcrStatus.Failed)
                {
                    item.OcrStatus = CheckOcrStatus.Failed;
                    if (_current == item)
                        RefreshOcrCopyPanelText();
                    await InvokeAsync(StateHasChanged);
                    break;
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch
            {
                // 轮询异常不致命，继续重试
            }
        }
    }

    private static JsonDocument? GetPreferredOcrDocument(QueueItem item) => item.RawResult;

    private Dictionary<string, double> GetPreferredConfidenceScores(QueueItem item) => item.ConfidenceScores;

    /// <summary>将识别结果预填到当前表单</summary>
    private async Task PrefillFormAsync(QueueItem item, bool force = false)
    {
        var rawResult = GetPreferredOcrDocument(item);
        if (rawResult == null) return;

        _confidenceScores = GetPreferredConfidenceScores(item);
        var root = rawResult.RootElement;

        // 始终预填识别到的值，置信度只影响视觉颜色/提示，不阻止填值
        var number = ExtractString(root, "CheckNumber");
        var amount = ExtractDecimal(root, "Amount");
        var date = ExtractDate(root, "Date");

        // force=true 时强制覆盖（切换滑块用），否则只在表单为空时预填
        if (!string.IsNullOrEmpty(number) && (force || string.IsNullOrEmpty(_checkNumber)))
            _checkNumber = number;
        if (amount > 0 && (force || _amount <= 0))
            _amount = amount;
        if (date.HasValue && (force || !_checkDate.HasValue))
            _checkDate = date;

        void PrefillStr(string jsonProp, ref string target, bool onlyIfEmpty = true)
        {
            var v = ExtractString(root, jsonProp);
            if (string.IsNullOrEmpty(v)) return;
            if (onlyIfEmpty && !force && !string.IsNullOrEmpty(target)) return;
            target = v;
        }

        PrefillStr("RoutingNumber", ref _routingNumber);
        PrefillStr("AccountNumber", ref _accountNumber);
        var acctForCustomer = ExtractString(root, "AccountNumber");
        if (!string.IsNullOrEmpty(acctForCustomer) && (force || string.IsNullOrWhiteSpace(_customerCode)))
            _customerCode = acctForCustomer;
        PrefillStr("BankName", ref _bankName);
        PrefillStr("AccountAddress", ref _accountAddress);
        var acctTypeRaw = ExtractString(root, "AccountType");
        if (!string.IsNullOrEmpty(acctTypeRaw))
        {
            var mapped = CheckAccountTypeCatalog.MatchSalesSelectable(acctTypeRaw);
            if (mapped != null && (force || string.IsNullOrEmpty(_accountType)
                    || string.Equals(_accountType, CheckAccountTypeCatalog.BusinessChecking, StringComparison.Ordinal)))
                _accountType = mapped;
        }

        var rawPayTo = ExtractString(root, "PayToOrderOf");
        if (!string.IsNullOrEmpty(rawPayTo))
        {
            var canonicalPayTo = PayToOrderOfCatalog.MatchCanonical(rawPayTo);
            if (canonicalPayTo != null && (force || string.IsNullOrEmpty(_payToOrderOf)
                    || string.Equals(_payToOrderOf, PayToOrderOfCatalog.CheungKongAllianceFood, StringComparison.Ordinal)))
                _payToOrderOf = canonicalPayTo;
        }
        PrefillStr("ForMemo", ref _forMemo);
        PrefillStr("MicrLineRaw", ref _micrLineRaw);
        PrefillStr("CheckNumberMicr", ref _checkNumberMicr);

        var payToForMerge = string.IsNullOrEmpty(_payToOrderOf) ? rawPayTo : _payToOrderOf;
        var mergedHolderCompany = OcrCheckCustomerFields.MergeHolderCompanyDisplayName(
            ExtractString(root, "CompanyName"),
            ExtractString(root, "AccountHolderName"),
            payToForMerge);
        if (!string.IsNullOrEmpty(mergedHolderCompany))
        {
            if (force)
            {
                _accountHolderName = mergedHolderCompany;
                _companyName = mergedHolderCompany;
            }
            else if (string.IsNullOrEmpty(_accountHolderName) && string.IsNullOrEmpty(_companyName))
            {
                _accountHolderName = mergedHolderCompany;
                _companyName = mergedHolderCompany;
            }
            else
            {
                if (string.IsNullOrEmpty(_accountHolderName)) _accountHolderName = mergedHolderCompany;
                if (string.IsNullOrEmpty(_companyName)) _companyName = mergedHolderCompany;
                if (!string.Equals(_accountHolderName, _companyName, StringComparison.Ordinal))
                {
                    _accountHolderName = mergedHolderCompany;
                    _companyName = mergedHolderCompany;
                }
            }
        }

        await SyncCustomerFromMasterAsync();
    }

    private async Task OnCustomerAccountBlurAsync(FocusEventArgs _)
        => await SyncCustomerFromMasterAsync();

    private Task OnAchRoutingBlurAsync(FocusEventArgs _)
        => SyncCustomerFromMasterAsync();

    /// <summary>客户账号有值时，从客户主数据按「账号 + 9 位 ABA」同步手机号、期望银行名、公司/持有人、地址、账户类型、Pay to（空则填；账号+ABA 相对上次成功同步变化时可覆盖）；OCR 或手工变更账号/路由时也会触发。</summary>
    private async Task SyncCustomerFromMasterAsync(CancellationToken cancellationToken = default)
    {
        if (string.IsNullOrWhiteSpace(_customerCode))
        {
            _lastCustomerCodeForAutoPhone = null;
            _lastRoutingKeyForAutoPhone = null;
            return;
        }

        var code = _customerCode.Trim();
        var lower = code.ToLowerInvariant();
        var routingKey = CustomerAchRoutingLookup.NormalizeRoutingKey(_routingNumber);

        await DbSerializedAsync(async () =>
        {
            var query = DbContext.Customers
                .AsNoTracking()
                .Where(c => c.IsActive && c.CustomerCode.ToLower() == lower);
            if (routingKey.Length == 9)
                query = query.Where(c => c.ExpectedRoutingNumber == routingKey);
            else
                query = query.Where(c => c.ExpectedRoutingNumber == "");

            var rowEntity = await query.FirstOrDefaultAsync(cancellationToken);
            CustomerMasterSync.MasterRow? masterRow = rowEntity == null
                ? null
                : new CustomerMasterSync.MasterRow(
                    rowEntity.MobilePhone,
                    rowEntity.ExpectedBankName,
                    rowEntity.ExpectedCompanyName,
                    rowEntity.ExpectedAccountHolderName,
                    rowEntity.ExpectedAccountAddress,
                    rowEntity.ExpectedAccountType,
                    rowEntity.ExpectedPayToOrderOf);

            var lastCode = _lastCustomerCodeForAutoPhone;
            var lastRk = _lastRoutingKeyForAutoPhone;
            CustomerMasterSync.ApplyToCheckFormFields(
                masterRow,
                code,
                routingKey,
                ref lastCode,
                ref lastRk,
                ref _customerPhone,
                ref _bankName,
                ref _companyName,
                ref _accountHolderName,
                ref _accountAddress,
                ref _accountType,
                ref _payToOrderOf);
            _lastCustomerCodeForAutoPhone = lastCode;
            _lastRoutingKeyForAutoPhone = lastRk;
        }, cancellationToken);
    }

    private async Task SelectItemAsync(QueueItem item)
    {
        _current = item;
        ClearForm();
        _ocrResult = null;

        if (item.OcrResultId.HasValue)
        {
            await DbSerializedAsync(async () =>
            {
                var result = await DbContext.OcrResults
                    .AsNoTracking()
                    .FirstOrDefaultAsync(o => o.Id == item.OcrResultId!.Value);
                if (result != null)
                    _ocrResult = result;

                if (item.Done)
                {
                    var record = await DbContext.CheckRecords
                        .AsNoTracking()
                        .Include(c => c.Customer)
                        .Where(c => c.OcrResultId == item.OcrResultId)
                        .OrderByDescending(c => c.CreatedAt)
                        .FirstOrDefaultAsync();
                    if (record != null)
                        ApplyCheckRecordToForm(item, record);
                }
            });
        }

        if (!item.Done && item.OcrStatus == CheckOcrStatus.Completed)
            await PrefillFormAsync(item);

        RefreshOcrCopyPanelText();
        StateHasChanged();
    }

    private bool IsCurrentQueueItemReadOnly()
        => _current?.Done == true;

    private void ApplyCheckRecordToForm(QueueItem queueItem, CheckRecord record)
    {
        _checkNumber = record.CheckNumber;
        _amount = record.CheckAmount;
        _checkDate = record.CheckDate;
        _notes = record.Notes ?? "";
        _routingNumber = record.RoutingNumber ?? "";
        _accountNumber = record.AccountNumber ?? "";
        _bankName = record.BankName ?? "";
        _accountHolderName = record.AccountHolderName ?? "";
        _accountAddress = record.AccountAddress ?? "";
        _accountType = string.IsNullOrWhiteSpace(record.AccountType)
            ? CheckAccountTypeCatalog.BusinessChecking
            : record.AccountType;
        _payToOrderOf = string.IsNullOrWhiteSpace(record.PayToOrderOf)
            ? PayToOrderOfCatalog.CheungKongAllianceFood
            : record.PayToOrderOf!;
        _forMemo = record.ForMemo ?? "";
        _micrLineRaw = record.MicrLineRaw ?? "";
        _checkNumberMicr = record.CheckNumberMicr ?? "";
        _invoiceNumbers = record.InvoiceNumbers ?? "";
        _paymentPeriodText = record.PaymentPeriodText ?? "";
        _companyName = record.CompanyName ?? "";

        if (record.Customer != null)
        {
            _customerCode = record.Customer.CustomerCode;
            _customerPhone = record.Customer.MobilePhone ?? "";
            _lastCustomerCodeForAutoPhone = _customerCode.Trim().ToLowerInvariant();
            _lastRoutingKeyForAutoPhone = CustomerAchRoutingLookup.NormalizeRoutingKey(_routingNumber);
        }
        else
        {
            _customerCode = "";
            _customerPhone = "";
            _lastCustomerCodeForAutoPhone = null;
            _lastRoutingKeyForAutoPhone = null;
        }

        _confidenceScores = new Dictionary<string, double>(queueItem.ConfidenceScores, StringComparer.OrdinalIgnoreCase);
    }

    private void RefreshOcrCopyPanelText()
    {
        if (_current == null || _current.OcrStatus != CheckOcrStatus.Completed)
        {
            _ocrCopyPanelText = "";
            return;
        }

        var doc = GetPreferredOcrDocument(_current);
        _ocrCopyPanelText = OcrCheckCopyPanelFormatter.FromJsonDocument(doc);
    }

