@page "/checks/upload"
@attribute [Authorize(Roles = "Sales,Admin")]
@using CheckPay.Application.Common.Interfaces
@using CheckPay.Domain.Entities
@using CheckPay.Domain.Enums
@using CheckPay.Application.Common
@using CheckPay.Application.Common.Models
@using CheckPay.Worker.Services
@using CheckPay.Web.Common
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Configuration
@using Microsoft.JSInterop
@using System.Text.Json
@implements IDisposable
@inject IBlobStorageService BlobStorage
@inject IJSRuntime JS
@inject IApplicationDbContext DbContext
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject OcrWorker OcrWorker
@inject IOcrService OcrService
@inject IAuditLogService AuditLog
@inject IConfiguration Configuration

<PageTitle>上传支票 - CheckPay</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">上传支票</MudText>

@* 步骤一：拖拽上传区 *@
@if (!_uploadQueue.Any())
{
    <MudPaper Class="pa-6 text-center" Style="border:2px dashed #ccc">
        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Primary" />
        <MudText Class="mt-2">选择支票图片（支持多张），上传后自动 OCR 识别</MudText>
        <InputFile id="checkBatch" OnChange="OnFilesSelected" accept="image/*" multiple hidden />
        <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" for="checkBatch">
            选择文件
        </MudButton>
    </MudPaper>
}
else
{
    @* 步骤二：队列缩略图 *@
    <MudPaper Class="pa-4 mb-4">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">
            待录入队列（@_uploadQueue.Count 张）— 已完成 @_uploadQueue.Count(q => q.Done) 张
        </MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
            @foreach (var item in _uploadQueue)
            {
                <div style="position:relative;width:100px">
                    <MudPaper @onclick="() => SelectItem(item)"
                              Elevation="item == _current ? 4 : 1"
                              Class="pa-2 text-center"
                              Style="@($"width:100px;cursor:pointer;border:2px solid {(item == _current ? "#1976d2" : item.Done ? "#4caf50" : "#e0e0e0")}")">
                        <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Medium"
                                 Color="@(item.Done ? Color.Success : Color.Default)" />
                        <MudText Typo="Typo.caption" Style="word-break:break-all">@item.FileName</MudText>
                        <MudText Typo="Typo.caption" Color="@(item.Done ? Color.Success : Color.Warning)">
                            @(item.Done ? "✅ 已录入" : "⏳ 待录入")
                        </MudText>
                    </MudPaper>
                    @if (!item.Uploading)
                    {
                        <span @onclick:stopPropagation="true"
                              style="position:absolute;top:-8px;right:-8px">
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           Style="background:white;padding:2px;width:20px;height:20px;min-width:0"
                                           OnClick="() => RemoveItem(item)" />
                        </span>
                    }
                </div>
            }
            @* 继续添加更多文件 *@
            <MudPaper Class="pa-2 text-center d-flex align-center justify-center"
                      Style="width:100px;cursor:pointer;border:2px dashed #ccc">
                <InputFile id="checkMore" OnChange="OnFilesSelected" accept="image/*" multiple hidden />
                <MudButton HtmlTag="label" for="checkMore" Style="min-width:0;padding:0">
                    <MudIcon Icon="@Icons.Material.Filled.Add" />
                </MudButton>
            </MudPaper>
        </MudStack>
    </MudPaper>

    @* 步骤三：左图右表单 *@
    @if (_current != null)
    {
        <MudGrid>
            @* 左：图片预览 + OCR 状态 *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" GutterBottom="true">支票图片</MudText>

                    @if (_current.Uploading)
                    {
                        <MudPaper Class="d-flex flex-column align-center justify-center pa-6"
                                  Style="background:#f5f5f5;min-height:200px">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Class="mt-2" Typo="Typo.caption">上传中...</MudText>
                        </MudPaper>
                    }
                    else if (!string.IsNullOrEmpty(_current.ImageUrl))
                    {
                        <MudImage Src="@GetProxyImageUrl(_current.ImageUrl)" Alt="支票图片"
                                  Class="rounded" Style="max-width:100%" />

                        @* OCR 识别状态 *@
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2" Spacing="1">
                            @if (_current.OcrStatus == CheckOcrStatus.Recognizing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" />
                                <MudText Typo="Typo.caption" Color="Color.Info">正在 OCR 识别，稍候...</MudText>
                            }
                            else if (_current.OcrStatus == CheckOcrStatus.Completed)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.AutoFixHigh" Size="Size.Small" Color="Color.Success" />
                                <MudText Typo="Typo.caption" Color="Color.Success">OCR 识别完成，已预填表单</MudText>
                                <MudTooltip Text="对识别结果不满意？点击再次识别">
                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                                   Color="Color.Info" OnClick="RetryOcrAsync"
                                                   Disabled="@_retryingOcr" />
                                </MudTooltip>
                            }
                            else if (_current.OcrStatus == CheckOcrStatus.Failed)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" Color="Color.Warning" />
                                <MudText Typo="Typo.caption" Color="Color.Warning">
                                    OCR 识别失败，请手动填写或重试
                                </MudText>
                                <MudTooltip Text="重新尝试 OCR 识别">
                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                                   Color="Color.Warning" OnClick="RetryOcrAsync"
                                                   Disabled="@_retryingOcr" />
                                </MudTooltip>
                            }
                        </MudStack>
                    }
                </MudPaper>

                @if (!string.IsNullOrEmpty(_ocrCopyPanelText))
                {
                    <MudPaper Class="pa-4 mt-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                            <MudText Typo="Typo.h6">抽取全文 / 解析摘要</MudText>
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.ContentCopy"
                                       OnClick="CopyOcrPanelAsync">
                                复制全部
                            </MudButton>
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                            与训练标注页相同格式，可整段复制后粘贴到备忘录或其它系统。
                        </MudText>
                        <MudPaper Class="pa-3" Style="background:#1e1e1e;border-radius:4px;overflow-x:auto;max-height:320px;overflow-y:auto">
                            <pre style="color:#d4d4d4;font-size:12px;margin:0;white-space:pre-wrap;word-break:break-all">@_ocrCopyPanelText</pre>
                        </MudPaper>
                    </MudPaper>
                }
            </MudItem>

            @* 右：复核表单 *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudText Typo="Typo.h6">录入信息</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            OCR：Azure AI Vision Read
                        </MudText>
                    </MudStack>

                    @if (_current.OcrStatus == CheckOcrStatus.Recognizing || _current.Uploading)
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" Class="mb-2 rounded" />
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" Class="mb-2 rounded" />
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" Class="mb-2 rounded" />
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="56px" Class="mb-2 rounded" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                            OCR 识别中，表单预填完成后可编辑...
                        </MudText>
                    }
                    else
                    {
                        @* 支票号 *@
                        <div class="mb-2">
                            <MudTextField @bind-Value="_checkNumber"
                                          Label="支票号"
                                          Required="true"
                                          Variant="Variant.Outlined"
                                          Style="@GetFieldStyle("checkNumber")"
                                          HelperText="@GetFieldHint("checkNumber")"
                                          HelperTextOnFocus="false"
                                          Adornment="@GetAdornment("checkNumber")"
                                          AdornmentColor="@GetAdornmentColor("checkNumber")"
                                          AdornmentIcon="@GetAdornmentIcon("checkNumber")" />
                        </div>

                        @* 金额 *@
                        <div class="mb-2">
                            <MudNumericField @bind-Value="_amount"
                                             Label="金额"
                                             Required="true"
                                             Format="N2"
                                             Variant="Variant.Outlined"
                                             Style="@GetFieldStyle("amount")"
                                             HelperText="@GetFieldHint("amount")"
                                             HelperTextOnFocus="false"
                                             Adornment="@GetAdornment("amount")"
                                             AdornmentColor="@GetAdornmentColor("amount")"
                                             AdornmentIcon="@GetAdornmentIcon("amount")" />
                        </div>
                        @if (TryBuildAmountValidationHint(out var validationSeverity, out var validationText))
                        {
                            <MudAlert Severity="@validationSeverity" Dense="true" Class="mb-2">
                                @validationText
                            </MudAlert>
                        }
                        @if (HasAmountValidationMismatch())
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.ReportProblem" Class="mr-1" />
                                @OcrAmountValidationNotes.MismatchBlockingMessage
                            </MudAlert>
                        }
                        @if (CanShowManualAmountValidationButton())
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       Color="Color.Info"
                                       Class="mb-2"
                                       StartIcon="@Icons.Material.Filled.FactCheck"
                                       OnClick="RunAmountValidationAsync"
                                       Disabled="@_amountValidationRunning">
                                @(_amountValidationRunning ? OcrAmountValidationNotes.ManualValidatingButtonText : OcrAmountValidationNotes.ManualValidateButtonText)
                            </MudButton>
                        }

                        @* 日期 *@
                        <div class="mb-2">
                            <MudDatePicker @bind-Date="_checkDate"
                                           Label="日期"
                                           Required="true"
                                           Variant="Variant.Outlined"
                                           Style="@GetFieldStyle("date")"
                                           HelperText="@GetFieldHint("date")" />
                        </div>

                        <MudDivider Class="my-3" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">ACH / 票面信息</MudText>
                        <MudTextField @bind-Value="_routingNumber" Label="Routing Number (ABA)" Variant="Variant.Outlined" Class="mb-2"
                                      Style="@GetFieldStyle("routingNumber")" HelperText="@GetFieldHint("routingNumber")" />
                        <MudTextField @bind-Value="_accountNumber" Label="Account Number" Variant="Variant.Outlined" Class="mb-2"
                                      Style="@GetFieldStyle("accountNumber")" HelperText="@GetFieldHint("accountNumber")" />
                        <MudTextField @bind-Value="_bankName" Label="Bank Name" Variant="Variant.Outlined" Class="mb-2"
                                      Style="@GetFieldStyle("bankName")" HelperText="@GetFieldHint("bankName")" />
                        <MudTextField @bind-Value="_accountHolderName" Label="Account Holder Name" Variant="Variant.Outlined" Class="mb-2"
                                      Style="@GetFieldStyle("accountHolderName")" HelperText="@GetFieldHint("accountHolderName")" />
                        <MudTextField @bind-Value="_accountAddress" Label="Account Address" Variant="Variant.Outlined" Class="mb-2"
                                      Style="@GetFieldStyle("accountAddress")" HelperText="@GetFieldHint("accountAddress")" Lines="2" />
                        <MudSelect T="string" @bind-Value="_accountType" Label="Account Type" Variant="Variant.Outlined"
                                   Class="mb-2" Clearable="true"
                                   Style="@GetFieldStyle("accountType")" HelperText="@GetFieldHint("accountType")">
                            <MudSelectItem T="string" Value="@("")">（请选择）</MudSelectItem>
                            <MudSelectItem T="string" Value="@CheckAccountTypeCatalog.BusinessChecking">
                                @CheckAccountTypeCatalog.BusinessChecking
                            </MudSelectItem>
                            <MudSelectItem T="string" Value="@CheckAccountTypeCatalog.Savings">
                                @CheckAccountTypeCatalog.Savings
                            </MudSelectItem>
                        </MudSelect>
                        <MudSelect T="string" @bind-Value="_payToOrderOf" Label="Pay to the order of" Variant="Variant.Outlined"
                                   Class="mb-2" Clearable="true"
                                   Style="@GetFieldStyle("payToOrderOf")" HelperText="@GetFieldHint("payToOrderOf")">
                            <MudSelectItem T="string" Value="@("")">（请选择）</MudSelectItem>
                            <MudSelectItem T="string" Value="@PayToOrderOfCatalog.CheungKongAllianceFood">
                                @PayToOrderOfCatalog.CheungKongAllianceFood
                            </MudSelectItem>
                            <MudSelectItem T="string" Value="@PayToOrderOfCatalog.MaxwellExcelFood">
                                @PayToOrderOfCatalog.MaxwellExcelFood
                            </MudSelectItem>
                        </MudSelect>
                        <MudTextField @bind-Value="_forMemo" Label="For / Memo" Variant="Variant.Outlined" Class="mb-2"
                                      Style="@GetFieldStyle("forMemo")" HelperText="@GetFieldHint("forMemo")" />
                        <MudTextField @bind-Value="_micrLineRaw" Label="MICR line (raw)" Variant="Variant.Outlined" Class="mb-2"
                                      Style="@GetFieldStyle("micrLineRaw")" HelperText="@GetFieldHint("micrLineRaw")" Lines="2" />
                        <MudTextField @bind-Value="_checkNumberMicr" Label="Check # (MICR)" Variant="Variant.Outlined" Class="mb-2"
                                      Style="@GetFieldStyle("checkNumberMicr")" HelperText="@GetFieldHint("checkNumberMicr")" />

                        <MudTextField @bind-Value="_companyName" Label="公司名称（付款/开票主体）" Variant="Variant.Outlined" Class="mb-2"
                                      Style="@GetFieldStyle("companyName")" HelperText="@GetFieldHint("companyName")" />

                        @* 客户账号 (customer_code =支票账号)；手机号与客户账号 1 对多（同一手机可对应多个账号） *@
                        <MudTextField @bind-Value="_customerCode"
                                      Label="客户账号"
                                      Required="true"
                                      Variant="Variant.Outlined"
                                      Class="mb-2"
                                      Placeholder="与支票账号一致，支持新建"
                                      OnBlur="@OnCustomerAccountBlur" />
                        <MudTextField @bind-Value="_customerPhone"
                                      Label="客户手机号"
                                      Required="true"
                                      Variant="Variant.Outlined"
                                      Class="mb-2"
                                      Placeholder="必填，可与主数据不一致时更新主数据"
                                      MaxLength="30" />

                        @if (ShowCustomerAuthorizationHint())
                        {
                            <MudText Typo="Typo.caption" Color="Color.Warning" Class="mb-2" Style="display:block">
                                该账号与公司信息可能未授权，请注意确认
                            </MudText>
                        }

                        @if (!string.IsNullOrWhiteSpace(_customerCode))
                        {
                            var match = GetCustomerMatch();
                            if (match != null)
                            {
                                <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                                    匹配客户：@match.CustomerName · 手机 @CustomerDisplay.MobileOrDash(match.MobilePhone)
                                </MudAlert>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                                    新客户将自动创建：@_customerCode.Trim()
                                </MudAlert>
                            }
                        }

                        @if (ShowNewCompanyRelationshipWarning())
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">
                                这是新的客户关系：当前公司名称未在该客户账号下登记，请在客户管理中维护关联公司后再核对。
                            </MudAlert>
                        }

                        <MudTextField @bind-Value="_notes" Label="备注" Lines="2"
                                      Variant="Variant.Outlined" Class="mb-3" />

                        <MudTextField @bind-Value="_invoiceNumbers" Label="发票号码（多个用英文逗号分隔）" Variant="Variant.Outlined" Class="mb-2" />
                        <MudTextField @bind-Value="_paymentPeriodText" Label="支付对应期间（如 2026-06）" Variant="Variant.Outlined" Class="mb-3" />

                        @* 置信度图例 *@
                        @if (_confidenceScores.Count > 0)
                        {
                            <MudPaper Class="pa-2 mb-4" Style="background:#f5f5f5">
                                <MudText Typo="Typo.caption">置信度说明：</MudText>
                                <MudStack Row="true" Spacing="2" Class="mt-1">
                                    <MudChip T="string" Size="Size.Small" Style="background:#e8f5e9;color:#2e7d32">高 ≥85%</MudChip>
                                    <MudChip T="string" Size="Size.Small" Style="background:#fff3e0;color:#e65100">中 60-85%</MudChip>
                                    <MudChip T="string" Size="Size.Small" Style="background:#ffebee;color:#c62828">低 &lt;60%</MudChip>
                                </MudStack>
                            </MudPaper>
                        }

                        <MudButton Variant="Variant.Outlined" Class="mr-2" OnClick="SkipCurrent"
                                   Disabled="@(_current.Uploading)">跳过</MudButton>
                        @if (HasAmountValidationMismatch())
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Warning"
                                       Class="mr-2"
                                       StartIcon="@Icons.Material.Filled.ReportProblem"
                                       OnClick="SaveDraftWithMismatchReasonAsync"
                                       Disabled="@(_saving || _current.Uploading || _current.OcrStatus == CheckOcrStatus.Recognizing)">
                                @OcrAmountValidationNotes.DraftOnMismatchButtonText
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined" Color="Color.Info" Class="mr-2" OnClick="() => SaveCurrent(false)"
                                   Disabled="@(_saving || _current.Uploading || _current.OcrStatus == CheckOcrStatus.Recognizing)">
                            @(_saving ? "保存中..." : "保存草稿")
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="() => SaveCurrent(true)"
                                   Disabled="@(_saving || _current.Uploading || _current.OcrStatus == CheckOcrStatus.Recognizing)">
                            @(_saving ? "保存中..." : "提交入库")
                        </MudButton>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else if (_uploadQueue.All(q => q.Done))
    {
        <MudAlert Severity="Severity.Success" Class="mt-4">
            所有支票录入完成！共处理 @_uploadQueue.Count 张。
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2" OnClick="Reset">
            继续上传
        </MudButton>
        <MudButton Variant="Variant.Outlined" Class="mt-2 ml-2" OnClick='() => Navigation.NavigateTo("/records")'>
            查看收款记录
        </MudButton>
    }
}

@code {
    private enum CheckOcrStatus { Idle, Uploading, Recognizing, Completed, Failed }

    private class QueueItem
    {
        public string FileName { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public bool Uploading { get; set; }
        public bool Done { get; set; }
        public CheckOcrStatus OcrStatus { get; set; } = CheckOcrStatus.Idle;
        public Guid? OcrResultId { get; set; }
        // 识别完成后缓存的数据（与 ocr_results.raw_result 一致）
        public JsonDocument? RawResult { get; set; }
        public Dictionary<string, double> ConfidenceScores { get; set; } = new(StringComparer.OrdinalIgnoreCase);
    }

    private List<QueueItem> _uploadQueue = new();
    private QueueItem? _current;

    private List<Customer> _customers = new();

    // 表单字段
    private string _checkNumber = "";
    private decimal _amount;
    private DateTime? _checkDate;
    private string _customerCode = "";
    private string _customerPhone = "";
    private string _notes = "";
    private string _routingNumber = "";
    private string _accountNumber = "";
    private string _bankName = "";
    private string _accountHolderName = "";
    private string _accountAddress = "";
    private string _accountType = "";
    private string _payToOrderOf = "";
    private string _forMemo = "";
    private string _micrLineRaw = "";
    private string _checkNumberMicr = "";
    private string _invoiceNumbers = "";
    private string _paymentPeriodText = "";
    private string _companyName = "";
    private Dictionary<string, double> _confidenceScores = new(StringComparer.OrdinalIgnoreCase);

    private bool _saving;
    private bool _retryingOcr;
    private bool _amountValidationRunning;
    private OcrResult? _ocrResult; // 当前 OCR 结果
    private string _ocrCopyPanelText = "";

    private readonly CancellationTokenSource _cts = new();

    protected override async Task OnInitializedAsync()
    {
        _customers = await DbContext.Customers
            .Where(c => c.IsActive)
            .Include(c => c.CompanyNames)
            .ToListAsync();
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        // 先全部读入内存，防止 DOM 切换后文件引用失效
        var snapshots = new List<(string Name, byte[] Data)>();
        foreach (var file in e.GetMultipleFiles(20))
        {
            try
            {
                using var raw = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var ms = new MemoryStream();
                await raw.CopyToAsync(ms);
                snapshots.Add((file.Name, ms.ToArray()));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"读取 {file.Name} 失败: {ex.Message}", Severity.Error);
            }
        }

        foreach (var (name, data) in snapshots)
        {
            var item = new QueueItem { FileName = name, Uploading = true, OcrStatus = CheckOcrStatus.Uploading };
            _uploadQueue.Add(item);
            if (_current == null) _current = item;
            StateHasChanged();

            try
            {
                // 1. 上传到 Blob 存储
                using var ms = new MemoryStream(data);
                item.ImageUrl = await BlobStorage.UploadAsync(ms, name);
                item.Uploading = false;
                item.OcrStatus = CheckOcrStatus.Recognizing;
                StateHasChanged();

                // 2. 创建 OcrResult 记录并入队
                var ocrResult = new OcrResult
                {
                    ImageUrl = item.ImageUrl,
                    Status = OcrStatus.Pending
                };
                DbContext.OcrResults.Add(ocrResult);
                await DbContext.SaveChangesAsync();
                await OcrWorker.EnqueueAsync(ocrResult.Id);
                item.OcrResultId = ocrResult.Id;

                // 3. 启动轮询（不 await，后台跑）
                _ = PollOcrStatusAsync(item, _cts.Token);
            }
            catch (Exception ex)
            {
                item.Uploading = false;
                item.OcrStatus = CheckOcrStatus.Failed;
                Snackbar.Add($"上传 {name} 失败: {ex.Message}", Severity.Error);
                StateHasChanged();
            }
        }
    }

    /// <summary>轮询数据库直到 OCR 完成或失败</summary>
    private async Task PollOcrStatusAsync(QueueItem item, CancellationToken ct)
    {
        if (item.OcrResultId == null) return;

        while (!ct.IsCancellationRequested)
        {
            await Task.Delay(2000, ct);

            try
            {
                var result = await DbContext.OcrResults
                    .AsNoTracking()
                    .FirstOrDefaultAsync(o => o.Id == item.OcrResultId, ct);

                if (result == null) break;

                var payload = result.RawResult ?? result.AzureRawResult;
                if (result.Status == OcrStatus.Completed && payload != null)
                {
                    item.OcrStatus = CheckOcrStatus.Completed;
                    item.RawResult = result.RawResult ?? result.AzureRawResult;
                    item.ConfidenceScores = ExtractConfidenceScores(result);

                    // 当前选中时更新 _ocrResult
                    if (_current == item)
                        _ocrResult = result;

                    // 当前选中且表单还是空的，自动预填
                    if (_current == item && IsFormEmpty())
                        PrefillForm(item);
                    if (_current == item)
                        RefreshOcrCopyPanelText();

                    await InvokeAsync(StateHasChanged);
                    break;
                }

                if (result.Status == OcrStatus.Failed)
                {
                    item.OcrStatus = CheckOcrStatus.Failed;
                    if (_current == item)
                        RefreshOcrCopyPanelText();
                    await InvokeAsync(StateHasChanged);
                    break;
                }
            }
            catch (OperationCanceledException)
            {
                break;
            }
            catch
            {
                // 轮询异常不致命，继续重试
            }
        }
    }

    private static JsonDocument? GetPreferredOcrDocument(QueueItem item) => item.RawResult;

    private Dictionary<string, double> GetPreferredConfidenceScores(QueueItem item) => item.ConfidenceScores;

    /// <summary>将识别结果预填到当前表单</summary>
    private void PrefillForm(QueueItem item, bool force = false)
    {
        var rawResult = GetPreferredOcrDocument(item);
        if (rawResult == null) return;

        _confidenceScores = GetPreferredConfidenceScores(item);
        var root = rawResult.RootElement;

        // 始终预填识别到的值，置信度只影响视觉颜色/提示，不阻止填值
        var number = ExtractString(root, "CheckNumber");
        var amount = ExtractDecimal(root, "Amount");
        var date = ExtractDate(root, "Date");

        // force=true 时强制覆盖（切换滑块用），否则只在表单为空时预填
        if (!string.IsNullOrEmpty(number) && (force || string.IsNullOrEmpty(_checkNumber)))
            _checkNumber = number;
        if (amount > 0 && (force || _amount <= 0))
            _amount = amount;
        if (date.HasValue && (force || !_checkDate.HasValue))
            _checkDate = date;

        void PrefillStr(string jsonProp, ref string target, bool onlyIfEmpty = true)
        {
            var v = ExtractString(root, jsonProp);
            if (string.IsNullOrEmpty(v)) return;
            if (onlyIfEmpty && !force && !string.IsNullOrEmpty(target)) return;
            target = v;
        }

        PrefillStr("RoutingNumber", ref _routingNumber);
        PrefillStr("AccountNumber", ref _accountNumber);
        var acctForCustomer = ExtractString(root, "AccountNumber");
        if (!string.IsNullOrEmpty(acctForCustomer) && (force || string.IsNullOrWhiteSpace(_customerCode)))
            _customerCode = acctForCustomer;
        PrefillStr("BankName", ref _bankName);
        PrefillStr("AccountAddress", ref _accountAddress);
        var acctTypeRaw = ExtractString(root, "AccountType");
        if (!string.IsNullOrEmpty(acctTypeRaw) && (force || string.IsNullOrEmpty(_accountType)))
        {
            var mapped = CheckAccountTypeCatalog.MatchSalesSelectable(acctTypeRaw);
            if (mapped != null)
                _accountType = mapped;
        }
        var rawPayTo = ExtractString(root, "PayToOrderOf");
        if (!string.IsNullOrEmpty(rawPayTo) && (force || string.IsNullOrEmpty(_payToOrderOf)))
            _payToOrderOf = PayToOrderOfCatalog.MatchCanonical(rawPayTo) ?? "";
        PrefillStr("ForMemo", ref _forMemo);
        PrefillStr("MicrLineRaw", ref _micrLineRaw);
        PrefillStr("CheckNumberMicr", ref _checkNumberMicr);

        var payToForMerge = string.IsNullOrEmpty(_payToOrderOf) ? rawPayTo : _payToOrderOf;
        var mergedHolderCompany = OcrCheckCustomerFields.MergeHolderCompanyDisplayName(
            ExtractString(root, "CompanyName"),
            ExtractString(root, "AccountHolderName"),
            payToForMerge);
        if (!string.IsNullOrEmpty(mergedHolderCompany))
        {
            if (force)
            {
                _accountHolderName = mergedHolderCompany;
                _companyName = mergedHolderCompany;
            }
            else if (string.IsNullOrEmpty(_accountHolderName) && string.IsNullOrEmpty(_companyName))
            {
                _accountHolderName = mergedHolderCompany;
                _companyName = mergedHolderCompany;
            }
            else
            {
                if (string.IsNullOrEmpty(_accountHolderName)) _accountHolderName = mergedHolderCompany;
                if (string.IsNullOrEmpty(_companyName)) _companyName = mergedHolderCompany;
                if (!string.Equals(_accountHolderName, _companyName, StringComparison.Ordinal))
                {
                    _accountHolderName = mergedHolderCompany;
                    _companyName = mergedHolderCompany;
                }
            }
        }

        SyncCustomerPhoneFromMasterIfNeeded();
    }

    private void OnCustomerAccountBlur(FocusEventArgs _)
        => SyncCustomerPhoneFromMasterIfNeeded();

    /// <summary>主数据中已有该账号时，若手机号未填则带出主数据手机号。</summary>
    private void SyncCustomerPhoneFromMasterIfNeeded()
    {
        if (string.IsNullOrWhiteSpace(_customerCode) || !string.IsNullOrWhiteSpace(_customerPhone)) return;
        var code = _customerCode.Trim();
        var c = _customers.FirstOrDefault(x => x.CustomerCode.Equals(code, StringComparison.OrdinalIgnoreCase));
        if (c != null && !string.IsNullOrWhiteSpace(c.MobilePhone))
            _customerPhone = c.MobilePhone;
    }

    private void SelectItem(QueueItem item)
    {
        if (item.Done) return;
        _current = item;
        ClearForm();

        // 异步加载 OCR 结果
        if (item.OcrResultId.HasValue)
        {
            _ = Task.Run(async () =>
            {
                var result = await DbContext.OcrResults
                    .AsNoTracking()
                    .FirstOrDefaultAsync(o => o.Id == item.OcrResultId.Value);
                if (result != null)
                {
                    _ocrResult = result;
                    await InvokeAsync(StateHasChanged);
                }
            });
        }

        // 切换时如果 OCR 已完成，立即预填
        if (item.OcrStatus == CheckOcrStatus.Completed)
            PrefillForm(item);
        RefreshOcrCopyPanelText();
        StateHasChanged();
    }

    private void RefreshOcrCopyPanelText()
    {
        if (_current == null || _current.OcrStatus != CheckOcrStatus.Completed)
        {
            _ocrCopyPanelText = "";
            return;
        }

        var doc = GetPreferredOcrDocument(_current);
        _ocrCopyPanelText = OcrCheckCopyPanelFormatter.FromJsonDocument(doc);
    }

    private async Task CopyOcrPanelAsync()
    {
        if (string.IsNullOrEmpty(_ocrCopyPanelText)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _ocrCopyPanelText);
            Snackbar.Add("已复制到剪贴板", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"复制失败: {ex.Message}", Severity.Warning);
        }
    }

    /// <summary>再次识别：重置 OcrResult 状态，重新入队</summary>
    private async Task RetryOcrAsync()
    {
        if (_current?.OcrResultId == null || _retryingOcr) return;

        _retryingOcr = true;
        try
        {
            var tracked = await DbContext.OcrResults.FirstOrDefaultAsync(o => o.Id == _current.OcrResultId);
            if (tracked == null)
            {
                Snackbar.Add("未找到 OCR 记录", Severity.Error);
                return;
            }

            tracked.Status = OcrStatus.Pending;
            tracked.ErrorMessage = null;
            tracked.RawResult?.Dispose();
            tracked.RawResult = null;
            tracked.ConfidenceScores?.Dispose();
            tracked.ConfidenceScores = null;
            tracked.AzureRawResult?.Dispose();
            tracked.AzureRawResult = null;
            tracked.AzureConfidenceScores?.Dispose();
            tracked.AzureConfidenceScores = null;
            tracked.AzureStatus = OcrStatus.Pending;
            tracked.AzureErrorMessage = null;
            tracked.AmountValidationResult?.Dispose();
            tracked.AmountValidationResult = null;
            tracked.AmountValidationStatus = AmountValidationStatus.Pending;
            tracked.AmountValidationErrorMessage = null;
            tracked.AmountValidatedAt = null;
            tracked.UpdatedAt = DateTime.UtcNow;

            await DbContext.SaveChangesAsync();
            await OcrWorker.EnqueueAsync(tracked.Id);

            _current.OcrStatus = CheckOcrStatus.Recognizing;
            _current.RawResult = null;
            _current.ConfidenceScores = new(StringComparer.OrdinalIgnoreCase);
            _ocrCopyPanelText = "";
            ClearForm();

            Snackbar.Add("已重新提交 OCR 任务", Severity.Info);

            // 重新开始轮询
            _ = PollOcrStatusAsync(_current, _cts.Token);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"重新提交失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _retryingOcr = false;
        }
    }

    private async Task RunAmountValidationAsync()
    {
        if (_current?.OcrResultId == null) return;
        if (_amount <= 0m)
        {
            Snackbar.Add("请先确认金额后再执行手写金额校验", Severity.Warning);
            return;
        }

        _amountValidationRunning = true;
        try
        {
            var tracked = await DbContext.OcrResults.FirstOrDefaultAsync(x => x.Id == _current.OcrResultId.Value);
            if (tracked == null)
            {
                Snackbar.Add("未找到 OCR 记录", Severity.Error);
                return;
            }

            var oldStatus = tracked.AmountValidationStatus;
            var oldError = tracked.AmountValidationErrorMessage;
            var oldResult = tracked.AmountValidationResult?.RootElement.GetRawText();

            var result = await OcrService.ValidateHandwrittenAmountAsync(tracked.ImageUrl, _amount);
            tracked.AmountValidationResult?.Dispose();
            tracked.AmountValidationResult = JsonDocument.Parse(JsonSerializer.Serialize(result));
            tracked.AmountValidationStatus = result.Status.Equals("completed", StringComparison.OrdinalIgnoreCase)
                ? AmountValidationStatus.Completed
                : result.Status.Equals("skipped", StringComparison.OrdinalIgnoreCase)
                    ? AmountValidationStatus.Skipped
                    : AmountValidationStatus.Failed;
            tracked.AmountValidationErrorMessage = result.Reason;
            tracked.AmountValidatedAt = DateTime.UtcNow;
            tracked.UpdatedAt = DateTime.UtcNow;

            await DbContext.SaveChangesAsync();
            await AuditLog.LogAsync(
                AuditAction.Update,
                "OcrResult",
                tracked.Id,
                new
                {
                    AmountValidationStatus = oldStatus.ToString(),
                    AmountValidationErrorMessage = oldError,
                    AmountValidationResult = oldResult
                },
                new
                {
                    AmountValidationStatus = tracked.AmountValidationStatus.ToString(),
                    AmountValidationErrorMessage = tracked.AmountValidationErrorMessage,
                    AmountValidationResult = tracked.AmountValidationResult?.RootElement.GetRawText(),
                    Trigger = "Manual"
                });

            _ocrResult = tracked;
            Snackbar.Add("手写金额校验已完成", Severity.Success);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"手写金额校验失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _amountValidationRunning = false;
        }
    }

    private async Task SaveCurrent(bool submitAsFinal)
    {
        if (_saving || _current == null) return;
        _saving = true;

        try
        {
            var error = await ValidateFormAsync(submitAsFinal);
            if (!string.IsNullOrEmpty(error))
            {
                Snackbar.Add(error, Severity.Warning);
                return;
            }

            var customer = await ResolveCustomerAsync();
            var mismatch = CheckMasterDataComparer.HasMismatch(
                customer,
                NullIfEmpty(_bankName),
                NullIfEmpty(_accountHolderName),
                NullIfEmpty(_companyName),
                NullIfEmpty(_accountNumber),
                NullIfEmpty(_accountAddress));
            if (mismatch)
                Snackbar.Add("与客户主数据中的期望银行/账号/持有人/公司/地址不一致，已标记警告。", Severity.Warning);

            var registeredCompanies = customer.CompanyNames.Select(x => x.CompanyName).ToList();
            var companyWarn = !CustomerCompanyNameRules.IsRegisteredCompany(registeredCompanies, _companyName);

            var capturedImageUrl = _current.ImageUrl;
            var capturedOcrResultId = _current.OcrResultId;
            var checkDateUtc = DateTime.SpecifyKind(_checkDate!.Value, DateTimeKind.Utc);

            var check = new CheckRecord
            {
                CheckNumber = _checkNumber,
                CheckAmount = _amount,
                CheckDate = checkDateUtc,
                Customer = customer,
                ImageUrl = capturedImageUrl,
                OcrResultId = capturedOcrResultId,
                Notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes.Trim(),
                Status = CheckStatus.PendingDebit,
                RowVersion = 0,
                BankName = NullIfEmpty(_bankName),
                RoutingNumber = NullIfEmpty(_routingNumber),
                AccountNumber = NullIfEmpty(_accountNumber),
                AccountType = NullIfEmpty(_accountType),
                AccountHolderName = NullIfEmpty(_accountHolderName),
                AccountAddress = NullIfEmpty(_accountAddress),
                PayToOrderOf = NullIfEmpty(_payToOrderOf),
                ForMemo = NullIfEmpty(_forMemo),
                MicrLineRaw = NullIfEmpty(_micrLineRaw),
                CheckNumberMicr = NullIfEmpty(_checkNumberMicr),
                InvoiceNumbers = NullIfEmpty(_invoiceNumbers),
                PaymentPeriodText = NullIfEmpty(_paymentPeriodText),
                CompanyName = NullIfEmpty(_companyName),
                SubmittedAt = submitAsFinal ? DateTime.UtcNow : null,
                CustomerMasterMismatchWarning = mismatch,
                CustomerCompanyNewRelationshipWarning = companyWarn
            };

            DbContext.CheckRecords.Add(check);
            await DbContext.SaveChangesAsync();

            if (submitAsFinal)
            {
                await CheckSubmitOcrTrainingSamplePageHelper.TryAppendAfterCheckFinalSubmitAsync(
                    DbContext,
                    Configuration,
                    capturedImageUrl,
                    capturedOcrResultId,
                    _checkNumber.Trim(),
                    _amount,
                    checkDateUtc,
                    BuildSubmittedAchExtensionData());
            }

            _current.Done = true;
            Snackbar.Add(submitAsFinal
                ? "支票已提交入库！"
                : "支票草稿已保存。可稍后在「收款记录」中打开该笔，使用「编辑草稿」继续修改，或在收款记录中补全 Routing / Account 后「提交入库」。",
                Severity.Success);

            _current = _uploadQueue.FirstOrDefault(q => !q.Done);
            ClearForm();
            if (_current?.OcrStatus == CheckOcrStatus.Completed)
                PrefillForm(_current);
        }
        catch (DbUpdateConcurrencyException)
        {
            Snackbar.Add("数据已被其他用户修改，请刷新后重试", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveDraftWithMismatchReasonAsync()
    {
        if (!HasAmountValidationMismatch())
        {
            Snackbar.Add("当前不存在金额不一致，无需一键转草稿。", Severity.Info);
            return;
        }

        AppendMismatchReasonToNotes();
        await SaveCurrent(false);
    }

    private void AppendMismatchReasonToNotes()
    {
        const string marker = OcrAmountValidationNotes.MismatchDraftMarker;
        if (!string.IsNullOrWhiteSpace(_notes) && _notes.Contains(marker, StringComparison.Ordinal))
            return;

        var line = $"{marker} 时间:{DateTime.Now.ToString(OcrAmountValidationNotes.UiDateTimeFormat)}";
        _notes = string.IsNullOrWhiteSpace(_notes) ? line : $"{_notes.Trim()}\n{line}";
    }

    private void RemoveItem(QueueItem item)
    {
        _uploadQueue.Remove(item);

        // 如果删的是当前选中项，切换到下一个未完成的
        if (_current == item)
        {
            _current = _uploadQueue.FirstOrDefault(q => !q.Done);
            ClearForm();
            if (_current?.OcrStatus == CheckOcrStatus.Completed)
                PrefillForm(_current);
        }

        // 队列清空时重置到初始状态
        if (!_uploadQueue.Any())
            Reset();
    }

    private void SkipCurrent()
    {
        if (_current?.Uploading == true)
        {
            Snackbar.Add("当前文件仍在上传，暂时无法跳过", Severity.Info);
            return;
        }
        _current = _uploadQueue.FirstOrDefault(q => !q.Done && q != _current);
        ClearForm();
    }

    private CheckAchExtensionData BuildSubmittedAchExtensionData() =>
        new(
            NullIfEmpty(_routingNumber),
            NullIfEmpty(_accountNumber),
            NullIfEmpty(_bankName),
            NullIfEmpty(_accountHolderName),
            NullIfEmpty(_accountAddress),
            NullIfEmpty(_accountType),
            NullIfEmpty(_payToOrderOf),
            NullIfEmpty(_forMemo),
            NullIfEmpty(_micrLineRaw),
            NullIfEmpty(_checkNumberMicr),
            null,
            NullIfEmpty(_companyName));

    private async Task<string?> ValidateFormAsync(bool submitAsFinal)
    {
        if (_current == null || string.IsNullOrEmpty(_current.ImageUrl))
            return "当前文件尚未上传完成";
        if (string.IsNullOrWhiteSpace(_checkNumber))
            return "支票号不能为空";
        if (_amount <= 0)
            return "金额必须大于 0";
        if (!_checkDate.HasValue)
            return "请选择支票日期";
        if (string.IsNullOrWhiteSpace(_customerCode))
            return "请输入客户账号";
        if (string.IsNullOrWhiteSpace(_customerPhone))
            return "请输入客户手机号";
        if (submitAsFinal)
        {
            if (HasAmountValidationMismatch())
                return OcrAmountValidationNotes.MismatchSubmitBlockedReason;
            if (string.IsNullOrWhiteSpace(_routingNumber) || _routingNumber.Length != 9 || !_routingNumber.All(char.IsDigit))
                return "提交入库时 Routing Number 须为 9 位数字";
            if (string.IsNullOrWhiteSpace(_accountNumber))
                return "提交入库时请填写 Account Number";
        }

        var exists = await DbContext.CheckRecords.AnyAsync(c => c.CheckNumber == _checkNumber);
        if (exists)
            return $"支票号 {_checkNumber} 已存在";

        return null;
    }

    private static string? NullIfEmpty(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private Customer? GetCustomerMatch()
    {
        if (string.IsNullOrWhiteSpace(_customerCode)) return null;
        var code = _customerCode.Trim();
        return _customers.FirstOrDefault(c => c.CustomerCode.Equals(code, StringComparison.OrdinalIgnoreCase));
    }

    private bool ShowNewCompanyRelationshipWarning()
    {
        var match = GetCustomerMatch();
        if (match == null || string.IsNullOrWhiteSpace(_companyName)) return false;
        var names = match.CompanyNames.Select(cn => cn.CompanyName);
        return !CustomerCompanyNameRules.IsRegisteredCompany(names, _companyName);
    }

    /// <summary>OCR 结果 JSON 中是否含有非空 AccountNumber（按当前选择的引擎）。</summary>
    private bool CurrentOcrJsonHasAccountNumber()
    {
        if (_current == null || _current.OcrStatus != CheckOcrStatus.Completed) return false;
        var doc = GetPreferredOcrDocument(_current);
        if (doc == null) return false;
        return !string.IsNullOrWhiteSpace(ExtractString(doc.RootElement, "AccountNumber"));
    }

    /// <summary>OCR 未识别账号，或当前账号/公司组合未在客户主数据中登记。</summary>
    private bool ShowCustomerAuthorizationHint()
    {
        if (_current == null || _current.OcrStatus != CheckOcrStatus.Completed) return false;

        if (!CurrentOcrJsonHasAccountNumber())
            return true;

        if (string.IsNullOrWhiteSpace(_customerCode))
            return false;

        var match = GetCustomerMatch();
        if (match == null)
            return true;

        if (ShowNewCompanyRelationshipWarning())
            return true;

        return false;
    }

    private async Task<Customer> ResolveCustomerAsync()
    {
        var code = _customerCode.Trim();
        var existing = await DbContext.Customers
            .Include(c => c.CompanyNames)
            .FirstOrDefaultAsync(c => c.CustomerCode == code);
        if (existing != null)
        {
            var phone = _customerPhone.Trim();
            if (!string.Equals(existing.MobilePhone, phone, StringComparison.Ordinal))
            {
                existing.MobilePhone = phone;
                existing.UpdatedAt = DateTime.UtcNow;
                var mem = _customers.FirstOrDefault(x => x.Id == existing.Id);
                if (mem != null) mem.MobilePhone = phone;
            }

            return existing;
        }

        var ocrCompany = OcrCheckCustomerFields.MergeHolderCompanyDisplayName(_companyName, _accountHolderName, _payToOrderOf);
        var ocrCompanyTrim = string.IsNullOrWhiteSpace(ocrCompany) ? null : ocrCompany.Trim();
        var displayName = ocrCompanyTrim ?? code;

        var customer = new Customer
        {
            CustomerCode = code,
            CustomerName = displayName,
            MobilePhone = _customerPhone.Trim(),
            ExpectedBankName = NullIfEmpty(_bankName),
            ExpectedAccountHolderName = ocrCompanyTrim,
            ExpectedCompanyName = ocrCompanyTrim,
            ExpectedAccountAddress = NullIfEmpty(_accountAddress),
            IsActive = true,
            IsAuthorized = false,
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow
        };
        if (ocrCompanyTrim != null)
        {
            customer.CompanyNames.Add(new CustomerCompanyName { CompanyName = ocrCompanyTrim });
        }

        DbContext.Customers.Add(customer);
        _customers.Add(customer);
        return customer;
    }

    private void ClearForm()
    {
        _checkNumber = "";
        _amount = 0;
        _checkDate = null;
        _customerCode = "";
        _customerPhone = "";
        _notes = "";
        _routingNumber = _accountNumber = _bankName = _accountHolderName = _accountAddress = "";
        _accountType = _payToOrderOf = _forMemo = _micrLineRaw = _checkNumberMicr = "";
        _invoiceNumbers = _paymentPeriodText = "";
        _companyName = "";
        _confidenceScores = new(StringComparer.OrdinalIgnoreCase);
    }

    private bool IsFormEmpty() =>
        string.IsNullOrEmpty(_checkNumber) && _amount <= 0 && string.IsNullOrEmpty(_customerCode)
        && string.IsNullOrEmpty(_routingNumber) && string.IsNullOrEmpty(_accountNumber);

    private void Reset()
    {
        _uploadQueue.Clear();
        _current = null;
        ClearForm();
    }

    // ── 置信度相关 ────────────────────────────────────────────────

    private double GetConfidence(string field)
    {
        var key = MapConfidenceKey(field);
        if (_confidenceScores.TryGetValue(key, out var v)) return v;
        return _confidenceScores.TryGetValue(field, out var v2) ? v2 : 0;
    }

    private static string MapConfidenceKey(string field) => field switch
    {
        "checkNumber" => "CheckNumber",
        "amount" => "Amount",
        "date" => "Date",
        "routingNumber" => "RoutingNumber",
        "accountNumber" => "AccountNumber",
        "bankName" => "BankName",
        "accountHolderName" => "AccountHolderName",
        "accountAddress" => "AccountAddress",
        "accountType" => "AccountType",
        "payToOrderOf" => "PayToOrderOf",
        "forMemo" => "ForMemo",
        "micrLineRaw" => "MicrLineRaw",
        "checkNumberMicr" => "CheckNumberMicr",
        "companyName" => "CompanyName",
        _ => field
    };

    private string GetFieldStyle(string field)
    {
        if (_confidenceScores.Count == 0) return string.Empty;
        return GetConfidence(field) switch
        {
            >= 0.85 => "border-color:#4caf50!important",
            >= 0.60 => "border-color:#ff9800!important",
            _ => "border-color:#f44336!important"
        };
    }

    private string GetFieldHint(string field)
    {
        if (_confidenceScores.Count == 0) return string.Empty;
        return GetConfidence(field) switch
        {
            >= 0.85 => string.Empty,
            >= 0.60 => "请复核此字段",
            _ => "识别不确定，请手动填写"
        };
    }

    private Adornment GetAdornment(string field)
    {
        var confidence = GetConfidence(field);
        return (confidence is > 0 and < 0.85 && _confidenceScores.Count > 0)
            ? Adornment.End : Adornment.None;
    }

    private Color GetAdornmentColor(string field)
        => GetConfidence(field) >= 0.60 ? Color.Warning : Color.Error;

    private string GetAdornmentIcon(string field)
        => GetConfidence(field) >= 0.60
            ? Icons.Material.Filled.Warning
            : Icons.Material.Filled.Error;

    private bool TryBuildAmountValidationHint(out Severity severity, out string text)
    {
        severity = Severity.Normal;
        text = string.Empty;
        if (_ocrResult == null || _current?.OcrStatus != CheckOcrStatus.Completed)
            return false;

        if (_ocrResult.AmountValidationStatus == AmountValidationStatus.Pending)
            return false;

        if (_ocrResult.AmountValidationStatus == AmountValidationStatus.Skipped)
        {
            severity = Severity.Info;
            text = _ocrResult.AmountValidationErrorMessage ?? "金额二次校验已跳过";
            return true;
        }

        if (_ocrResult.AmountValidationStatus == AmountValidationStatus.Failed)
        {
            severity = Severity.Warning;
            text = _ocrResult.AmountValidationErrorMessage ?? "金额二次校验失败，请人工复核";
            return true;
        }

        if (_ocrResult.AmountValidationResult == null)
            return false;

        try
        {
            var payload = _ocrResult.AmountValidationResult.RootElement.GetRawText();
            var result = JsonSerializer.Deserialize<AmountValidationResult>(payload);
            if (result == null) return false;

            var parsed = result.LegalAmountParsed.HasValue ? result.LegalAmountParsed.Value.ToString("N2") : "未解析";
            if (result.IsConsistent == true)
            {
                severity = Severity.Success;
                text = $"手写金额校验一致：数字金额 {_amount:N2}，手写解析 {parsed}（置信度 {result.Confidence:P0}）{BuildValidationTimeText()}";
            }
            else if (result.IsConsistent == false)
            {
                severity = Severity.Error;
                text = $"手写金额与数字金额不一致：数字金额 {_amount:N2}，手写解析 {parsed}（置信度 {result.Confidence:P0}）{BuildValidationTimeText()}";
            }
            else
            {
                severity = Severity.Warning;
                text = (result.Reason ?? "手写金额未能确定一致性，请人工复核") + BuildValidationTimeText();
            }

            return true;
        }
        catch
        {
            return false;
        }
    }

    private bool CanShowManualAmountValidationButton()
        => _current is { OcrStatus: CheckOcrStatus.Completed } && _amount > 0m;

    private string BuildValidationTimeText()
        => _ocrResult?.AmountValidatedAt is DateTime dt ? $"（最后校验：{dt.ToLocalTime().ToString(OcrAmountValidationNotes.UiDateTimeFormat)}）" : string.Empty;

    private bool HasAmountValidationMismatch()
    {
        if (_ocrResult?.AmountValidationResult == null) return false;
        try
        {
            var payload = _ocrResult.AmountValidationResult.RootElement.GetRawText();
            var result = JsonSerializer.Deserialize<AmountValidationResult>(payload);
            return result?.IsConsistent == false;
        }
        catch
        {
            return false;
        }
    }

    // ── JSON 解析工具 ─────────────────────────────────────────────

    private static Dictionary<string, double> ExtractConfidenceScores(OcrResult ocrResult)
    {
        var dict = new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);
        var confJson = ocrResult.RawResult != null
            ? ocrResult.ConfidenceScores
            : ocrResult.AzureConfidenceScores;

        if (confJson?.RootElement.ValueKind != JsonValueKind.Object)
            return dict;

        foreach (var prop in confJson.RootElement.EnumerateObject())
        {
            if (prop.Value.ValueKind == JsonValueKind.Number)
                dict[prop.Name] = prop.Value.GetDouble();
            else if (prop.Value.ValueKind == JsonValueKind.String &&
                     double.TryParse(prop.Value.GetString(), out var parsed))
                dict[prop.Name] = parsed;
        }
        return dict;
    }

    private static string ExtractString(JsonElement root, string name)
        => root.TryGetProperty(name, out var el) && el.ValueKind != JsonValueKind.Null
            ? el.GetString() ?? "" : "";

    private static decimal ExtractDecimal(JsonElement root, string name)
    {
        if (!root.TryGetProperty(name, out var el) || el.ValueKind == JsonValueKind.Null)
            return 0m;
        return el.ValueKind switch
        {
            JsonValueKind.Number => el.GetDecimal(),
            JsonValueKind.String when decimal.TryParse(el.GetString(), out var v) => v,
            _ => 0m
        };
    }

    private static DateTime? ExtractDate(JsonElement root, string name)
    {
        if (!root.TryGetProperty(name, out var el) || el.ValueKind == JsonValueKind.Null)
            return null;
        return el.ValueKind == JsonValueKind.String &&
               DateTime.TryParse(el.GetString(), out var d) ? d : null;
    }

    private static string GetProxyImageUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return string.Empty;
        return $"/api/ImageProxy?url={Uri.EscapeDataString(url)}";
    }

    public void Dispose() => _cts.Cancel();
}
