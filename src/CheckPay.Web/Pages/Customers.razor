@page "/customers"
@attribute [Authorize]
@using System.Text
@using CheckPay.Application.Common
@using CheckPay.Application.Common.Interfaces
@using CheckPay.Domain.Entities
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@inject IApplicationDbContext DbContext
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>客户管理 - CheckPay</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">客户管理</MudText>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudButton Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Download"
                   OnClick="ExportCsvAsync"
                   Disabled="@(_loading || _importing)">
            导出 CSV
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Description"
                   OnClick="DownloadTemplateAsync"
                   Disabled="@_importing">
            下载模板
        </MudButton>
        <InputFile id="customerCsvImport" OnChange="OnImportCsvAsync" accept=".csv,text/csv" hidden />
        <MudButton HtmlTag="label" Variant="Variant.Outlined" Color="Color.Secondary"
                   for="customerCsvImport"
                   Disabled="@(_loading || _importing)">
            导入 CSV
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="StartAddNew"
                   Disabled="@(_addingNew || _editingId.HasValue || _importing)">
            新增客户
        </MudButton>
    </MudStack>
</MudStack>

<MudTable Items="@_customers" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" T="Customer">
    <HeaderContent>
        <MudTh>客户账号</MudTh>
        <MudTh>客户名称</MudTh>
        <MudTh>关联公司</MudTh>
        <MudTh>关联银行</MudTh>
        <MudTh>期望地址</MudTh>
        <MudTh>状态</MudTh>
        <MudTh>授权</MudTh>
        <MudTh>操作</MudTh>
    </HeaderContent>
    <RowTemplate>
        @if (_editingId == context.Id)
        {
            @* 内联编辑行 *@
            <MudTd DataLabel="客户账号">
                <MudText Color="Color.Secondary">@context.CustomerCode</MudText>
            </MudTd>
            <MudTd DataLabel="客户名称">
                <MudStack Spacing="1">
                    <MudTextField @bind-Value="_editName" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="min-width:200px" />
                    <MudTextField @bind-Value="_editExpectedBank" Label="关联银行" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudTextField @bind-Value="_editOcrCompanyName" Label="票面公司名称（OCR 公司/持有人）" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    <MudTextField @bind-Value="_editExpectedAddress" Label="期望账户地址" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                </MudStack>
            </MudTd>
            <MudTd DataLabel="关联公司">
                <MudTextField @bind-Value="_editCompaniesRaw" Label="关联公司名称（每行一条）" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Lines="4" Style="min-width:220px" />
            </MudTd>
            <MudTd DataLabel="关联银行"><MudText Typo="Typo.caption" Color="Color.Secondary">见名称列</MudText></MudTd>
            <MudTd DataLabel="期望地址"><MudText Typo="Typo.caption" Color="Color.Secondary">见名称列</MudText></MudTd>
            <MudTd DataLabel="状态">
                <MudSelect @bind-Value="_editIsActive" Variant="Variant.Outlined" Margin="Margin.Dense"
                           Style="min-width:100px">
                    <MudSelectItem Value="true">活跃</MudSelectItem>
                    <MudSelectItem Value="false">停用</MudSelectItem>
                </MudSelect>
            </MudTd>
            <MudTd DataLabel="授权">
                @if (context.IsAuthorized)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">已授权</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                             Disabled="_addingNew"
                             OnClick="@(async () => await ConfirmAuthorizeAsync(context))"
                             title="点击设为已授权">
                        未授权
                    </MudChip>
                }
            </MudTd>
            <MudTd DataLabel="操作">
                <MudStack Row="true" Spacing="1">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                               OnClick="@(() => SaveEdit(context))">保存</MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="CancelEdit">取消</MudButton>
                </MudStack>
            </MudTd>
        }
        else
        {
            @* 只读行 *@
            <MudTd DataLabel="客户账号">@context.CustomerCode</MudTd>
            <MudTd DataLabel="客户名称">@context.CustomerName</MudTd>
            <MudTd DataLabel="关联公司">
                <MudText Typo="Typo.caption" Style="word-break:break-word">@DisplayCompanyNamesColumn(context)</MudText>
            </MudTd>
            <MudTd DataLabel="关联银行">@(context.ExpectedBankName ?? "—")</MudTd>
            <MudTd DataLabel="期望地址">
                <MudText Typo="Typo.caption" Style="word-break:break-word">@(context.ExpectedAccountAddress ?? "—")</MudText>
            </MudTd>
            <MudTd DataLabel="状态">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.IsActive ? Color.Success : Color.Default)">
                    @(context.IsActive ? "活跃" : "停用")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="授权">
                @if (context.IsAuthorized)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">已授权</MudChip>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                             Disabled="@(_editingId.HasValue || _addingNew)"
                             OnClick="@(async () => await ConfirmAuthorizeAsync(context))"
                             title="点击设为已授权">
                        未授权
                    </MudChip>
                }
            </MudTd>
            <MudTd DataLabel="操作">
                <MudStack Row="true" Spacing="1">
                    <MudButton Size="Size.Small" Variant="Variant.Outlined"
                               Disabled="@(_editingId.HasValue || _addingNew)"
                               OnClick="@(() => StartEdit(context))">编辑</MudButton>
                    @if (!context.IsAuthorized)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                   Disabled="@(_editingId.HasValue || _addingNew)"
                                   StartIcon="@Icons.Material.Filled.VerifiedUser"
                                   OnClick="@(async () => await ConfirmAuthorizeAsync(context))">确认授权</MudButton>
                    }
                    <AuthorizeView Roles="Admin" Context="_">
                        <Authorized>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error"
                                       Disabled="@(_editingId.HasValue || _addingNew)"
                                       StartIcon="@Icons.Material.Filled.DeleteOutline"
                                       OnClick="@(async () => await ConfirmDeleteCustomerAsync(context))"
                                       title="无关联支票与扣款时可删除">
                                删除
                            </MudButton>
                        </Authorized>
                    </AuthorizeView>
                    @if (context.IsActive)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                                   Disabled="@(_editingId.HasValue || _addingNew)"
                                   OnClick="@(() => ToggleActive(context))">停用</MudButton>
                    }
                    else
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                                   Disabled="@(_editingId.HasValue || _addingNew)"
                                   OnClick="@(() => ToggleActive(context))">启用</MudButton>
                    }
                </MudStack>
            </MudTd>
        }
    </RowTemplate>

    @* 新增行——在 FooterContent slot 内条件渲染 *@
    <FooterContent>
        @if (_addingNew)
        {
            <MudTd colspan="8">
                <MudGrid Class="pa-2" AlignItems="AlignItems.Center">
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="_newCode" Label="客户账号" Variant="Variant.Outlined"
                                      Margin="Margin.Dense" Placeholder="与支票 OCR账号一致" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudStack Spacing="1">
                            <MudTextField @bind-Value="_newName" Label="客户名称" Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                            <MudTextField @bind-Value="_newExpectedBank" Label="关联银行（可选）" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudTextField @bind-Value="_newOcrCompanyName" Label="票面公司名称（可选）" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudTextField @bind-Value="_newExpectedAddress" Label="期望地址（可选）" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="2" />
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="_newCompaniesRaw" Label="关联公司名称（每行一条，可选）" Variant="Variant.Outlined"
                                      Margin="Margin.Dense" Lines="4" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">保存后授权状态默认为「未授权」，需确认后变为已授权。</MudText>
                            <MudStack Row="true" Spacing="1">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                                           OnClick="SaveNew"
                                           Disabled="@(string.IsNullOrWhiteSpace(_newCode) || string.IsNullOrWhiteSpace(_newName))">
                                    保存
                                </MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="CancelNew">取消</MudButton>
                            </MudStack>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudTd>
        }
    </FooterContent>
</MudTable>

@code {
    private List<Customer> _customers = new();
    private bool _loading = true;
    private bool _importing;

    // 内联编辑状态
    private Guid? _editingId;
    private string _editName = "";
    private string _editExpectedBank = "";
    private string _editOcrCompanyName = "";
    private string _editExpectedAddress = "";
    private string _editCompaniesRaw = "";
    private bool _editIsActive;

    // 新增行状态
    private bool _addingNew;
    private string _newCode = "";
    private string _newName = "";
    private string _newExpectedBank = "";
    private string _newOcrCompanyName = "";
    private string _newExpectedAddress = "";
    private string _newCompaniesRaw = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task ExportCsvAsync()
    {
        try
        {
            var list = await DbContext.Customers
                .Include(c => c.CompanyNames)
                .OrderBy(c => c.CustomerCode)
                .ToListAsync();
            var bytes = CustomerCsvImportExport.ExportToUtf8BomBytes(list);
            var base64 = Convert.ToBase64String(bytes);
            var name = $"customers_{DateTime.UtcNow:yyyyMMddHHmmss}.csv";
            await JS.InvokeVoidAsync("downloadFile", name, "text/csv;charset=utf-8", base64);
            Snackbar.Add($"已导出 {list.Count} 条客户", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"导出失败：{ex.Message}", Severity.Error);
        }
    }

    private async Task DownloadTemplateAsync()
    {
        try
        {
            var bytes = CustomerCsvImportExport.TemplateUtf8BomBytes();
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", "customers_import_template.csv", "text/csv;charset=utf-8", base64);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"下载失败：{ex.Message}", Severity.Error);
        }
    }

    private async Task OnImportCsvAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("请上传 .csv 文件", Severity.Warning);
            return;
        }

        _importing = true;
        try
        {
            await using var stream = file.OpenReadStream(5_242_880);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var text = Encoding.UTF8.GetString(ms.ToArray());
            var (rows, errors) = CustomerCsvImportExport.Parse(text);
            if (errors.Count > 0)
            {
                Snackbar.Add(string.Join("；", errors.Take(10)), Severity.Error);
                return;
            }

            if (rows.Count == 0)
            {
                Snackbar.Add("没有可导入的数据行", Severity.Warning);
                return;
            }

            await ApplyCustomerImportAsync(rows);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"导入失败：{ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ApplyCustomerImportAsync(List<CustomerCsvImportRow> rows)
    {
        var codes = rows.Select(r => r.CustomerCode).ToList();
        var existing = await DbContext.Customers
            .Include(c => c.CompanyNames)
            .Where(c => codes.Contains(c.CustomerCode))
            .ToListAsync();
        var dict = existing.ToDictionary(c => c.CustomerCode, StringComparer.OrdinalIgnoreCase);
        var now = DateTime.UtcNow;
        var inserted = 0;
        var updated = 0;

        foreach (var r in rows)
        {
            if (!dict.TryGetValue(r.CustomerCode, out var c))
            {
                var ocr = r.OcrCompanyName;
                c = new Customer
                {
                    CustomerCode = r.CustomerCode,
                    CustomerName = r.CustomerName,
                    ExpectedBankName = r.ExpectedBankName,
                    ExpectedAccountHolderName = ocr,
                    ExpectedCompanyName = ocr,
                    ExpectedAccountAddress = r.ExpectedAccountAddress,
                    IsActive = r.IsActive ?? true,
                    IsAuthorized = r.IsAuthorized ?? false
                };
                DbContext.Customers.Add(c);
                dict[r.CustomerCode] = c;
                inserted++;
                ReplaceCompanyNamesForImport(c, CustomerCsvImportExport.ParseCompanyNamesCell(r.CompanyNamesRaw));
            }
            else
            {
                c.CustomerName = r.CustomerName;
                c.ExpectedBankName = r.ExpectedBankName;
                var ocr2 = r.OcrCompanyName;
                c.ExpectedAccountHolderName = ocr2;
                c.ExpectedCompanyName = ocr2;
                c.ExpectedAccountAddress = r.ExpectedAccountAddress;
                if (r.IsActive.HasValue) c.IsActive = r.IsActive.Value;
                if (r.IsAuthorized.HasValue) c.IsAuthorized = r.IsAuthorized.Value;
                c.UpdatedAt = now;
                updated++;
                ReplaceCompanyNamesForImport(c, CustomerCsvImportExport.ParseCompanyNamesCell(r.CompanyNamesRaw));
            }
        }

        await DbContext.SaveChangesAsync();
        Snackbar.Add($"导入完成：新增 {inserted} 条，更新 {updated} 条", Severity.Success);
        CancelEdit();
        CancelNew();
        await LoadData();
    }

    private void ReplaceCompanyNamesForImport(Customer c, List<string> names)
    {
        var trackedNames = DbContext.CustomerCompanyNames.Where(x => x.CustomerId == c.Id).ToList();
        if (trackedNames.Count > 0)
            DbContext.CustomerCompanyNames.RemoveRange(trackedNames);
        foreach (var name in names)
        {
            DbContext.CustomerCompanyNames.Add(new CustomerCompanyName
            {
                CustomerId = c.Id,
                CompanyName = name
            });
        }
    }

    /// <summary>列表「关联公司」列：优先展示多名称表；无登记时回退票面 OCR 公司/持有人（与已删列信息不重复展示）。</summary>
    private static string DisplayCompanyNamesColumn(Customer c)
    {
        var lines = c.CompanyNames
            .OrderBy(x => x.CompanyName)
            .Select(x => x.CompanyName)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .ToList();
        if (lines.Count > 0)
            return string.Join("；", lines);

        var a = c.ExpectedCompanyName;
        var b = c.ExpectedAccountHolderName;
        if (string.IsNullOrWhiteSpace(a) && string.IsNullOrWhiteSpace(b)) return "—";
        if (string.IsNullOrWhiteSpace(a)) return b!;
        if (string.IsNullOrWhiteSpace(b)) return a!;
        return string.Equals(a, b, StringComparison.Ordinal) ? a! : $"{a} / {b}";
    }

    private async Task LoadData()
    {
        _loading = true;
        // 显示全部（含停用），管理员需要看到
        _customers = await DbContext.Customers
            .Include(c => c.CompanyNames)
            .OrderBy(c => c.CustomerCode)
            .ToListAsync();
        _loading = false;
    }

    // 开始编辑某行
    private void StartEdit(Customer c)
    {
        _editingId = c.Id;
        _editName = c.CustomerName;
        _editExpectedBank = c.ExpectedBankName ?? "";
        _editOcrCompanyName = c.ExpectedCompanyName ?? c.ExpectedAccountHolderName ?? "";
        _editExpectedAddress = c.ExpectedAccountAddress ?? "";
        _editIsActive = c.IsActive;
        _editCompaniesRaw = string.Join(Environment.NewLine,
            c.CompanyNames.OrderBy(x => x.CompanyName).Select(x => x.CompanyName));
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editName = "";
        _editExpectedBank = "";
        _editOcrCompanyName = "";
        _editExpectedAddress = "";
        _editCompaniesRaw = "";
    }

    private static List<string> ParseCompanyLines(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return new List<string>();
        return raw
            .Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(s => s.Trim())
            .Where(s => s.Length > 0)
            .GroupBy(CustomerCompanyNameRules.NormalizeKey)
            .Select(g => g.First())
            .ToList();
    }

    private async Task SaveEdit(Customer c)
    {
        if (string.IsNullOrWhiteSpace(_editName)) return;

        c.CustomerName = _editName.Trim();
        c.ExpectedBankName = string.IsNullOrWhiteSpace(_editExpectedBank) ? null : _editExpectedBank.Trim();
        var ocrName = string.IsNullOrWhiteSpace(_editOcrCompanyName) ? null : _editOcrCompanyName.Trim();
        c.ExpectedAccountHolderName = ocrName;
        c.ExpectedCompanyName = ocrName;
        c.ExpectedAccountAddress = string.IsNullOrWhiteSpace(_editExpectedAddress) ? null : _editExpectedAddress.Trim();
        c.IsActive = _editIsActive;
        c.UpdatedAt = DateTime.UtcNow;

        var lines = ParseCompanyLines(_editCompaniesRaw);
        var trackedNames = await DbContext.CustomerCompanyNames.Where(x => x.CustomerId == c.Id).ToListAsync();
        DbContext.CustomerCompanyNames.RemoveRange(trackedNames);
        foreach (var name in lines)
        {
            DbContext.CustomerCompanyNames.Add(new CustomerCompanyName
            {
                CustomerId = c.Id,
                CompanyName = name
            });
        }

        await DbContext.SaveChangesAsync();

        Snackbar.Add($"客户 {c.CustomerCode} 已保存", Severity.Success);
        CancelEdit();
        await LoadData();
    }

    private async Task ConfirmDeleteCustomerAsync(Customer c)
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall };
        var confirmed = await DialogService.ShowMessageBoxAsync(
            title: "确认删除客户",
            message: $"确定删除客户「{c.CustomerName}」（账号 {c.CustomerCode}）吗？须无未删除的支票（check_records）与银行扣款（debit_records）；删除支票后扣款导入记录仍可能占用该客户。删除客户为软删除。",
            yesText: "删除",
            noText: null,
            cancelText: "取消",
            options: options);

        if (confirmed != true)
            return;

        var hasChecks = await DbContext.CheckRecords.AnyAsync(r => r.CustomerId == c.Id && r.DeletedAt == null);
        var hasDebits = await DbContext.DebitRecords.AnyAsync(r => r.CustomerId == c.Id && r.DeletedAt == null);
        if (hasChecks && hasDebits)
        {
            Snackbar.Add("该客户下仍有支票记录与银行扣款记录，无法删除。请先处理或删除相关扣款（debit_records）与支票。", Severity.Error);
            return;
        }

        if (hasChecks)
        {
            Snackbar.Add("该客户下仍有支票记录，无法删除。", Severity.Error);
            return;
        }

        if (hasDebits)
        {
            Snackbar.Add("该客户下仍有银行扣款记录（导入扣款产生），即使支票已删也会占用客户。请在「导入扣款」或数据库中处理 debit_records 后再删客户。", Severity.Error);
            return;
        }

        var now = DateTime.UtcNow;
        var tracked = await DbContext.Customers
            .Include(x => x.CompanyNames)
            .FirstOrDefaultAsync(x => x.Id == c.Id);
        if (tracked == null)
        {
            Snackbar.Add("客户不存在或已删除", Severity.Error);
            await LoadData();
            return;
        }

        tracked.DeletedAt = now;
        tracked.UpdatedAt = now;
        foreach (var name in tracked.CompanyNames)
        {
            name.DeletedAt = now;
            name.UpdatedAt = now;
        }

        await DbContext.SaveChangesAsync();
        Snackbar.Add($"客户 {tracked.CustomerCode} 已删除", Severity.Success);
        await LoadData();
    }

    private async Task ConfirmAuthorizeAsync(Customer c)
    {
        if (c.IsAuthorized) return;

        var tracked = await DbContext.Customers.FirstOrDefaultAsync(x => x.Id == c.Id);
        if (tracked == null)
        {
            Snackbar.Add("客户不存在或已删除", Severity.Error);
            await LoadData();
            return;
        }

        tracked.IsAuthorized = true;
        tracked.UpdatedAt = DateTime.UtcNow;
        await DbContext.SaveChangesAsync();
        Snackbar.Add($"客户 {tracked.CustomerCode} 已设为已授权", Severity.Success);
        await LoadData();
    }

    // 停用/启用切换
    private async Task ToggleActive(Customer c)
    {
        c.IsActive = !c.IsActive;
        c.UpdatedAt = DateTime.UtcNow;
        await DbContext.SaveChangesAsync();
        Snackbar.Add(c.IsActive ? $"{c.CustomerName} 已启用" : $"{c.CustomerName} 已停用",
            c.IsActive ? Severity.Success : Severity.Warning);
        await LoadData();
    }

    // 新增行
    private void StartAddNew()
    {
        _addingNew = true;
        _newCode = "";
        _newName = "";
        _newExpectedBank = "";
        _newOcrCompanyName = "";
        _newExpectedAddress = "";
        _newCompaniesRaw = "";
    }

    private void CancelNew()
    {
        _addingNew = false;
        _newCode = "";
        _newName = "";
        _newExpectedBank = "";
        _newOcrCompanyName = "";
        _newExpectedAddress = "";
        _newCompaniesRaw = "";
    }

    private async Task SaveNew()
    {
        if (string.IsNullOrWhiteSpace(_newCode) || string.IsNullOrWhiteSpace(_newName)) return;

        var code = _newCode.Trim();
        var exists = await DbContext.Customers.AnyAsync(c => c.CustomerCode == code);
        if (exists)
        {
            Snackbar.Add($"客户账号 {code} 已存在", Severity.Error);
            return;
        }

        var ocrName = string.IsNullOrWhiteSpace(_newOcrCompanyName) ? null : _newOcrCompanyName.Trim();

        var customer = new Customer
        {
            CustomerCode = code,
            CustomerName = _newName.Trim(),
            ExpectedBankName = string.IsNullOrWhiteSpace(_newExpectedBank) ? null : _newExpectedBank.Trim(),
            ExpectedAccountHolderName = ocrName,
            ExpectedCompanyName = ocrName,
            ExpectedAccountAddress = string.IsNullOrWhiteSpace(_newExpectedAddress) ? null : _newExpectedAddress.Trim(),
            IsActive = true,
            IsAuthorized = false
        };
        DbContext.Customers.Add(customer);
        await DbContext.SaveChangesAsync();

        foreach (var name in ParseCompanyLines(_newCompaniesRaw))
        {
            DbContext.CustomerCompanyNames.Add(new CustomerCompanyName
            {
                CustomerId = customer.Id,
                CompanyName = name
            });
        }

        await DbContext.SaveChangesAsync();

        Snackbar.Add($"客户 {customer.CustomerCode} 已新增", Severity.Success);
        CancelNew();
        await LoadData();
    }
}
