@page "/debits/import"
@attribute [Authorize(Roles = "USFinance,Admin")]
@using CheckPay.Application.Common.Interfaces
@using CheckPay.Application.Common
@using CheckPay.Domain.Entities
@using CheckPay.Domain.Enums
@using CheckPay.Web.Common
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@inject IApplicationDbContext DbContext
@inject IJSRuntime JS
@inject IBlobStorageService BlobStorage
@inject IOcrService OcrService
@inject ISnackbar Snackbar

<PageTitle>导入扣款 - CheckPay</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">导入扣款记录</MudText>

@* 步骤一：批量上传区 *@
@if (!_uploadQueue.Any())
{
    <MudPaper Class="pa-6 text-center" Style="border:2px dashed #ccc">
        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Large" Color="Color.Primary" />
        <MudText Class="mt-2">选择或拖入扫描件（支持多张），上传后自动 OCR 识别</MudText>
        <InputFile id="scanBatch" OnChange="OnFilesSelected" accept="image/*" multiple hidden />
        <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" for="scanBatch">
            选择文件
        </MudButton>
    </MudPaper>
}
else
{
    @* 步骤二：待录入队列缩略图 *@
    <MudPaper Class="pa-4 mb-4">
        <MudText Typo="Typo.subtitle1" GutterBottom="true">
            待录入队列（@_uploadQueue.Count 张）— 已完成 @_uploadQueue.Count(q => q.Done) 张
        </MudText>
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
            @foreach (var item in _uploadQueue)
            {
                <div style="position:relative;width:100px">
                    <MudPaper @onclick="@(async () => await SelectItem(item))"
                              Elevation="item == _current ? 4 : 1"
                              Class="pa-2 text-center"
                              Style="@($"width:100px;cursor:pointer;border:2px solid {(item == _current ? "#1976d2" : item.Done ? "#4caf50" : "#e0e0e0")}")">
                        <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Medium"
                                 Color="@(item.Done ? Color.Success : Color.Default)" />
                        <MudText Typo="Typo.caption" Style="word-break:break-all">@item.FileName</MudText>
                        <MudText Typo="Typo.caption" Color="@(item.Done ? Color.Success : Color.Warning)">
                            @(item.Done ? "✅ 已录入" : "⏳ 待录入")
                        </MudText>
                    </MudPaper>
                    @if (!item.Uploading)
                    {
                        <span @onclick:stopPropagation="true"
                              style="position:absolute;top:-8px;right:-8px">
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           Style="background:white;padding:2px;width:20px;height:20px;min-width:0"
                                           OnClick="() => RemoveItem(item)" />
                        </span>
                    }
                </div>
            }
            @* 继续添加更多文件 *@
            <MudPaper Class="pa-2 text-center d-flex align-center justify-center"
                      Style="width:100px;cursor:pointer;border:2px dashed #ccc">
                <InputFile id="scanMore" OnChange="OnFilesSelected" accept="image/*" multiple hidden />
                <MudButton HtmlTag="label" for="scanMore" Style="min-width:0;padding:0">
                    <MudIcon Icon="@Icons.Material.Filled.Add" />
                </MudButton>
            </MudPaper>
        </MudStack>
    </MudPaper>

    @* 步骤三：左图右表单 *@
    @if (_current != null)
    {
        <MudGrid>
            @* 左：扫描件预览 + OCR 状态 *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" GutterBottom="true">扫描件预览</MudText>
                    @if (!string.IsNullOrEmpty(_current.ImageUrl))
                    {
                        <MudImage Src="@GetProxyImageUrl(_current.ImageUrl)" Alt="扫描件" Class="rounded" Style="max-width:100%" />
                        @* OCR 识别状态提示 *@
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mt-2" Spacing="1">
                            @if (_current.OcrStatus == DebitOcrStatus.Recognizing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Info" />
                                <MudText Typo="Typo.caption" Color="Color.Info">正在 OCR 识别，稍候...</MudText>
                            }
                            else if (_current.OcrStatus == DebitOcrStatus.Success)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.AutoFixHigh" Size="Size.Small" Color="Color.Success" />
                                <MudText Typo="Typo.caption" Color="Color.Success">OCR 识别完成，已预填表单</MudText>
                                <MudTooltip Text="对识别结果不满意？点击再次识别">
                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                                   Color="Color.Info" OnClick="ReOcrAsync"
                                                   Disabled="@_reOcring" />
                                </MudTooltip>
                            }
                            else if (_current.OcrStatus == DebitOcrStatus.Failed)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" Color="Color.Warning" />
                                <MudText Typo="Typo.caption" Color="Color.Warning">OCR 识别失败，请手动填写</MudText>
                                <MudTooltip Text="重新尝试 OCR 识别">
                                    <MudIconButton Icon="@Icons.Material.Filled.Refresh" Size="Size.Small"
                                                   Color="Color.Warning" OnClick="ReOcrAsync"
                                                   Disabled="@_reOcring" />
                                </MudTooltip>
                            }
                        </MudStack>
                    }
                    else if (_current.Uploading)
                    {
                        <MudProgressCircular Indeterminate="true" />
                        <MudText Class="mt-2">上传中...</MudText>
                    }
                </MudPaper>

                @if (!string.IsNullOrEmpty(_debitOcrCopyPanelText))
                {
                    <MudPaper Class="pa-4 mt-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                            <MudText Typo="Typo.h6">抽取全文 / 解析摘要</MudText>
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.ContentCopy"
                                       OnClick="CopyDebitOcrPanelAsync">
                                复制全部
                            </MudButton>
                        </MudStack>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">
                            与训练标注页相同格式，可整段复制后粘贴到备忘录或其它系统。
                        </MudText>
                        <MudPaper Class="pa-3" Style="background:#1e1e1e;border-radius:4px;overflow-x:auto;max-height:320px;overflow-y:auto">
                            <pre style="color:#d4d4d4;font-size:12px;margin:0;white-space:pre-wrap;word-break:break-all">@_debitOcrCopyPanelText</pre>
                        </MudPaper>
                    </MudPaper>
                }
            </MudItem>

            @* 右：录入表单 *@
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4">
                    <MudText Typo="Typo.h6" GutterBottom="true">录入信息</MudText>

                    <MudSelect T="Guid" Value="_customerId" ValueChanged="OnCustomerChanged"
                               Label="客户" Required="true" Class="mb-2">
                        @foreach (var c in _customers)
                        {
                            <MudSelectItem Value="@c.Id">@c.CustomerName · @CustomerDisplay.MobileOrDash(c.MobilePhone)</MudSelectItem>
                        }
                    </MudSelect>

                    @* 级联：选客户后展示该客户的待扣款支票，方便 OCR 失败时手动关联 *@
                    @if (_pendingChecks.Any())
                    {
                        <MudSelect T="Guid?" Value="_selectedCheckId" ValueChanged="OnCheckSelected"
                                   Label="从该客户待扣款支票中选择（可选）"
                                   Clearable="true" Class="mb-2"
                                   HelperText="@($"该客户共 {_pendingChecks.Count} 张待扣款支票")">
                            @foreach (var ck in _pendingChecks)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)ck.Id)">
                                    #@ck.CheckNumber — ＄@ck.CheckAmount.ToString("N2") — @ck.CheckDate.ToString("yyyy-MM-dd")
                                </MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (_customerId != Guid.Empty && !_loadingPendingChecks)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                            该客户暂无待扣款支票
                        </MudAlert>
                    }

                    @* 支票号——实时匹配状态 *@
                    <MudTextField @bind-Value="_checkNumber"
                                  Label="支票号"
                                  Required="true"
                                  Variant="Variant.Outlined"
                                  Class="mb-1"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_matchIcon"
                                  AdornmentColor="@_matchColor"
                                  OnBlur="CheckMatchAsync" />

                    @if (_matchedCheck != null)
                    {
                        <MudAlert Severity="Severity.Success" Dense="true" Class="mb-2">
                            已匹配：@_matchedCheck.Customer?.CustomerName（手机 @CustomerDisplay.MobileOrDash(_matchedCheck.Customer?.MobilePhone)）— ＄@_matchedCheck.CheckAmount.ToString("N2")
                        </MudAlert>
                        @* 对应支票详情，方便财务核对 *@
                        <MudPaper Class="pa-3 mb-3" Style="background:#f1f8e9;border-left:4px solid #4caf50">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Color="Color.Success" />
                                <MudText Typo="Typo.caption" Color="Color.Success"><strong>对应支票信息</strong></MudText>
                            </MudStack>
                            <MudSimpleTable Dense="true">
                                <tbody>
                                    <tr>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">客户</MudText></td>
                                        <td><MudText Typo="Typo.body2">@_matchedCheck.Customer?.CustomerName</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">客户手机号</MudText></td>
                                        <td><MudText Typo="Typo.body2">@CustomerDisplay.MobileOrDash(_matchedCheck.Customer?.MobilePhone)</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">支票号</MudText></td>
                                        <td><MudText Typo="Typo.body2"><strong>@_matchedCheck.CheckNumber</strong></MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">支票金额</MudText></td>
                                        <td><MudText Typo="Typo.body2" Color="Color.Primary">＄@_matchedCheck.CheckAmount.ToString("N2")</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">支票日期</MudText></td>
                                        <td><MudText Typo="Typo.body2">@_matchedCheck.CheckDate.ToString("yyyy-MM-dd")</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">状态</MudText></td>
                                        <td><MudChip T="string" Size="Size.Small" Color="Color.Warning">待扣款</MudChip></td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>
                        </MudPaper>
                    }
                    else if (_checkNumber.Length > 0 && _checkedOnce)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                            未找到匹配支票，录入后将进入异常列表
                        </MudAlert>
                    }

                    <MudNumericField @bind-Value="_amount" Label="扣款金额" Required="true" Format="N2" Class="mb-2" />
                    @if (_matchedCheck != null && _amount > 0 && Math.Abs(_matchedCheck.CheckAmount - _amount) > 0.01m)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                            扣款金额（＄@_amount.ToString("N2")）与支票金额（＄@_matchedCheck.CheckAmount.ToString("N2")）不一致，差额 ＄@(Math.Abs(_matchedCheck.CheckAmount - _amount).ToString("N2"))，请确认后录入
                        </MudAlert>
                    }
                    <MudDatePicker @bind-Date="_debitDate" Label="扣款日期" Required="true" Class="mb-2" />
                    <MudTextField @bind-Value="_bankReference" Label="银行流水号" Required="true" Class="mb-2" />
                    <MudTextField @bind-Value="_notes" Label="备注" Lines="2" Class="mb-4" />

                    @* OCR 训练标注：仅在 OCR 识别完成后显示 *@
                    @if (_current?.OcrStatus == DebitOcrStatus.Success && _current.OcrResult != null)
                    {
                        <MudDivider Class="my-3" />
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.School" Size="Size.Small" Color="Color.Info" />
                            <MudText Typo="Typo.subtitle2" Color="Color.Info">OCR 训练标注</MudText>
                        </MudStack>
                        <MudCheckBox @bind-Value="_saveOcrSample" Color="Color.Info" Dense="true" Class="mb-2">
                            <MudText Typo="Typo.body2">同时保存 OCR 训练样本（帮助提升识别率）</MudText>
                        </MudCheckBox>
                        @if (_saveOcrSample)
                        {
                            <MudSimpleTable Dense="true" Class="mb-3" Style="font-size:12px">
                                <thead>
                                    <tr>
                                        <th style="width:70px">字段</th>
                                        <th>OCR 识别值</th>
                                        <th>当前录入值</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><MudText Typo="Typo.caption">支票号</MudText></td>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">@(_current.OcrResult.CheckNumber ?? "—")</MudText></td>
                                        <td><MudText Typo="Typo.caption" Color="@OcrDiffColor(_current.OcrResult.CheckNumber, _checkNumber)">@(string.IsNullOrEmpty(_checkNumber) ? "—" : _checkNumber)</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.caption">金额</MudText></td>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">@(_current.OcrResult.Amount.HasValue ? $"${_current.OcrResult.Amount:N2}" : "—")</MudText></td>
                                        <td><MudText Typo="Typo.caption" Color="@OcrDiffColor(_current.OcrResult.Amount?.ToString("N2"), _amount > 0 ? _amount.ToString("N2") : null)">@(_amount > 0 ? $"${_amount:N2}" : "—")</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.caption">日期</MudText></td>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">@(_current.OcrResult.Date?.ToString("yyyy-MM-dd") ?? "—")</MudText></td>
                                        <td><MudText Typo="Typo.caption" Color="@OcrDiffColor(_current.OcrResult.Date?.ToString("yyyy-MM-dd"), _debitDate?.ToString("yyyy-MM-dd"))">@(_debitDate?.ToString("yyyy-MM-dd") ?? "—")</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.caption">流水号</MudText></td>
                                        <td><MudText Typo="Typo.caption" Color="Color.Secondary">@(_current.OcrResult.BankReference ?? "—")</MudText></td>
                                        <td><MudText Typo="Typo.caption" Color="@OcrDiffColor(_current.OcrResult.BankReference, _bankReference)">@(string.IsNullOrEmpty(_bankReference) ? "—" : _bankReference)</MudText></td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>
                        }
                    }

                    <MudButton Variant="Variant.Outlined" Class="mr-2" OnClick="SkipCurrent"
                               Disabled="@(_current?.Uploading == true)">跳过</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SaveCurrent"
                               Disabled="@(_saving || _current?.Uploading == true)">
                        @(_saving ? "保存中..." : "确认录入 ✓")
                    </MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else if (_uploadQueue.All(q => q.Done))
    {
        <MudAlert Severity="Severity.Success" Class="mt-4">
            所有扫描件录入完成！共处理 @_uploadQueue.Count 张，
            匹配 @_uploadQueue.Count(q => q.Matched) 张，
            进入异常列表 @_uploadQueue.Count(q => !q.Matched) 张。
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                   OnClick="Reset">继续导入</MudButton>
    }
}

@code {
    private enum DebitOcrStatus { Idle, Recognizing, Success, Failed }

    // 队列项
    private class QueueItem
    {
        public string FileName { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public bool Uploading { get; set; }
        public bool Done { get; set; }
        public bool Matched { get; set; }
        public DebitOcrStatus OcrStatus { get; set; } = DebitOcrStatus.Idle;
        public DebitOcrResultDto? OcrResult { get; set; }
    }

    private List<QueueItem> _uploadQueue = new();
    private QueueItem? _current;

    private List<Customer> _customers = new();
    private Guid _customerId;
    private List<CheckRecord> _pendingChecks = new();
    private Guid? _selectedCheckId;
    private bool _loadingPendingChecks;
    private string _checkNumber = "";
    private decimal _amount;
    private DateTime? _debitDate;
    private string _bankReference = "";
    private string _notes = "";
    private bool _saving;
    private bool _checkedOnce;
    private bool _reOcring;
    private bool _saveOcrSample = true;
    private string _debitOcrCopyPanelText = "";

    // 实时匹配状态
    private CheckRecord? _matchedCheck;
    private string _matchIcon = Icons.Material.Filled.HelpOutline;
    private Color _matchColor = Color.Default;

    protected override async Task OnInitializedAsync()
    {
        _customers = await DbContext.Customers.Where(c => c.IsActive).ToListAsync();
    }

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        // 必须先把所有文件读入内存，再触发任何 StateHasChanged。
        // 原因：第一次 StateHasChanged 会因 _uploadQueue.Any() 变 true 而切换整个 DOM
        // （上传区 → 队列视图），InputFile 组件被替换，JS 文件引用失效，后续读流必崩。
        var snapshots = new List<(string Name, byte[] Data)>();
        foreach (var file in e.GetMultipleFiles(20))
        {
            try
            {
                using var raw = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                using var ms = new MemoryStream();
                await raw.CopyToAsync(ms);
                snapshots.Add((file.Name, ms.ToArray()));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"读取 {file.Name} 失败: {ex.Message}", Severity.Error);
            }
        }

        // 文件数据已在内存中，现在可以安全地更新 UI 并上传
        foreach (var (name, data) in snapshots)
        {
            var item = new QueueItem { FileName = name, Uploading = true };
            _uploadQueue.Add(item);
            if (_current == null) _current = item;
            StateHasChanged();

            try
            {
                using var ms = new MemoryStream(data);
                item.ImageUrl = await BlobStorage.UploadAsync(ms, name);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"上传 {name} 失败: {ex.Message}", Severity.Error);
            }
            finally
            {
                item.Uploading = false;
                StateHasChanged();
            }

            // 上传成功后异步触发 OCR（不阻塞后续文件上传）
            if (!string.IsNullOrEmpty(item.ImageUrl))
                _ = TriggerOcrAsync(item);
        }
    }

    /// <summary>再次识别：清空表单中的 OCR 预填内容，重新触发 OCR 识别</summary>
    private async Task ReOcrAsync()
    {
        if (_current == null || string.IsNullOrEmpty(_current.ImageUrl) || _reOcring) return;

        _reOcring = true;
        // 清空当前表单，让 OCR 重新预填
        ClearForm();
        // 重置 OCR 状态，准备重新识别
        _current.OcrStatus = DebitOcrStatus.Idle;
        _current.OcrResult = null;
        _debitOcrCopyPanelText = "";
        StateHasChanged();

        try
        {
            await TriggerOcrAsync(_current);
        }
        finally
        {
            _reOcring = false;
            StateHasChanged();
        }
    }

    /// <summary>后台异步 OCR 识别，完成后自动预填当前选中表单</summary>
    private async Task TriggerOcrAsync(QueueItem item)
    {
        item.OcrStatus = DebitOcrStatus.Recognizing;
        if (_current == item)
            _debitOcrCopyPanelText = "";
        StateHasChanged();
        try
        {
            item.OcrResult = await OcrService.ProcessDebitImageAsync(item.ImageUrl);
            item.OcrStatus = DebitOcrStatus.Success;
            // 当前选中且表单还是空的，自动预填
            if (_current == item && IsFormEmpty())
                await ApplyOcrResultAsync(item.OcrResult);
        }
        catch
        {
            // OCR 失败不影响手动录入，留空让财务手填
            item.OcrStatus = DebitOcrStatus.Failed;
        }
        finally
        {
            if (_current == item)
                RefreshDebitOcrCopyPanelText();
            StateHasChanged();
        }
    }

    /// <summary>将 OCR 结果预填到表单（仅填空字段，不覆盖已手动输入的内容）</summary>
    private async Task ApplyOcrResultAsync(DebitOcrResultDto result)
    {
        var needMatch = false;
        if (!string.IsNullOrEmpty(result.CheckNumber) && string.IsNullOrEmpty(_checkNumber))
        {
            _checkNumber = result.CheckNumber;
            needMatch = true;
        }
        if (result.Amount.HasValue && result.Amount > 0 && _amount <= 0)
            _amount = result.Amount.Value;
        if (result.Date.HasValue && !_debitDate.HasValue)
            _debitDate = result.Date.Value;
        if (!string.IsNullOrEmpty(result.BankReference) && string.IsNullOrEmpty(_bankReference))
            _bankReference = result.BankReference;

        // OCR 识别出支票号时自动触发匹配
        if (needMatch)
            await CheckMatchAsync();
    }

    private bool IsFormEmpty() =>
        string.IsNullOrEmpty(_checkNumber) && _amount <= 0 && string.IsNullOrEmpty(_bankReference);

    private async Task SelectItem(QueueItem item)
    {
        if (item.Done) return;
        _current = item;
        ClearForm();
        // 切换时如果 OCR 已完成，立即预填
        if (item.OcrStatus == DebitOcrStatus.Success && item.OcrResult != null)
            await ApplyOcrResultAsync(item.OcrResult);
        RefreshDebitOcrCopyPanelText();
    }

    private void RefreshDebitOcrCopyPanelText()
    {
        if (_current?.OcrResult == null || _current.OcrStatus != DebitOcrStatus.Success)
        {
            _debitOcrCopyPanelText = "";
            return;
        }

        _debitOcrCopyPanelText = OcrDebitCopyPanelFormatter.Build(_current.OcrResult);
    }

    private async Task CopyDebitOcrPanelAsync()
    {
        if (string.IsNullOrEmpty(_debitOcrCopyPanelText)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _debitOcrCopyPanelText);
            Snackbar.Add("已复制到剪贴板", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"复制失败: {ex.Message}", Severity.Warning);
        }
    }

    /// <summary>客户切换时加载该客户的待扣款支票列表</summary>
    private async Task OnCustomerChanged(Guid customerId)
    {
        _customerId = customerId;
        _selectedCheckId = null;
        _pendingChecks = new();

        if (customerId == Guid.Empty) return;

        _loadingPendingChecks = true;
        _pendingChecks = await DbContext.CheckRecords
            .Include(c => c.Customer)
            .Where(c => c.CustomerId == customerId && c.Status == CheckStatus.PendingDebit)
            .OrderByDescending(c => c.CheckDate)
            .ToListAsync();
        _loadingPendingChecks = false;
    }

    /// <summary>从级联列表选中支票后，自动填充支票号 / 金额，并设置匹配状态</summary>
    private async Task OnCheckSelected(Guid? checkId)
    {
        _selectedCheckId = checkId;

        if (!checkId.HasValue)
        {
            // 清除选中状态，重置支票号相关字段
            _matchedCheck = null;
            _checkNumber = "";
            _matchIcon = Icons.Material.Filled.HelpOutline;
            _matchColor = Color.Default;
            _checkedOnce = false;
            return;
        }

        _matchedCheck = _pendingChecks.FirstOrDefault(c => c.Id == checkId);
        if (_matchedCheck == null) return;

        _checkNumber = _matchedCheck.CheckNumber;
        _matchIcon = Icons.Material.Filled.CheckCircle;
        _matchColor = Color.Success;
        _checkedOnce = true;

        // 只填空字段，不覆盖 OCR 已识别的金额
        if (_amount <= 0)
            _amount = _matchedCheck.CheckAmount;
    }

    private async Task CheckMatchAsync()
    {
        if (string.IsNullOrWhiteSpace(_checkNumber)) return;
        _checkNumber = CheckNumberGuard.Normalize(_checkNumber);
        _checkedOnce = true;

        var candidatesQuery = DbContext.CheckRecords
            .Include(c => c.Customer)
            .Where(c => c.CheckNumber == _checkNumber && c.Status == CheckStatus.PendingDebit);

        if (_customerId != Guid.Empty)
            candidatesQuery = candidatesQuery.Where(c => c.CustomerId == _customerId);

        var candidates = await candidatesQuery
            .OrderByDescending(c => c.CheckDate)
            .Take(2)
            .ToListAsync();

        if (candidates.Count > 1)
        {
            _matchedCheck = null;
            _matchIcon = Icons.Material.Filled.WarningAmber;
            _matchColor = Color.Warning;
            Snackbar.Add("同支票号存在多条待扣款记录，请先选择客户并从待扣款列表手动指定。", Severity.Warning);
            return;
        }

        _matchedCheck = candidates.FirstOrDefault();

        if (_matchedCheck != null)
        {
            _matchIcon = Icons.Material.Filled.CheckCircle;
            _matchColor = Color.Success;

            if (_customerId == Guid.Empty)
                _customerId = _matchedCheck.CustomerId;
            if (_amount <= 0)
                _amount = _matchedCheck.CheckAmount;
        }
        else
        {
            _matchIcon = Icons.Material.Filled.Cancel;
            _matchColor = Color.Error;
        }
    }

    private async Task SaveCurrent()
    {
        if (_saving) return;
        _saving = true;

        try
        {
            var validationError = ValidateCurrentEntry();
            if (!string.IsNullOrEmpty(validationError))
            {
                Snackbar.Add(validationError, Severity.Warning);
                return;
            }

            await CheckMatchAsync();
            var matchError = ValidateMatchedCheck();
            if (!string.IsNullOrEmpty(matchError))
            {
                Snackbar.Add(matchError, Severity.Error);
                return;
            }

            var debit = new DebitRecord
            {
                CustomerId = _customerId,
                CheckNumber = _checkNumber,
                DebitAmount = _amount,
                DebitDate = DateTime.SpecifyKind(_debitDate!.Value, DateTimeKind.Utc),
                BankReference = _bankReference,
                ScanImageUrl = _current!.ImageUrl,
                Notes = _notes,
                DebitStatus = _matchedCheck != null ? DebitStatus.Matched : DebitStatus.Unmatched,
                CheckRecordId = _matchedCheck?.Id
            };

            if (_matchedCheck != null)
                _matchedCheck.Status = CheckStatus.PendingReview;

            DbContext.DebitRecords.Add(debit);
            await DbContext.SaveChangesAsync();

            _current.Done = true;
            _current.Matched = _matchedCheck != null;

            // 顺手保存 OCR 训练样本
            if (_saveOcrSample && _current.OcrResult != null && !string.IsNullOrEmpty(_current.ImageUrl))
                await SaveOcrSampleAsync(_current.ImageUrl, _current.OcrResult);

            Snackbar.Add(_matchedCheck != null ? "匹配成功！" : "未匹配，已加入异常列表",
                _matchedCheck != null ? Severity.Success : Severity.Warning);

            _current = _uploadQueue.FirstOrDefault(q => !q.Done);
            ClearForm();

            // 自动预填下一张（如果 OCR 已完成）
            if (_current?.OcrStatus == DebitOcrStatus.Success && _current.OcrResult != null)
                await ApplyOcrResultAsync(_current.OcrResult);
        }
        catch (DbUpdateConcurrencyException)
        {
            Snackbar.Add("数据已被其他用户修改，请刷新后重试", Severity.Error);
            await CheckMatchAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"保存失败: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private string? ValidateCurrentEntry()
    {
        if (_current == null)
            return "请先选择扫描件";
        if (_current.Uploading || string.IsNullOrEmpty(_current.ImageUrl))
            return "当前文件仍在上传，请稍候";
        if (string.IsNullOrWhiteSpace(_checkNumber))
            return "请输入支票号";
        if (_customerId == Guid.Empty)
            return "请选择客户";
        if (_amount <= 0)
            return "请输入扣款金额";
        if (!_debitDate.HasValue)
            return "请选择扣款日期";
        if (string.IsNullOrWhiteSpace(_bankReference))
            return "请输入银行流水号";
        return null;
    }

    private string? ValidateMatchedCheck()
    {
        if (_matchedCheck == null)
            return null;

        if (_matchedCheck.CustomerId != _customerId)
            return "匹配支票的客户与录入客户不一致";

        return null;
    }

    private void RemoveItem(QueueItem item)
    {
        _uploadQueue.Remove(item);

        if (_current == item)
        {
            _current = _uploadQueue.FirstOrDefault(q => !q.Done);
            ClearForm();
            if (_current?.OcrStatus == DebitOcrStatus.Success && _current.OcrResult != null)
                _ = ApplyOcrResultAsync(_current.OcrResult);
        }

        if (!_uploadQueue.Any())
            Reset();
    }

    private void SkipCurrent()
    {
        if (_current?.Uploading == true)
        {
            Snackbar.Add("当前文件仍在上传，暂时无法跳过", Severity.Info);
            return;
        }

        _current = _uploadQueue.FirstOrDefault(q => !q.Done && q != _current);
        ClearForm();
    }

    private void ClearForm()
    {
        _checkNumber = "";
        _amount = 0;
        _debitDate = null;
        _bankReference = "";
        _notes = "";
        _customerId = Guid.Empty;
        _selectedCheckId = null;
        _pendingChecks = new();
        _matchedCheck = null;
        _matchIcon = Icons.Material.Filled.HelpOutline;
        _matchColor = Color.Default;
        _checkedOnce = false;
        _saveOcrSample = true;
    }

    private void Reset()
    {
        _uploadQueue.Clear();
        _current = null;
        ClearForm();
    }

    private static string GetProxyImageUrl(string? url)
    {
        if (string.IsNullOrEmpty(url)) return string.Empty;
        return $"/api/ImageProxy?url={Uri.EscapeDataString(url)}";
    }

    /// <summary>将当前录入值与 OCR 识别值对比后保存训练样本</summary>
    private async Task SaveOcrSampleAsync(string imageUrl, DebitOcrResultDto ocrResult)
    {
        try
        {
            var sample = new OcrTrainingSample
            {
                ImageUrl         = imageUrl,
                DocumentType     = "debit",
                OcrRawResponse   = string.Empty,
                OcrCheckNumber   = ocrResult.CheckNumber,
                OcrAmount        = ocrResult.Amount,
                OcrDate          = ocrResult.Date.HasValue ? DateTime.SpecifyKind(ocrResult.Date.Value, DateTimeKind.Utc) : null,
                OcrBankReference = ocrResult.BankReference,
                CorrectCheckNumber   = string.IsNullOrWhiteSpace(_checkNumber) ? null : _checkNumber.Trim(),
                CorrectAmount        = _amount > 0 ? _amount : null,
                CorrectDate          = _debitDate.HasValue ? DateTime.SpecifyKind(_debitDate.Value, DateTimeKind.Utc) : null,
                CorrectBankReference = string.IsNullOrWhiteSpace(_bankReference) ? null : _bankReference.Trim()
            };
            DbContext.OcrTrainingSamples.Add(sample);
            await DbContext.SaveChangesAsync();
            Snackbar.Add("OCR 训练样本已保存", Severity.Info);
        }
        catch (Exception ex)
        {
            // 样本保存失败不影响主流程，仅提示
            Snackbar.Add($"OCR 样本保存失败: {ex.Message}", Severity.Warning);
        }
    }

    private static Color OcrDiffColor(string? ocr, string? correct)
    {
        if (string.IsNullOrEmpty(correct)) return Color.Default;
        return string.Equals(ocr?.Trim(), correct?.Trim(), StringComparison.OrdinalIgnoreCase)
            ? Color.Success : Color.Warning;
    }
}
