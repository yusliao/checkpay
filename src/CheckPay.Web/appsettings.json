{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=checkpay;Username=admin;Password=admin123"
  },
  "Ocr": {
    "MaxRetries": 3,
    "RetryDelayMs": 3000,
    "Dedup": {
      "_comment": "支票上传按图像 SHA-256 复用已完成 OCR，跳过重复 Vision；MaxSourceAgeDays≤0 或不配置=不限制来源日期",
      "Enabled": true,
      "MaxSourceAgeDays": 0
    },
    "AmountValidation": {
      "Enabled": true,
      "TriggerConfidenceThreshold": 0.80,
      "FailOpen": true
    },
    "PrebuiltCheck": {
      "_comment": "EnrichPrimaryResult=true：每张支票主路径再调 prebuilt-check.us 全量融合（路由/账号/金额等），成功率优先；本地无外网或仅 CV Key 时可 false",
      "EnrichPrimaryResult": true,
      "AmountFallbackWhenVisionFails": true
    },
    "Micr": {
      "BottomBandSecondPassEnabled": true,
      "BottomBandMinNormCenterY": 0.78
    },
    "ImagePreprocess": {
      "_comment": "支票 MinIO 原图在 Azure Vision Read 前：纠倾 / 亮纸轴对齐裁剪 / 长边放大。默认 Enabled=true 以抬成功率；极慢环境可设 false",
      "Enabled": true,
      "DeskewEnabled": true,
      "DeskewMaxDegrees": 15,
      "DeskewMinApplyDegrees": 0.35,
      "DeskewStepDegrees": 1,
      "ContentTrimEnabled": true,
      "ContentMinCoverageRatio": 0.12,
      "ContentPaddingRatio": 0.02,
      "DeskewProbeMaxSide": 560,
      "MinMaxSidePixels": 1280,
      "MinMaxSideUpperClamp": 4096,
      "FallbackToOriginalOnError": true
    },
    "AmountRoiSecondPass": {
      "_comment": "首轮 Read 后按行框估算金额/大写带状 ROI。Mode=OnDemand 按置信/粘连触发；Always=每张有边界则必跑二次 Read（再耗一次 Vision）。PrebuiltCheckOnCrop=对同一块裁剪再调 prebuilt-check.us 参与多源仲裁",
      "Enabled": true,
      "Mode": "OnDemand",
      "VisionConfTrigger": 0.68,
      "MaxRoiNormArea": 0.55,
      "PrebuiltCheckOnCrop": true
    },
    "Training": {
      "_comment": "支票上传/复核「提交入库」成功后是否自动写入 ocr_training_samples；RequireDiff 为 true 时与 OCR 完全一致则不写入；Dedup 按 ocrResultId 已有自动样本则跳过；LogVerbosity=Minimal|Verbose|Off",
      "AutoSampleOnCheckSubmit": true,
      "AutoSampleRequireDiff": true,
      "AutoSampleDedupByOcrResultId": true,
      "AutoSampleLogVerbosity": "Minimal"
    },
    "CheckAzureTrainingCorrectionEnabled": true,
    "CheckAzureTrainingCorrectionMode": "Similarity",
    "CheckAzureTrainingCorrectionMinSimilarity": 0.80,
    "CheckAzureTrainingCorrectionSimilarityMaxFieldConfidence": 0.62,
    "CheckAzureTrainingCorrectionMaxScan": 40,
    "CheckAzureTrainingCorrectionPoolTake": 80,
    "CheckAzureTrainingCorrectionClusterMinSamples": 1,
    "CheckAzureTrainingCorrectionSampleMinAgeMinutes": 0,
    "CheckAzureTrainingCorrectionRequireTemplateMatch": true,
    "CheckAzureTrainingCorrectionSummaryEnabled": true,
    "CheckAzureTrainingCorrectionSummaryFlushMinutes": 15
  },
  "Minio": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin",
    "BucketName": "checkpay-files",
    "UseSSL": "false"
  },
  "Azure": {
    "BlobStorage": {
      "ConnectionString": "UseDevelopmentStorage=true",
      "ContainerName": "checkpay-files"
    },
    "DocumentIntelligence": {
      "Endpoint": "https://your-resource.cognitiveservices.azure.com/",
      "ApiKey": "your-api-key-here",
      "DocumentAnalysisEndpoint": "",
      "DocumentAnalysisApiKey": ""
    },
    "_comment": "Endpoint/ApiKey：Azure Vision Read（主 OCR）。可选 DocumentAnalysis*：手写金额校验用 Document Intelligence v4 模型 prebuilt-check.us；纯 CV 资源请另建 DI 并填此项（否则 401）；须用支持 v4 的 DI 资源（否则旧模型名会 404）"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "DataProtection": {
    "_comment": "认证 Cookie 与登录桥接 token 使用的密钥环；KeysDirectory 为空则用应用程序目录下 data-protection-keys。多实例需同一共享目录；可用环境变量 DATA_PROTECTION_KEYS_DIRECTORY",
    "KeysDirectory": ""
  },
  "AllowedHosts": "*"
}
